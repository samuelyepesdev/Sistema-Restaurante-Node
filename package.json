{
  "name": "ecl-fruver",
  "version": "1.0.0",
  "description": "Sistema de Facturación para ECL FRUVER",
  "main": "server.js",
  "bin": "server.js",
  "pkg": {
    "assets": [
      "views/**/*",
      "public/**/*",
      "node_modules/ejs/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . --public --target node18-win-x64",
    "migrate": "node scripts/run-migrations.js",
    "create-admin": "node scripts/create-admin.js",
    "create-test-users": "node scripts/create-test-users.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.9",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}

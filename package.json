{
  "name": "ecl-fruver",
  "version": "1.0.0",
  "description": "Sistema de Facturación para ECL FRUVER",
  "main": "server.js",
  "bin": "server.js",
  "pkg": {
    "assets": [
      "views/**/*",
      "public/**/*",
      "node_modules/ejs/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node scripts/run-migrations.js && node scripts/create-admin.js && node scripts/seed-doc-types.js && node scripts/seed-temas-parametros.js && node server.js",
    "dev": "nodemon server.js",
    "package": "pkg . --public --target node18-win-x64",
    "migrate": "node scripts/run-migrations.js",
    "seed:docs": "node scripts/seed-doc-types.js",
    "create-admin": "node scripts/create-admin.js",
    "create-test-users": "node scripts/create-test-users.js",
    "seed-tenants": "node scripts/seed-tenants-test.js",
    "stress": "artillery run stress-tests/artillery-stress.yml",
    "stress:quick": "artillery run stress-tests/artillery-quick.yml",
    "stress:report": "node -e \"require('fs').mkdirSync('stress-tests/reports',{recursive:true})\" && artillery run stress-tests/artillery-stress.yml --output stress-tests/reports/report.json && node stress-tests/generate-report-html.js stress-tests/reports/report.json",
    "stress:load": "node stress-tests/run-load.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.9",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "artillery": "^2.0.0",
    "autocannon": "^7.14.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.4"
  },
  "overrides": {
    "@opentelemetry/api": "1.9.0"
  }
}

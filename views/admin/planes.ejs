<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Planes y Add-ons - Superadmin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/admin/planes.css">
</head>

<body>
    <%- include('../partials/navbar', { user, tenant: null, currentAdminPage: 'planes' }) %>

        <div class="container-fluid py-4">
            <div class="page-header d-flex align-items-center gap-3">
                <div
                    style="width:42px;height:42px;background:linear-gradient(135deg,#6366f1,#4f46e5);border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-layers-fill text-white fs-5"></i>
                </div>
                <div>
                    <h1>Planes &amp; Add-ons</h1>
                    <p class="text-muted mb-0 small">Gestiona planes de suscripcion y modulos adicionales por
                        restaurante.</p>
                </div>
                <div class="ms-auto">
                    <a href="/admin/planes/exportar-pdf" class="btn btn-outline-danger shadow-sm border-0 bg-white"
                        target="_blank">
                        <i class="bi bi-file-earmark-pdf-fill me-1"></i>Exportar Portafolio (PDF)
                    </a>
                </div>
            </div>

            <ul class="nav nav-tabs" id="tabs">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabR">
                        <i class="bi bi-building me-1"></i>Restaurantes
                        <span class="badge bg-primary ms-1">
                            <%= tenants ? tenants.length : 0 %>
                        </span>
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabP">
                        <i class="bi bi-box me-1"></i>Planes
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabA">
                        <i class="bi bi-puzzle me-1"></i>Add-ons
                        <span class="badge bg-secondary ms-1">
                            <%= addons ? addons.length : 0 %>
                        </span>
                    </button>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Tab Restaurantes -->
                <%- include('planes/_tab_restaurantes', { ...locals, tenants }) %>

                    <!-- Tab Planes -->
                    <%- include('planes/_tab_planes', { ...locals, plans }) %>

                        <!-- Tab Add-ons -->
                        <%- include('planes/_tab_addons', { ...locals, addons }) %>
            </div>
        </div>

        <!-- Modales -->
        <%- include('planes/_modal_gestionar', { ...locals, addons, plans }) %>

            <!-- Scripts -->
            <%- include('planes/_scripts', { ...locals, serverData }) %>
</body>

</html>
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Planes y Add-ons - Superadmin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background: #f1f5f9;
            min-height: 100vh;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .page-header {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, .08);
            padding: 1.4rem 2rem;
            margin-bottom: 1.4rem;
            border-left: 4px solid #6366f1;
        }

        .page-header h1 {
            font-weight: 800;
            color: #1e293b;
            font-size: 1.55rem;
            margin: 0;
        }

        .nav-tabs {
            border-bottom: none;
            gap: .3rem;
        }

        .nav-tabs .nav-link {
            border: 1px solid transparent;
            border-radius: 10px 10px 0 0;
            font-weight: 600;
            color: #64748b;
            padding: .55rem 1.1rem;
        }

        .nav-tabs .nav-link.active {
            background: #fff;
            border-color: #dee2e6 #dee2e6 #fff;
            color: #0d6efd;
        }

        .tab-content {
            background: #fff;
            border: 1px solid #dee2e6;
            border-top: none;
            border-radius: 0 14px 14px 14px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, .08);
            padding: 1.6rem;
        }

        .tbl th {
            background: #f8fafc;
            color: #475569;
            font-weight: 700;
            font-size: .72rem;
            text-transform: uppercase;
            letter-spacing: .4px;
            border-bottom: 2px solid #e2e8f0;
        }

        .tbl td {
            padding: .8rem 1rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .tbl tr:last-child td {
            border-bottom: none;
        }

        .tbl tr:hover td {
            background: #f8fafc;
        }

        .badge-plan {
            display: inline-block;
            padding: .3em .75em;
            border-radius: 20px;
            font-size: .72rem;
            font-weight: 700;
            color: #fff;
        }

        .badge-tam {
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
            padding: .28em .65em;
            border-radius: 8px;
            font-size: .75rem;
            font-weight: 600;
        }

        .chip {
            display: inline-block;
            background: #eff6ff;
            color: #1d4ed8;
            border-radius: 20px;
            padding: .18em .6em;
            font-size: .7rem;
            font-weight: 600;
            border: 1px solid #bfdbfe;
            margin: .1rem;
        }

        .total-num {
            font-weight: 800;
            font-size: .95rem;
            color: #0d6efd;
        }

        .total-det {
            font-size: .7rem;
            color: #94a3b8;
        }

        .btn-gest {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            color: #0d6efd;
            border-radius: 9px;
            padding: .3rem .65rem;
            font-size: .78rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
        }

        .btn-gest:hover {
            background: #0d6efd;
            color: #fff;
            border-color: #0d6efd;
        }

        .plan-card {
            border: none;
            border-radius: 14px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, .08);
            overflow: hidden;
        }

        .plan-hdr {
            padding: 1.2rem 1.4rem;
            color: #fff;
            text-align: center;
        }

        .plan-hdr h5 {
            font-weight: 800;
            font-size: 1.1rem;
            margin: 0;
        }

        .plan-hdr p {
            font-size: .78rem;
            opacity: .88;
            margin: .25rem 0 0 0;
        }

        .plan-body {
            padding: 1.2rem 1.4rem;
        }

        .feat-list {
            list-style: none;
            padding: 0;
            margin: 0 0 .9rem 0;
        }

        .feat-list li {
            font-size: .79rem;
            color: #475569;
            border-bottom: 1px solid #f1f5f9;
            padding: .38rem 0;
            display: flex;
            align-items: center;
            gap: .4rem;
        }

        .feat-list li:last-child {
            border-bottom: none;
        }

        .price-row {
            display: flex;
            align-items: center;
            gap: .55rem;
            margin-bottom: .5rem;
        }

        .price-row label {
            min-width: 68px;
            font-size: .76rem;
            font-weight: 700;
            color: #64748b;
            margin: 0;
        }

        .price-input {
            flex: 1;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: .32rem .65rem;
            font-size: .875rem;
            font-weight: 600;
        }

        .price-input:focus {
            border-color: #0d6efd;
            outline: none;
            box-shadow: 0 0 0 3px rgba(13, 110, 253, .1);
        }

        .btn-savep {
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            border: none;
            border-radius: 9px;
            color: #fff;
            font-weight: 700;
            padding: .45rem .9rem;
            font-size: .8rem;
            width: 100%;
            cursor: pointer;
        }

        .addon-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: .85rem 1rem;
            margin-bottom: .55rem;
            transition: border-color .15s;
        }

        .addon-row:hover {
            border-color: #93c5fd;
            background: #eff6ff;
        }

        .ap-input {
            width: 128px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: .32rem .65rem;
            font-size: .875rem;
            font-weight: 700;
            text-align: right;
        }

        .ap-input:focus {
            border-color: #0d6efd;
            outline: none;
            box-shadow: 0 0 0 3px rgba(13, 110, 253, .1);
        }

        .btn-savea {
            background: #f0fdf4;
            border: 1px solid #86efac;
            color: #15803d;
            border-radius: 8px;
            padding: .32rem .65rem;
            font-size: .78rem;
            font-weight: 700;
            transition: all .15s;
            cursor: pointer;
        }

        .btn-savea:hover {
            background: #15803d;
            color: #fff;
            border-color: #15803d;
        }

        .modal-content {
            border: none;
            border-radius: 18px;
            box-shadow: 0 24px 64px rgba(0, 0, 0, .18);
        }

        .addon-item {
            display: flex;
            align-items: center;
            padding: .7rem 1rem;
            border: 1.5px solid #e2e8f0;
            border-radius: 12px;
            margin-bottom: .45rem;
            cursor: pointer;
            transition: all .15s;
            user-select: none;
        }

        .addon-item:hover {
            border-color: #93c5fd;
            background: #f0f9ff;
        }

        .addon-item.sel {
            border-color: #3b82f6;
            background: #eff6ff;
        }

        .addon-chk {
            width: 20px;
            height: 20px;
            border: 2px solid #cbd5e1;
            border-radius: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all .15s;
            margin-right: .75rem;
        }

        .addon-item.sel .addon-chk {
            background: #0d6efd;
            border-color: #0d6efd;
            color: #fff;
        }

        .addon-name {
            font-weight: 700;
            font-size: .84rem;
            color: #1e293b;
        }

        .addon-desc {
            font-size: .73rem;
            color: #94a3b8;
        }

        .addon-price {
            font-weight: 800;
            color: #0d6efd;
            font-size: .88rem;
            white-space: nowrap;
            margin-left: auto;
            padding-left: .75rem;
        }

        .total-box {
            background: linear-gradient(135deg, #eff6ff, #dbeafe);
            border: 2px solid #93c5fd;
            border-radius: 13px;
            padding: .9rem 1.1rem;
            text-align: center;
            margin-top: .9rem;
        }

        .total-amount {
            font-size: 1.65rem;
            font-weight: 900;
            color: #0d6efd;
        }

        .section-lbl {
            font-size: .7rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: .5rem;
        }
    </style>
</head>

<body>
    <%- include('../partials/navbar', { user, tenant: null, currentAdminPage: 'planes' }) %>

        <div class="container-fluid py-4">
            <div class="page-header d-flex align-items-center gap-3">
                <div
                    style="width:42px;height:42px;background:linear-gradient(135deg,#6366f1,#4f46e5);border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-layers-fill text-white fs-5"></i>
                </div>
                <div>
                    <h1>Planes &amp; Add-ons</h1>
                    <p class="text-muted mb-0 small">Gestiona planes de suscripcion y modulos adicionales por
                        restaurante.</p>
                </div>
            </div>

            <ul class="nav nav-tabs" id="tabs">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabR">
                        <i class="bi bi-building me-1"></i>Restaurantes
                        <span class="badge bg-primary ms-1">
                            <%= tenants ? tenants.length : 0 %>
                        </span>
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabP">
                        <i class="bi bi-box me-1"></i>Planes
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabA">
                        <i class="bi bi-puzzle me-1"></i>Add-ons
                        <span class="badge bg-secondary ms-1">
                            <%= addons ? addons.length : 0 %>
                        </span>
                    </button>
                </li>
            </ul>

            <div class="tab-content">

                <div class="tab-pane fade show active" id="tabR">
                    <p class="text-muted small mb-3">Clic en <strong>Gestionar</strong> para agregar add-ons y cambiar
                        el tamano del negocio.</p>
                    <% if (!tenants || tenants.length===0) { %>
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-building" style="font-size:2.5rem;opacity:.3;"></i>
                            <p class="mt-2">No hay restaurantes registrados.</p>
                        </div>
                        <% } %>
                            <% if (tenants && tenants.length> 0) { %>
                                <div class="table-responsive">
                                    <table class="table tbl align-middle mb-0">
                                        <thead>
                                            <tr>
                                                <th>Restaurante</th>
                                                <th>Plan</th>
                                                <th>Tamano</th>
                                                <th>Add-ons</th>
                                                <th class="text-end">Total/mes</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% for (var ri=0; ri < tenants.length; ri++) { var t=tenants[ri]; %>
                                                <tr>
                                                    <td>
                                                        <div class="fw-bold">
                                                            <%= t.nombre %>
                                                        </div>
                                                        <small class="text-muted"><code><%= t.slug %></code></small>
                                                    </td>
                                                    <td>
                                                        <% if (t.plan_slug==='basico' ) { %>
                                                            <span class="badge-plan" style="background:#64748b">
                                                                <%= t.plan_nombre %>
                                                            </span>
                                                            <% } else if (t.plan_slug==='pro' ) { %>
                                                                <span class="badge-plan" style="background:#0d6efd">
                                                                    <%= t.plan_nombre %>
                                                                </span>
                                                                <% } else if (t.plan_slug==='premium' ) { %>
                                                                    <span class="badge-plan" style="background:#6366f1">
                                                                        <%= t.plan_nombre %>
                                                                    </span>
                                                                    <% } else { %>
                                                                        <span class="text-muted small">Sin plan</span>
                                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <span class="badge-tam" id="tb-tam-<%= t.id %>">
                                                            <% if (t.tamano==='grande' ) { %>Grande<% } else if
                                                                    (t.tamano==='mediano' ) { %>Mediano<% } else { %>
                                                                        Pequeno<% } %>
                                                        </span>
                                                    </td>
                                                    <td id="tb-chips-<%= t.id %>">
                                                        <% if (t.addons && t.addons.length> 0) { %>
                                                            <% for (var ai=0; ai < t.addons.length; ai++) { %>
                                                                <span class="chip">
                                                                    <%= t.addons[ai].nombre %>
                                                                </span>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <span class="text-muted"
                                                                            style="font-size:.75rem;">Ninguno</span>
                                                                        <% } %>
                                                    </td>
                                                    <td class="text-end">
                                                        <div class="total-num" id="tb-total-<%= t.id %>">$<%=
                                                                Number(t.precio_total||0).toLocaleString('es-CO') %>
                                                        </div>
                                                        <div class="total-det">Plan <span id="tb-pp-<%= t.id %>">$<%=
                                                                    Number(t.precio_plan||0).toLocaleString('es-CO') %>
                                                                    </span> + Addons <span id="tb-pa-<%= t.id %>">$<%=
                                                                    Number(t.precio_addons||0).toLocaleString('es-CO')
                                                                    %></span></div>
                                                    </td>
                                                    <td>
                                                        <button class="btn-gest" onclick="openModal(<%= t.id %>)">
                                                            <i class="bi bi-pencil"></i> Gestionar
                                                        </button>
                                                    </td>
                                                </tr>
                                                <% } %>
                                        </tbody>
                                    </table>
                                </div>
                                <% } %>
                </div>

                <div class="tab-pane fade" id="tabP">
                    <p class="text-muted small mb-3">Ajusta los precios de cada plan segun el tamano del negocio.</p>
                    <div class="row g-4">
                        <% for (var pi=0; pi < (plans ? plans.length : 0); pi++) { var p=plans[pi]; %>
                            <% var pGrad=p.slug==='pro' ? 'linear-gradient(135deg,#0d6efd,#0a58ca)' : p.slug==='premium'
                                ? 'linear-gradient(135deg,#6366f1,#4f46e5)' : 'linear-gradient(135deg,#64748b,#475569)'
                                ; %>
                                <div class="col-md-4">
                                    <div class="plan-card">
                                        <div class="plan-hdr" style="background:<%= pGrad %>">
                                            <h5>
                                                <%= p.nombre %>
                                            </h5>
                                            <p>
                                                <%= p.descripcion %>
                                            </p>
                                        </div>
                                        <div class="plan-body">
                                            <ul class="feat-list">
                                                <% for (var fi=0; fi < (p.caracteristicas ? p.caracteristicas.length :
                                                    0); fi++) { %>
                                                    <li><i class="bi bi-check-circle-fill text-success"
                                                            style="font-size:.68rem;"></i>
                                                        <%= p.caracteristicas[fi] %>
                                                    </li>
                                                    <% } %>
                                            </ul>
                                            <div class="section-lbl">Precio mensual por tamano</div>
                                            <div class="price-row"><label>Pequeno</label><input type="number"
                                                    class="price-input" id="pp-<%= p.id %>-pequeno"
                                                    value="<%= p.precio_pequeno %>" min="0" step="100"></div>
                                            <div class="price-row"><label>Mediano</label><input type="number"
                                                    class="price-input" id="pp-<%= p.id %>-mediano"
                                                    value="<%= p.precio_mediano %>" min="0" step="100"></div>
                                            <div class="price-row"><label>Grande</label> <input type="number"
                                                    class="price-input" id="pp-<%= p.id %>-grande"
                                                    value="<%= p.precio_grande  %>" min="0" step="100"></div>
                                            <button class="btn-savep mt-2" onclick="savePlanPrecios(<%= p.id %>)">
                                                <i class="bi bi-floppy me-1"></i>Guardar precios
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                    </div>
                </div>

                <div class="tab-pane fade" id="tabA">
                    <p class="text-muted small mb-3">Edita el precio de cada add-on.</p>
                    <% for (var xi=0; xi < (addons ? addons.length : 0); xi++) { var a=addons[xi]; %>
                        <div class="addon-row">
                            <div>
                                <strong style="font-size:.88rem;">
                                    <%= a.nombre %>
                                </strong>
                                <br><small class="text-muted">
                                    <%= a.descripcion %>
                                </small>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <input type="number" class="ap-input" id="ap-<%= a.id %>" value="<%= a.precio %>"
                                    min="0" step="100">
                                <button class="btn-savea" onclick="saveAddon(<%= a.id %>)"><i class="bi bi-floppy"></i>
                                    Guardar</button>
                            </div>
                        </div>
                        <% } %>
                </div>

            </div>
        </div>

        <div class="modal fade" id="modalAddons" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header border-bottom-0 pb-1">
                        <div>
                            <h5 class="modal-title fw-bold mb-0" id="mTitle">Gestionar</h5>
                            <small class="text-muted" id="mSlug"></small>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body pt-2">
                        <div class="d-flex align-items-center gap-2 p-2 rounded-3 mb-3"
                            style="background:#f8fafc;border:1px solid #e2e8f0;">
                            <span id="mPlanDot"
                                style="width:10px;height:10px;border-radius:50%;display:inline-block;background:#64748b;"></span>
                            <span class="fw-bold" id="mPlanNombre">-</span>
                            <span class="text-muted small ms-1">Plan activo</span>
                        </div>
                        <div class="mb-3">
                            <div class="section-lbl">Tamano del negocio</div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-secondary btn-sm flex-fill tamano-btn"
                                    data-tamano="pequeno" onclick="selTamano('pequeno')">Pequeno</button>
                                <button class="btn btn-outline-secondary btn-sm flex-fill tamano-btn"
                                    data-tamano="mediano" onclick="selTamano('mediano')">Mediano</button>
                                <button class="btn btn-outline-secondary btn-sm flex-fill tamano-btn"
                                    data-tamano="grande" onclick="selTamano('grande')">Grande</button>
                            </div>
                        </div>
                        <div class="section-lbl mt-3">Add-ons disponibles</div>
                        <div id="mList"></div>
                        <div class="total-box">
                            <div
                                style="font-size:.72rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.4px;">
                                Total mensual</div>
                            <div class="total-amount" id="mTotal">$0</div>
                            <div style="font-size:.73rem;color:#94a3b8;" id="mBreak"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-primary fw-bold px-4" id="btnGuardar">
                            <i class="bi bi-floppy me-1"></i>Guardar cambios
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script type="application/json" id="SD"><%- serverData %></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            var SD = JSON.parse(document.getElementById('SD').textContent);
            var ALL_ADDONS = SD.addons;
            var ALL_PLANS = SD.plans;
            var PC = { basico: '#64748b', pro: '#0d6efd', premium: '#6366f1' };

            var addonMap = {};
            var metaMap = {};
            SD.tenants.forEach(function (t) {
                addonMap[t.id] = new Set(t.addonIds || []);
                metaMap[t.id] = { planId: t.plan_id, tamano: t.tamano || 'pequeno', plan_slug: t.plan_slug, nombre: t.nombre, slug: t.slug };
            });

            var mTid = null, mTamano = 'pequeno';

            function openModal(tid) {
                mTid = tid;
                var meta = metaMap[tid];
                mTamano = meta.tamano || 'pequeno';
                document.getElementById('mTitle').textContent = meta.nombre;
                document.getElementById('mSlug').textContent = meta.slug;
                var plan = ALL_PLANS.find(function (p) { return p.id === meta.planId; });
                document.getElementById('mPlanDot').style.background = PC[meta.plan_slug] || '#64748b';
                document.getElementById('mPlanNombre').textContent = plan ? plan.nombre : 'Sin plan';
                selTamano(mTamano, true);
                renderList();
                recalc();
                new bootstrap.Modal(document.getElementById('modalAddons')).show();
            }

            function selTamano(t, silent) {
                mTamano = t;
                document.querySelectorAll('.tamano-btn').forEach(function (b) {
                    b.className = 'btn btn-sm flex-fill tamano-btn ' + (b.dataset.tamano === t ? 'btn-primary' : 'btn-outline-secondary');
                });
                if (!silent) recalc();
            }

            function renderList() {
                var c = document.getElementById('mList');
                c.innerHTML = '';
                var act = addonMap[mTid] || new Set();
                ALL_ADDONS.forEach(function (a) {
                    var sel = act.has(a.id);
                    var d = document.createElement('div');
                    d.className = 'addon-item' + (sel ? ' sel' : '');
                    d.id = 'ai-' + a.id;
                    d.onclick = function () { toggleAddon(a.id); };
                    var chkI = document.createElement('i');
                    chkI.className = 'bi bi-check2';
                    chkI.style.fontSize = '.8rem';
                    if (!sel) chkI.style.display = 'none';
                    var chkDiv = document.createElement('div');
                    chkDiv.className = 'addon-chk';
                    chkDiv.appendChild(chkI);
                    var infoDiv = document.createElement('div');
                    var nameD = document.createElement('div');
                    nameD.className = 'addon-name';
                    nameD.textContent = a.nombre;
                    var descD = document.createElement('div');
                    descD.className = 'addon-desc';
                    descD.textContent = a.descripcion;
                    infoDiv.appendChild(nameD);
                    infoDiv.appendChild(descD);
                    var priceDiv = document.createElement('div');
                    priceDiv.className = 'addon-price';
                    priceDiv.textContent = fmtCOP(a.precio);
                    d.appendChild(chkDiv);
                    d.appendChild(infoDiv);
                    d.appendChild(priceDiv);
                    c.appendChild(d);
                });
            }

            function toggleAddon(addonId) {
                var s = addonMap[mTid] || new Set();
                if (s.has(addonId)) s.delete(addonId); else s.add(addonId);
                addonMap[mTid] = s;
                var el = document.getElementById('ai-' + addonId);
                var chk = el && el.querySelector('.addon-chk i');
                var sel = s.has(addonId);
                if (el) el.className = 'addon-item' + (sel ? ' sel' : '');
                if (chk) chk.style.display = sel ? '' : 'none';
                recalc();
            }

            function recalc() {
                var meta = metaMap[mTid];
                var plan = ALL_PLANS.find(function (p) { return p.id === meta.planId; });
                var keyP = 'precio_' + mTamano;
                var pPlan = plan ? (plan[keyP] || 0) : 0;
                var act = ALL_ADDONS.filter(function (a) { return (addonMap[mTid] || new Set()).has(a.id); });
                var pAd = act.reduce(function (s, a) { return s + a.precio; }, 0);
                document.getElementById('mTotal').textContent = fmtCOP(pPlan + pAd);
                document.getElementById('mBreak').textContent = 'Plan: ' + fmtCOP(pPlan) + '  +  Add-ons: ' + fmtCOP(pAd);
            }

            document.getElementById('btnGuardar').addEventListener('click', async function () {
                var tid = mTid;
                var tamano = mTamano;
                var newSet = new Set(addonMap[tid]);
                try {
                    await apiFetch('/admin/planes/api/tenant/' + tid + '/tamano', 'PUT', { tamano: tamano });
                    var cur = await apiFetch('/admin/planes/api/tenant/' + tid + '/addons', 'GET');
                    var curIds = new Set(cur.map(function (a) { return a.id; }));
                    var toAdd = Array.from(newSet).filter(function (id) { return !curIds.has(id); });
                    var toDel = Array.from(curIds).filter(function (id) { return !newSet.has(id); });
                    for (var i = 0; i < toAdd.length; i++) {
                        await apiFetch('/admin/planes/api/tenant/' + tid + '/addons', 'POST', { addon_id: toAdd[i] });
                    }
                    for (var j = 0; j < toDel.length; j++) {
                        await apiFetch('/admin/planes/api/tenant/' + tid + '/addons/' + toDel[j], 'DELETE');
                    }
                    metaMap[tid].tamano = tamano;
                    updateRow(tid, tamano, newSet);
                    bootstrap.Modal.getInstance(document.getElementById('modalAddons')).hide();
                    Swal.fire({ icon: 'success', title: 'Guardado', timer: 1300, showConfirmButton: false });
                } catch (e) {
                    Swal.fire({ icon: 'error', title: 'Error al guardar', text: e.message });
                }
            });

            function updateRow(tid, tamano, set) {
                var meta = metaMap[tid];
                var plan = ALL_PLANS.find(function (p) { return p.id === meta.planId; });
                var keyP = 'precio_' + tamano;
                var pPlan = plan ? (plan[keyP] || 0) : 0;
                var act = ALL_ADDONS.filter(function (a) { return set.has(a.id); });
                var pAd = act.reduce(function (s, a) { return s + a.precio; }, 0);
                var chipsEl = document.getElementById('tb-chips-' + tid);
                if (chipsEl) {
                    if (act.length > 0) {
                        chipsEl.innerHTML = '';
                        act.forEach(function (a) {
                            var sp = document.createElement('span');
                            sp.className = 'chip';
                            sp.textContent = a.nombre;
                            chipsEl.appendChild(sp);
                        });
                    } else {
                        chipsEl.innerHTML = '<span class="text-muted" style="font-size:.75rem;">Ninguno</span>';
                    }
                }
                setText('tb-total-' + tid, fmtCOP(pPlan + pAd));
                setText('tb-pp-' + tid, fmtCOP(pPlan));
                setText('tb-pa-' + tid, fmtCOP(pAd));
                var labels = { pequeno: 'Pequeno', mediano: 'Mediano', grande: 'Grande' };
                setText('tb-tam-' + tid, labels[tamano] || tamano);
            }

            async function savePlanPrecios(planId) {
                var sq = function (s) { return parseFloat(document.getElementById('pp-' + planId + '-' + s).value || 0); };
                try {
                    await apiFetch('/admin/planes/api/planes/' + planId + '/precios', 'PUT', {
                        precio_pequeno: sq('pequeno'), precio_mediano: sq('mediano'), precio_grande: sq('grande')
                    });
                    var p = ALL_PLANS.find(function (pl) { return pl.id === planId; });
                    if (p) { p.precio_pequeno = sq('pequeno'); p.precio_mediano = sq('mediano'); p.precio_grande = sq('grande'); }
                    Swal.fire({ icon: 'success', title: 'Precios actualizados', timer: 1300, showConfirmButton: false });
                } catch (e) {
                    Swal.fire({ icon: 'error', title: 'Error', text: e.message });
                }
            }

            async function saveAddon(addonId) {
                var precio = parseFloat(document.getElementById('ap-' + addonId).value || 0);
                try {
                    await apiFetch('/admin/planes/api/addons/' + addonId, 'PUT', { precio: precio });
                    var a = ALL_ADDONS.find(function (x) { return x.id === addonId; });
                    if (a) a.precio = precio;
                    Swal.fire({ icon: 'success', title: 'Precio actualizado', timer: 1200, showConfirmButton: false });
                } catch (e) {
                    Swal.fire({ icon: 'error', title: 'Error', text: e.message });
                }
            }

            async function apiFetch(url, method, body) {
                var opts = { method: method, credentials: 'same-origin', headers: { 'Content-Type': 'application/json' } };
                if (body && method !== 'GET') opts.body = JSON.stringify(body);
                var resp = await fetch(url, opts);
                if (!resp.ok) {
                    var e = await resp.json().catch(function () { return {}; });
                    throw new Error(e.error || 'HTTP ' + resp.status);
                }
                if (method === 'DELETE') return null;
                return resp.json().catch(function () { return null; });
            }

            function fmtCOP(n) { return '$' + Number(n || 0).toLocaleString('es-CO'); }
            function setText(id, txt) { var el = document.getElementById(id); if (el) el.textContent = txt; }
        </script>
</body>

</html>
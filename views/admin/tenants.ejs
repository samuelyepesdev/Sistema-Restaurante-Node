<% const selectedTenant=tenants.find(t=> t.id === Number(activeTenantId)); %>
    <!DOCTYPE html>
    <html lang="es">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Gestión de Restaurantes | Panel de Control</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/css/admin-tenants-modern.css">
    </head>

    <body>
        <%- include('../partials/navbar', { user, tenant: selectedTenant || null, currentAdminPage: 'tenants' }) %>

            <div class="admin-layout">
                <!-- Sidebar: Lista de Restaurantes -->
                <aside class="tenants-sidebar">
                    <div class="sidebar-header">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h5 class="mb-0 fw-800">Locales</h5>
                            <span class="badge bg-primary rounded-pill">
                                <%= tenants.length %>
                            </span>
                        </div>
                        <div class="search-tenants">
                            <i class="bi bi-search"></i>
                            <input type="text" id="searchTenants" class="form-control" placeholder="Buscar sucursal...">
                        </div>
                    </div>

                    <div class="tenants-list" id="tenantsList">
                        <% tenants.forEach(t=> { %>
                            <a href="?tenantId=<%= t.id %>"
                                class="tenant-item <%= Number(activeTenantId) === t.id ? 'active' : '' %>"
                                data-name="<%= t.nombre.toLowerCase() %>">
                                <div class="tenant-avatar"
                                    style="background: <%= (t.config && t.config.colors && t.config.colors.primary) ? t.config.colors.primary : '#0f172a' %>">
                                    <%= t.nombre.charAt(0).toUpperCase() %>
                                </div>
                                <div class="tenant-info">
                                    <div class="tenant-name">
                                        <%= t.nombre %>
                                    </div>
                                    <div class="tenant-meta">
                                        <span
                                            class="status-indicator bg-<%= t.activo ? 'success' : 'secondary' %>"></span>
                                        <%= t.activo ? 'En línea' : 'Inactivo' %>
                                            <% if (t.plan_nombre) { %>
                                                <span class="ms-1 border-start ps-1">
                                                    <%= t.plan_nombre %>
                                                </span>
                                                <% } %>
                                    </div>
                                </div>
                            </a>
                            <% }) %>
                    </div>

                    <div class="p-3 border-top">
                        <button class="btn btn-primary w-100 py-2 fw-semibold" data-bs-toggle="modal"
                            data-bs-target="#modalCreateTenant">
                            <i class="bi bi-plus-lg me-2"></i>Nuevo Local
                        </button>
                    </div>
                </aside>

                <!-- Área de Detalle -->
                <main class="tenant-detail-container">
                    <% if (selectedTenant) { %>
                        <div class="detail-header">
                            <div class="detail-title">
                                <div class="d-flex align-items-center gap-3">
                                    <h2>
                                        <%= selectedTenant.nombre %>
                                    </h2>
                                    <span
                                        class="badge bg-<%= selectedTenant.activo ? 'success' : 'danger' %>-subtle text-<%= selectedTenant.activo ? 'success' : 'danger' %> border border-<%= selectedTenant.activo ? 'success' : 'danger' %>-subtle">
                                        <%= selectedTenant.activo ? 'Suscripción Activo' : 'Suscripción bloqueada' %>
                                    </span>
                                </div>
                            </div>
                            <div class="detail-actions">
                                <button class="btn btn-outline-danger btn-sm px-3"
                                    onclick="confirmToggleStatus('<%= selectedTenant.id %>', <%= selectedTenant.activo ? 'false' : 'true' %>)">
                                    <i
                                        class="bi bi-<%= selectedTenant.activo ? 'pause-circle' : 'play-circle' %> me-2"></i>
                                    <%= selectedTenant.activo ? 'Deshabilitar Tienda' : 'Habilitar Tienda' %>
                                </button>
                            </div>
                        </div>

                        <!-- Tabs de Navegación -->
                        <ul class="nav nav-tabs-premium" id="tenantTabs" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link active" id="general-tab" data-bs-toggle="tab"
                                    data-bs-target="#general" type="button">General</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" id="fiscal-tab" data-bs-toggle="tab" data-bs-target="#fiscal"
                                    type="button">Datos Fiscales</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" id="appearance-tab" data-bs-toggle="tab"
                                    data-bs-target="#appearance" type="button">Personalización</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" id="users-tab" data-bs-toggle="tab" data-bs-target="#users"
                                    type="button">Usuarios</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <!-- Tab General -->
                            <div class="tab-pane fade show active" id="general">
                                <div class="glass-card">
                                    <form id="form-edit-general"
                                        onsubmit="return handleFormSubmit(event, <%= selectedTenant.id %>, 'general')">
                                        <div class="row g-4">
                                            <div class="col-md-6">
                                                <label class="form-label">Nombre Comercial</label>
                                                <input type="text" name="nombre" class="form-control"
                                                    value="<%= selectedTenant.nombre %>" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Identificador (Slug)</label>
                                                <div class="input-group">
                                                    <span class="input-group-text bg-light text-muted">/tienda/</span>
                                                    <input type="text" class="form-control bg-light"
                                                        value="<%= selectedTenant.slug %>" disabled>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Tipo de Negocio</label>
                                                <select name="tipo_negocio" id="editTipoNegocio" class="form-select">
                                                    <option value="restaurante" <%=selectedTenant.config &&
                                                        selectedTenant.config.tipo_negocio==='restaurante' ? 'selected'
                                                        : '' %>>🍴 Restaurante Estándar</option>
                                                    <option value="comidas_rapidas" <%=selectedTenant.config &&
                                                        selectedTenant.config.tipo_negocio==='comidas_rapidas'
                                                        ? 'selected' : '' %>>🍔 Comidas Rápidas</option>
                                                    <option value="panaderia" <%=selectedTenant.config &&
                                                        selectedTenant.config.tipo_negocio==='panaderia' ? 'selected'
                                                        : '' %>>🥯 Panadería</option>
                                                    <option value="pasteleria" <%=selectedTenant.config &&
                                                        selectedTenant.config.tipo_negocio==='pasteleria' ? 'selected'
                                                        : '' %>>🍰 Pastelería Profesional</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Plan de Servicio</label>
                                                <select name="plan_id" class="form-select">
                                                    <% plans.forEach(p=> { %>
                                                        <option value="<%= p.id %>" <%=selectedTenant.plan_id==p.id
                                                            ? 'selected' : '' %>><%= p.nombre %> - <%= p.descripcion %>
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                            <div class="col-12 text-end">
                                                <button type="submit" class="btn btn-primary px-4 shadow-sm">Guardar
                                                    Cambios</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>

                                <div class="glass-card bg-light border-dashed">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div>
                                            <h6 class="mb-1 fw-bold">Configuración Inicial</h6>
                                            <p class="text-muted small mb-0">Carga las categorías y productos sugeridos
                                                según el tipo de negocio.</p>
                                        </div>
                                        <button class="btn btn-outline-dark btn-sm" id="btnSeedCategorias"
                                            data-tenant-id="<%= selectedTenant.id %>">
                                            <i class="bi bi-magic me-2"></i>Auto-configurar
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Tab Fiscal -->
                            <div class="tab-pane fade" id="fiscal">
                                <div class="glass-card">
                                    <form id="form-edit-fiscal"
                                        onsubmit="return handleFormSubmit(event, <%= selectedTenant.id %>, 'fiscal')">
                                        <div class="row g-4">
                                            <div class="col-md-4">
                                                <label class="form-label">NIT / RUT</label>
                                                <input type="text" name="nit" class="form-control"
                                                    value="<%= selectedTenant.nit || '' %>" placeholder="000.000.000-0">
                                            </div>
                                            <div class="col-md-8">
                                                <label class="form-label">Dirección Fiscal</label>
                                                <input type="text" name="direccion" class="form-control"
                                                    value="<%= selectedTenant.direccion || '' %>"
                                                    placeholder="Calle ...">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Ciudad</label>
                                                <input type="text" name="ciudad" class="form-control"
                                                    value="<%= selectedTenant.ciudad || '' %>">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Teléfono de Contacto</label>
                                                <input type="text" name="telefono" class="form-control"
                                                    value="<%= selectedTenant.telefono || '' %>">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Régimen Fiscal</label>
                                                <select name="regimen_fiscal" class="form-select">
                                                    <option value="No responsable de IVA"
                                                        <%=selectedTenant.regimen_fiscal==='No responsable de IVA'
                                                        ? 'selected' : '' %>>No responsable de IVA</option>
                                                    <option value="Responsable de IVA"
                                                        <%=selectedTenant.regimen_fiscal==='Responsable de IVA'
                                                        ? 'selected' : '' %>>Responsable de IVA</option>
                                                    <option value="Régimen Simple"
                                                        <%=selectedTenant.regimen_fiscal==='Régimen Simple' ? 'selected'
                                                        : '' %>>Régimen Simple (RST)</option>
                                                </select>
                                            </div>
                                            <div class="col-12 text-end">
                                                <button type="submit" class="btn btn-primary px-4">Actualizar Datos
                                                    Fiscales</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <!-- Tab Apariencia -->
                            <div class="tab-pane fade" id="appearance">
                                <div class="glass-card">
                                    <div class="row">
                                        <div class="col-lg-4">
                                            <div class="color-preview-box" id="colorPreview"
                                                style="background: <%= (selectedTenant.config && selectedTenant.config.colors && selectedTenant.config.colors.primary) ? selectedTenant.config.colors.primary : '#6366f1' %>">
                                                Vista Previa
                                            </div>
                                        </div>
                                        <div class="col-lg-8">
                                            <label class="form-label">Color de Marca (Botones y Menú)</label>
                                            <p class="text-muted small">Este color definirá la identidad visual dentro
                                                del panel del restaurante.</p>
                                            <div class="d-flex align-items-center gap-3 mb-4">
                                                <input type="color" id="editConfigColor"
                                                    class="form-control form-control-color"
                                                    style="width: 50px; height: 50px;"
                                                    value="<%= (selectedTenant.config && selectedTenant.config.colors && selectedTenant.config.colors.primary) ? selectedTenant.config.colors.primary : '#6366f1' %>">
                                                <div class="d-flex flex-wrap gap-2">
                                                    <% ['#0f172a', '#3b82f6' , '#10b981' , '#f59e0b' , '#ef4444'
                                                        , '#8b5cf6' , '#f43f5e' ].forEach(c=> { %>
                                                        <div class="rounded-circle cursor-pointer border preset-color-dot"
                                                            data-color="<%= c %>"
                                                            style="width:30px; height:30px; background:<%= c %>; cursor:pointer;">
                                                        </div>
                                                        <% }) %>
                                                </div>
                                            </div>
                                            <button onclick="saveAppearance(<%= selectedTenant.id %>)"
                                                class="btn btn-primary px-4">Guardar Apariencia</button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Tab Usuarios -->
                            <div class="tab-pane fade" id="users">
                                <div class="glass-card p-0 overflow-hidden">
                                    <div class="p-4 d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0 fw-bold">Personal Administrativo</h6>
                                        <button class="btn btn-dark btn-sm rounded-pill px-3" data-bs-toggle="modal"
                                            data-bs-target="#modalCreateUser">
                                            <i class="bi bi-person-plus me-2"></i>Añadir Usuario
                                        </button>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table modern-table mb-0 align-middle">
                                            <thead>
                                                <tr>
                                                    <th class="ps-4">Usuario / Email</th>
                                                    <th>Rol del Sistema</th>
                                                    <th>Estado</th>
                                                    <th class="text-end pe-4">Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% tenantUsers.forEach(u=> { %>
                                                    <tr class="user-row">
                                                        <td class="ps-4">
                                                            <div class="fw-semibold">
                                                                <%= u.username %>
                                                            </div>
                                                            <div class="text-muted small">
                                                                <%= u.email || 'Sin correo registrado' %>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <form
                                                                onsubmit="return handleRoleChange(event, <%= u.id %>, <%= selectedTenant.id %>)"
                                                                class="d-flex gap-2">
                                                                <select name="rol_nombre"
                                                                    class="form-select form-select-sm"
                                                                    style="width: 140px;">
                                                                    <option value="admin" <%=u.rol==='admin'
                                                                        ? 'selected' : '' %>>Administrador</option>
                                                                    <option value="mesero" <%=u.rol==='mesero'
                                                                        ? 'selected' : '' %>>Mesero</option>
                                                                    <option value="cajero" <%=u.rol==='cajero'
                                                                        ? 'selected' : '' %>>Cajero</option>
                                                                    <option value="cocinero" <%=u.rol==='cocinero'
                                                                        ? 'selected' : '' %>>Cocinero</option>
                                                                </select>
                                                                <button type="submit" class="btn btn-icon btn-light"><i
                                                                        class="bi bi-check2"></i></button>
                                                            </form>
                                                        </td>
                                                        <td>
                                                            <span
                                                                class="badge rounded-pill bg-<%= u.activo ? 'success' : 'danger' %>-subtle text-<%= u.activo ? 'success' : 'danger' %>">
                                                                <%= u.activo ? 'Activo' : 'Bloqueado' %>
                                                            </span>
                                                        </td>
                                                        <td class="text-end pe-4">
                                                            <div class="dropdown">
                                                                <button class="btn btn-icon btn-light"
                                                                    data-bs-toggle="dropdown"><i
                                                                        class="bi bi-three-dots-vertical"></i></button>
                                                                <ul
                                                                    class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                                                                    <li><a class="dropdown-item"
                                                                            href="javascript:void(0)"
                                                                            onclick="openModalPassword(<%= u.id %>, '<%= u.username %>', <%= selectedTenant.id %>)"><i
                                                                                class="bi bi-key me-2"></i>Resetear
                                                                            Clave</a></li>
                                                                    <li><a class="dropdown-item text-<%= u.activo ? 'danger' : 'success' %>"
                                                                            href="javascript:void(0)"
                                                                            onclick="toggleUserStatus(<%= u.id %>, <%= selectedTenant.id %>, <%= u.activo ? 'false' : 'true' %>)">
                                                                            <i
                                                                                class="bi bi-<%= u.activo ? 'shield-lock' : 'shield-check' %> me-2"></i>
                                                                            <%= u.activo ? 'Bloquear Acceso'
                                                                                : 'Desbloquear Acceso' %>
                                                                        </a></li>
                                                                </ul>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="bi bi-shop"></i>
                                <h3>No hay restaurante seleccionado</h3>
                                <p class="text-muted">Elige una sucursal de la lista de la izquierda para comenzar la
                                    gestión profesional.</p>
                                <div class="mt-4">
                                    <img src="https://illustrations.popsy.co/slate/waiting-for-data.svg" alt="Empty"
                                        style="max-width: 300px; opacity: 0.6;">
                                </div>
                            </div>
                            <% } %>
                </main>
            </div>

            <!-- Modal Crear Restaurante (Diseño Limpio) -->
            <div class="modal fade" id="modalCreateTenant" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <form action="/admin/tenants" method="POST">
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title fw-bold">Nuevo Establacimiento</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Nombre del Restaurante</label>
                                        <input name="nombre" class="form-control" placeholder="Ej: Pizzería Roma"
                                            required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Slug de acceso</label>
                                        <input name="slug" class="form-control" placeholder="pizzeria-roma" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">NIT / Documento</label>
                                        <input name="nit" class="form-control" placeholder="NIT o Cédula">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Ciudad</label>
                                        <input name="ciudad" class="form-control">
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Tipo de Negocio</label>
                                        <select name="config[tipo_negocio]" class="form-select">
                                            <option value="restaurante">🍴 Restaurante</option>
                                            <option value="comidas_rapidas">🍔 Comidas Rápidas</option>
                                            <option value="panaderia">🥯 Panadería / Repostería</option>
                                        </select>
                                    </div>
                                    <input type="hidden" name="plan_id" value="1">
                                    <hr>
                                    <h6 class="fw-bold mt-2">Usuario Administrador</h6>
                                    <div class="col-md-6">
                                        <label class="form-label">Nombre de Usuario</label>
                                        <input name="admin_username" class="form-control" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Contraseña inicial</label>
                                        <input name="admin_password" type="password" class="form-control" required
                                            minlength="6">
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer border-0 pt-0">
                                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
                                <button type="submit" class="btn btn-primary px-4">Crear Restaurante</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Modal Añadir Usuario -->
            <div class="modal fade" id="modalCreateUser" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <form action="/admin/tenants/<%= selectedTenant ? selectedTenant.id : '' %>/users"
                            method="POST">
                            <div class="modal-header">
                                <h5 class="modal-title">Añadir Colaborador</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Username</label>
                                    <input name="username" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Contraseña</label>
                                    <input name="password" type="password" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Rol</label>
                                    <select name="rol_nombre" class="form-select">
                                        <option value="mesero">Mesero</option>
                                        <option value="cajero">Cajero</option>
                                        <option value="cocinero">Cocinero</option>
                                        <option value="admin">Administrador</option>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary">Crear Acceso</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Modal Password Reset -->
            <div class="modal fade" id="modalCambiarPassword" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title fw-bold">Resetear Contraseña</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" id="modalPasswordUserId">
                            <input type="hidden" id="modalPasswordTenantId">
                            <div class="mb-3">
                                <label class="form-label">Nueva Clave para <strong
                                        id="modalPasswordUsername"></strong></label>
                                <input type="password" id="modalPasswordNew" class="form-control"
                                    placeholder="Nueva contraseña">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Confirmar Clave</label>
                                <input type="password" id="modalPasswordConfirm" class="form-control">
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-primary w-100" id="btnGuardarPassword">Aplicar
                                Cambio</button>
                        </div>
                    </div>
                </div>
            </div>

            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

            <script>
                // Búsqueda en sidebar
                const searchInput = document.getElementById('searchTenants');
                const tenantItems = document.querySelectorAll('.tenant-item');
                if (searchInput) {
                    searchInput.addEventListener('input', (e) => {
                        const term = e.target.value.toLowerCase();
                        tenantItems.forEach(item => {
                            const name = item.getAttribute('data-name');
                            item.style.display = name.includes(term) ? 'flex' : 'none';
                        });
                    });
                }

                // Manejo de Colores
                const colorInput = document.getElementById('editConfigColor');
                const colorPreview = document.getElementById('colorPreview');
                const presetDots = document.querySelectorAll('.preset-color-dot');

                if (colorInput) {
                    colorInput.addEventListener('input', (e) => {
                        colorPreview.style.background = e.target.value;
                    });
                }

                presetDots.forEach(dot => {
                    dot.addEventListener('click', () => {
                        const color = dot.getAttribute('data-color');
                        colorInput.value = color;
                        colorPreview.style.background = color;
                    });
                });

                async function saveAppearance(tenantId) {
                    const color = colorInput.value;
                    const tipoNegocioElement = document.getElementById('editTipoNegocio');
                    const config = {
                        colors: { primary: color },
                        tipo_negocio: tipoNegocioElement ? tipoNegocioElement.value : 'restaurante'
                    };

                    try {
                        const resp = await fetch(`/admin/tenants/${tenantId}`, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ config: JSON.stringify(config) })
                        });
                        if (resp.ok) {
                            Swal.fire({ icon: 'success', title: 'Diseño Actualizado', timer: 1500, showConfirmButton: false })
                                .then(() => window.location.reload());
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error al servidor' });
                        }
                    } catch (e) {
                        Swal.fire({ icon: 'error', title: 'Error de red' });
                    }
                }

                async function handleFormSubmit(event, tenantId, type) {
                    event.preventDefault();
                    const formData = new FormData(event.target);
                    const data = Object.fromEntries(formData.entries());

                    // Si es general, incluir config actualizada
                    if (type === 'general') {
                        const color = colorInput ? colorInput.value : '#6366f1';
                        data.config = JSON.stringify({
                            colors: { primary: color },
                            tipo_negocio: data.tipo_negocio
                        });
                    }

                    try {
                        const resp = await fetch(`/admin/tenants/${tenantId}`, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });
                        if (resp.ok) {
                            Swal.fire({ icon: 'success', title: 'Datos Guardados', timer: 1500, showConfirmButton: false })
                                .then(() => { if (type === 'general') window.location.reload(); });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error al actualizar datos' });
                        }
                    } catch (e) {
                        Swal.fire({ icon: 'error', title: 'Error de conexión' });
                    }
                }

                async function confirmToggleStatus(id, activo) {
                    const result = await Swal.fire({
                        title: activo ? '¿Reactivar suscripción?' : '¿Deshabilitar acceso?',
                        text: activo ? 'El restaurante podrá operar de nuevo.' : 'El personal no podrá iniciar sesión y las funciones se bloquearán.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Sí, confirmar',
                        cancelButtonText: 'Cancelar'
                    });

                    if (result.isConfirmed) {
                        toggleTenantStatus(id, activo);
                    }
                }

                async function toggleTenantStatus(id, activo) {
                    const resp = await fetch(`/admin/tenants/${id}/status`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ activo })
                    });
                    if (resp.ok) window.location.reload();
                }

                // Usuarios y Roles
                async function handleRoleChange(event, userId, tenantId) {
                    event.preventDefault();
                    const rol = event.target.rol_nombre.value;
                    const resp = await fetch(`/admin/tenants/${tenantId}/users/${userId}/roles`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ rol_nombre: rol })
                    });
                    if (resp.ok) Swal.fire({ icon: 'success', title: 'Rol Actualizado', timer: 1000, showConfirmButton: false });
                    return false;
                }

                async function toggleUserStatus(userId, tenantId, activo) {
                    const resp = await fetch(`/admin/tenants/${tenantId}/users/${userId}/status`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ activo: activo === 'true' })
                    });
                    if (resp.ok) window.location.reload();
                }

                function openModalPassword(userId, username, tenantId) {
                    document.getElementById('modalPasswordUserId').value = userId;
                    document.getElementById('modalPasswordTenantId').value = tenantId;
                    document.getElementById('modalPasswordUsername').textContent = username;
                    new bootstrap.Modal('#modalCambiarPassword').show();
                }

                document.getElementById('btnGuardarPassword').addEventListener('click', async () => {
                    const userId = document.getElementById('modalPasswordUserId').value;
                    const tenantId = document.getElementById('modalPasswordTenantId').value;
                    const newP = document.getElementById('modalPasswordNew').value;
                    const confirmP = document.getElementById('modalPasswordConfirm').value;

                    if (newP !== confirmP) return Swal.fire({ icon: 'error', title: 'No coinciden' });

                    const resp = await fetch(`/admin/tenants/${tenantId}/users/${userId}/password`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ newPassword: newP, newPasswordConfirm: confirmP })
                    });
                    if (resp.ok) {
                        Swal.fire({ icon: 'success', title: 'Clave reseteada' });
                        bootstrap.Modal.getInstance('#modalCambiarPassword').hide();
                    }
                });

                // Seeding
                document.getElementById('btnSeedCategorias')?.addEventListener('click', async function () {
                    const tenantId = this.getAttribute('data-tenant-id');
                    const resp = await fetch(`/admin/tenants/${tenantId}/seed-categorias`, { method: 'POST' });
                    if (resp.ok) Swal.fire({ icon: 'success', title: 'Categorías Iniciales creadas' }).then(() => window.location.reload());
                });
            </script>
    </body>

    </html>
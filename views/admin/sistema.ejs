<% const selectedTenant=activeTenant || (tenants && tenants.find(t=> t.id === Number(activeTenantId))); %>
    <!DOCTYPE html>
    <html lang="es">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Sistema - Temas y parámetros</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/admin/sistema.css">
    </head>

    <body>
        <%- include('../partials/navbar', { user, tenant: selectedTenant || null, currentAdminPage: 'sistema' }) %>

            <div class="container-fluid py-4">
                <div class="admin-page-header d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div>
                        <h1><i class="bi bi-gear-wide-connected me-2"></i>Sistema</h1>
                        <p class="text-muted mb-0">Gestioná temas y parámetros por restaurante (tenant).</p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label mb-0 text-nowrap">Restaurante:</label>
                        <select class="form-select form-select-lg" id="selectorTenant" style="min-width: 220px;">
                            <option value="">Seleccionar restaurante</option>
                            <% (tenants || []).forEach(t=> { %>
                                <option value="<%= t.id %>" <%=Number(activeTenantId)===t.id ? 'selected' : '' %>><%=
                                        t.nombre %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                </div>

                <% if (activeTenantId && selectedTenant) { %>
                    <input type="hidden" id="tenantId" value="<%= activeTenantId %>">
                    <div class="card">
                        <div class="card-header">
                            <ul class="nav nav-tabs card-header-tabs" id="sistemaTab" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="temas-tab" data-bs-toggle="tab"
                                        data-bs-target="#temas-pane" type="button">Temas</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="parametros-tab" data-bs-toggle="tab"
                                        data-bs-target="#parametros-pane" type="button">Parámetros</button>
                                </li>
                            </ul>
                        </div>
                        <div class="card-body">
                            <div class="tab-content" id="sistemaTabContent">
                                <!-- Tab Temas -->
                                <%- include('sistema/_tab_temas', { ...locals, selectedTenant }) %>

                                    <!-- Tab Parámetros -->
                                    <%- include('sistema/_tab_parametros', { ...locals, selectedTenant }) %>
                            </div>
                        </div>
                    </div>
                    <% } else { %>
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>Seleccioná un restaurante arriba para gestionar sus
                            temas y parámetros.
                        </div>
                        <% } %>
            </div>

            <!-- Modales -->
            <%- include('sistema/_modales') %>

                <!-- Scripts -->
                <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
                <script src="/js/admin/sistema.js"></script>
    </body>

    </html>
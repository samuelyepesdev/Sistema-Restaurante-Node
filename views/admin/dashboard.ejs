<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Superadministrador</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin/dashboard.css">
</head>

<body>
    <%- include('../partials/navbar', { user, tenant: null, currentAdminPage: 'dashboard' }) %>

        <div class="dashboard-container">
            <div class="dashboard-header d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="header-icon-box">
                        <i class="bi bi-speedometer2"></i>
                    </div>
                    <div>
                        <h1>Dashboard</h1>
                        <p class="mb-0">Resumen general del sistema y los restaurantes · <%= new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                    </div>
                </div>
            </div>

            <!-- Tarjetas de Estadísticas Principales -->
            <%- include('dashboard/_stats_cards', { ...locals, stats }) %>

            <!-- Estadísticas de Uso -->
            <%- include('dashboard/_usage_stats', { ...locals, stats }) %>

            <!-- Gráficos de Ventas -->
            <%- include('dashboard/_charts', { ...locals, stats }) %>

            <!-- Detalles por Plan y Accesos Rápidos -->
            <%- include('dashboard/_footer_details', { ...locals, stats }) %>
        </div>

        <!-- Datos para los gráficos (Safe inject) -->
        <script type="application/json" id="chartData"><%- JSON.stringify({ ventasDiarias: (stats && stats.ventasDiariasMes) || [], ventasDiariasAnt: (stats && stats.ventasDiariasMesAnterior) || [], ventasPorTenant: (stats && stats.ventasDiariasPorTenant) || [], ventasEventos: (stats && stats.ventasEventosDiariasMes) || [] }) %></script>

        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="/js/admin/dashboard.js?v=5"></script>
</body>

</html>
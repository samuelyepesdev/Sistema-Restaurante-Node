<div class="tab-pane fade" id="tabP">
    <p class="text-muted small mb-3">Ajusta los precios de cada plan segun el tamano del negocio.</p>
    <div class="row g-4">
        <% for (var pi=0; pi < (plans ? plans.length : 0); pi++) { var p=plans[pi]; %>
            <% var pGrad=p.slug==='pro' ? 'linear-gradient(135deg,#0d6efd,#0a58ca)' : p.slug==='premium'
                ? 'linear-gradient(135deg,#6366f1,#4f46e5)' : 'linear-gradient(135deg,#64748b,#475569)' ; %>
                <div class="col-md-4">
                    <div class="plan-card">
                        <div class="plan-hdr" style="background:<%= pGrad %>">
                            <input type="text" class="plan-title-input mb-1" id="pn-<%= p.id %>" value="<%= p.nombre %>"
                                style="background:transparent; border:none; color:white; font-weight:bold; font-size:1.25rem; width:100%; border-bottom: 1px dashed rgba(255,255,255,0.3);">
                            <textarea class="plan-desc-input" id="pd-<%= p.id %>" rows="2"
                                style="background:transparent; border:none; color:rgba(255,255,255,0.9); font-size:0.85rem; width:100%; resize:none;"><%= p.descripcion %></textarea>
                        </div>
                        <div class="plan-body">
                            <div class="mb-3">
                                <label class="small text-muted fw-bold">Descripción Detallada (PDF)</label>
                                <textarea class="form-control form-control-sm" id="pdd-<%= p.id %>" rows="3"
                                    style="font-size: 0.75rem;"><%= p.descripcion_detallada %></textarea>
                            </div>
                            <ul class="feat-list">
                                <% for (var fi=0; fi < (p.caracteristicas ? p.caracteristicas.length : 0); fi++) { %>
                                    <li><i class="bi bi-check-circle-fill text-success" style="font-size:.68rem;"></i>
                                        <%= p.caracteristicas[fi] %>
                                    </li>
                                    <% } %>
                            </ul>
                            <div class="section-lbl">Precio mensual por tamaño</div>
                            <div class="price-row"><label>Pequeño</label><input type="number" class="price-input"
                                    id="pp-<%= p.id %>-pequeno" value="<%= p.precio_pequeno %>" min="0" step="100">
                            </div>
                            <div class="price-row"><label>Mediano</label><input type="number" class="price-input"
                                    id="pp-<%= p.id %>-mediano" value="<%= p.precio_mediano %>" min="0" step="100">
                            </div>
                            <div class="price-row"><label>Grande</label> <input type="number" class="price-input"
                                    id="pp-<%= p.id %>-grande" value="<%= p.precio_grande  %>" min="0" step="100"></div>
                            <button class="btn-savep mt-2" onclick="savePlanCompleto(<%= p.id %>)">
                                <i class="bi bi-floppy me-1"></i>Guardar Cambios
                            </button>
                        </div>
                    </div>
                </div>
                <% } %>
    </div>
</div>
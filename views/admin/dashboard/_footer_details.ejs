<div class="row g-4">
    <!-- Planes list -->
    <div class="col-lg-6">
        <div class="premium-card d-flex flex-column">
            <div class="d-flex align-items-center gap-2 mb-3 border-bottom pb-3">
                <i class="bi bi-layers text-success"></i>
                <h5 class="m-0 fw-bold" style="font-size: 15px; color: var(--text-secondary);">DETALLE DE RESTAURANTES POR PLAN</h5>
            </div>
            <div class="flex-grow-1">
                <% if (stats.porPlan && stats.porPlan.length) { %>
                    <% stats.porPlan.forEach(function(item) { %>
                        <div class="list-plan-item">
                            <span>
                                <%= item.plan_nombre %>
                            </span>
                            <span class="badge rounded-pill px-3 py-1.5 fw-bold">
                                <%= item.cantidad %>
                            </span>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="py-4 text-center text-muted small">
                        <i class="bi bi-info-circle me-1"></i> No hay datos de planes.
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="col-lg-6">
        <div class="premium-card">
            <div class="d-flex align-items-center gap-2 mb-3 border-bottom pb-3">
                <i class="bi bi-link-45deg text-success"></i>
                <h5 class="m-0 fw-bold" style="font-size: 15px; color: var(--text-secondary);">ACCESOS RÁPIDOS</h5>
            </div>
            <div class="d-flex flex-column gap-2">
                <a href="/admin/tenants" class="quick-link">
                    <i class="bi bi-building"></i>
                    <span>Gestionar restaurantes</span>
                </a>
                <a href="/admin/planes" class="quick-link">
                    <i class="bi bi-layers"></i>
                    <span>Planes de suscripción</span>
                </a>
                <a href="/admin/permisos" class="quick-link">
                    <i class="bi bi-shield-lock"></i>
                    <span>Permisos por usuario</span>
                </a>
                <a href="/admin/sistema" class="quick-link">
                    <i class="bi bi-gear-wide-connected"></i>
                    <span>Sistema (temas y parámetros)</span>
                </a>
                <a href="/admin/ventas" class="quick-link">
                    <i class="bi bi-trash"></i>
                    <span>Eliminar ventas</span>
                </a>
            </div>
        </div>
    </div>
</div>
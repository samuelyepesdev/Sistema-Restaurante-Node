<%
    const colorsMap = {
        'Principal': '#2e7d46',
        'Restaurante Principal': '#2e7d46',
        'Ichiban': '#10b981',
        'Rollito Cinnamon': '#f59e0b',
        'Carreteritos': '#0ea5e9',
        'Callejero': '#f43f5e',
        'Gelatto & Arte': '#8b5cf6'
    };
    const getTenantColor = name => colorsMap[name] || '#94a3b8';

    function hexToRgb(hex) {
        const r = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
        return r ? `${parseInt(r[1], 16)}, ${parseInt(r[2], 16)}, ${parseInt(r[3], 16)}` : '148, 163, 184';
    }
%>

<!-- Ventas de Hoy por Restaurante (Leaderboard) -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
            <div class="section-header my-0">
                <i class="bi bi-clock-history"></i>
                <h2>Ventas de hoy por restaurante</h2>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-white text-dark border px-3 py-2 rounded-pill fw-bold" id="totalHoyBadge">
                    Total Hoy: $<span id="ventasHoyTotalGlobal">
                        <%= Number(stats.ventasHoyTotalGlobal || 0).toLocaleString('es-CO', { maximumFractionDigits: 0 }) %>
                    </span>
                </span>
                <span class="small text-muted" id="lastUpdatedLabel" title="Actualización automática cada 60 segundos">
                    <i class="bi bi-arrow-clockwise me-1"></i><span id="lastUpdatedTime">Actualizado al cargar</span>
                </span>
            </div>
        </div>

        <div class="leaderboard-container" id="ventasHoyContainer">
            <% if (stats.ventasHoyPorTenant && stats.ventasHoyPorTenant.length > 0) { %>
                <% 
                    const maxSales = Math.max(...stats.ventasHoyPorTenant.map(t => t.total)) || 1;
                    stats.ventasHoyPorTenant.forEach((v, idx) => { 
                        const color = getTenantColor(v.nombre);
                        const pct = (v.total / maxSales) * 100;
                %>
                    <div class="leaderboard-row" data-tenant-row="<%= v.nombre %>">
                        <span class="leaderboard-rank <%= idx === 0 ? 'top-rank' : '' %>"><%= idx + 1 %></span>
                        <span class="leaderboard-dot" style="background: <%= color %>"></span>
                        <div class="flex-grow-1 min-width-0" style="width: 180px; flex: 0 0 180px;">
                            <div class="leaderboard-tenant-name text-truncate" title="<%= v.nombre %>"><%= v.nombre %></div>
                            <div class="leaderboard-tenant-subtext"><%= v.facturas %> factura<%= v.facturas !== 1 ? 's' : '' %></div>
                        </div>
                        <div class="flex-grow-1 d-none d-md-block">
                            <div class="leaderboard-progress-bg">
                                <div class="leaderboard-progress-fill" style="width: <%= Math.max(pct, 1.5) %>%; background: linear-gradient(90deg, rgba(<%= hexToRgb(color) %>, 0.25), <%= color %>);"></div>
                            </div>
                        </div>
                        <span class="leaderboard-sales-val">$<%= Number(v.total || 0).toLocaleString('es-CO', { maximumFractionDigits: 0 }) %></span>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="py-4 text-center text-muted small" id="noVentasHoy">
                    <i class="bi bi-info-circle me-2 fs-4 d-block mb-1 text-secondary"></i>
                    No se encontraron datos de ventas para hoy.
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Ventas Diarias por Restaurante (Multi-Serie) -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="premium-card">
            <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-graph-up-arrow text-success"></i>
                    <h5 class="m-0 fw-bold" style="font-size: 15px; color: var(--text-secondary);">VENTAS DIARIAS POR RESTAURANTE (MES ACTUAL)</h5>
                </div>
                <span class="badge bg-light text-dark fw-bold border px-3 py-1.5 rounded-pill">Vista Multi-Serie</span>
            </div>
            <div style="height: 380px;">
                <canvas id="chartVentasTenants"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Comparativa Mensual & Ganancias por Eventos -->
<div class="row g-4 mb-4">
    <!-- Column 1: Comparativa Mensual Global -->
    <div class="col-lg-8">
        <div class="premium-card">
            <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-graph-up text-success"></i>
                    <h5 class="m-0 fw-bold" style="font-size: 15px; color: var(--text-secondary);">COMPARATIVA MENSUAL · GLOBAL</h5>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="d-flex align-items-center gap-1 small fw-bold text-muted">
                        <span class="dot bg-accent" style="width: 8px; height: 8px;"></span> Mes Actual
                    </span>
                    <span class="d-flex align-items-center gap-1 small fw-bold text-muted">
                        <span class="dot" style="width: 8px; height: 8px; background-color: #b7c0cf;"></span> Mes Anterior
                    </span>
                </div>
            </div>
            <div style="height: 300px;">
                <canvas id="chartVentasMes"></canvas>
            </div>
        </div>
    </div>

    <!-- Column 2: Ganancias por Eventos -->
    <div class="col-lg-4">
        <div class="premium-card">
            <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-stars text-warning"></i>
                    <h5 class="m-0 fw-bold" style="font-size: 15px; color: var(--text-secondary);">GANANCIAS POR EVENTOS (MES ACTUAL)</h5>
                </div>
            </div>
            <div style="min-height: 300px;" class="d-flex flex-column justify-content-center">
                <% if (stats.topEventos && stats.topEventos.length > 0) { %>
                    <div class="d-flex flex-column gap-3 w-100">
                        <% 
                            const maxEvent = Math.max(...stats.topEventos.map(e => e.total)) || 1;
                            const eventColors = ['#2e7d46', '#10b981', '#f59e0b', '#0ea5e9', '#f43f5e'];
                            stats.topEventos.forEach((e, i) => {
                                const color = eventColors[i % eventColors.length];
                                const pct = (e.total / maxEvent) * 100;
                        %>
                            <div class="event-row">
                                <div class="d-flex justify-content-between align-items-end">
                                    <span class="fw-bold" style="font-size: 13px; color: var(--text-secondary);"><%= e.nombre %></span>
                                    <span class="fw-bold text-dark" style="font-size: 13px;">$<%= Number(e.total).toLocaleString('es-CO', { maximumFractionDigits: 0 }) %></span>
                                </div>
                                <div class="event-progress-bg">
                                    <div class="event-progress-fill" style="width: <%= Math.max(pct, 2) %>%; background: linear-gradient(90deg, rgba(<%= hexToRgb(color) %>, 0.25), <%= color %>);"></div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="text-center text-muted small py-4">
                        <i class="bi bi-calendar-event d-block fs-3 mb-2 text-secondary"></i>
                        No hay eventos registrados en este período.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
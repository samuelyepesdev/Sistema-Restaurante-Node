<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Permisos - Superadmin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/admin/permisos.css">
</head>

<body>
    <%- include('../partials/navbar', { user, tenant: null, currentAdminPage: 'permisos' }) %>

        <div class="container-fluid py-4">
            <div class="admin-page-header">
                <h1><i class="bi bi-shield-lock me-2"></i>Permisos por restaurante y usuario</h1>
                <p class="mb-0">Elige el restaurante y el usuario. Los permisos marcados son los que tendrá; puedes
                    quitar permisos (ej. Inventario, Recetas) desmarcando y guardando. Los cambios se aplican al
                    instante (recargar página) o al volver a iniciar sesión.</p>
            </div>

            <!-- Selector de Restaurante y Usuario -->
            <%- include('permisos/_selector') %>

                <!-- Panel de Permisos -->
                <%- include('permisos/_panel_permisos') %>
        </div>

        <!-- Scripts -->
        <%- include('permisos/_scripts') %>
</body>

</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Permisos - Superadmin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background: linear-gradient(180deg, #f0f4f8 0%, #e2e8f0 100%); min-height: 100vh; }
        .navbar { background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%) !important; }
        .admin-page-header { background: #fff; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); padding: 1.5rem 2rem; margin-bottom: 1.5rem; border-left: 4px solid #0d6efd; }
        .permiso-card { border: none; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); margin-bottom: 1.5rem; overflow: hidden; }
        .permiso-card .card-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; font-weight: 600; padding: 1rem 1.25rem; }
        .permiso-list { max-height: 320px; overflow-y: auto; }
        .permiso-item { padding: 0.5rem 1rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: 0.75rem; }
        .permiso-item:last-child { border-bottom: none; }
        .permiso-item small { color: #64748b; }
    </style>
</head>
<body>
<%- include('../partials/navbar', { user, tenant: null }) %>

<div class="container-fluid py-4">
    <div class="admin-page-header">
        <h1><i class="bi bi-shield-lock me-2"></i>Permisos por rol</h1>
        <p class="mb-0">Asigna permisos a cada rol. Los usuarios con ese rol tendrán los permisos marcados. Los cambios aplican al volver a iniciar sesión.</p>
    </div>

    <div class="row">
        <% roles.forEach(function(rol) { %>
        <div class="col-lg-6 col-xl-4 mb-4">
            <div class="card permiso-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-person-badge me-2"></i><%= rol.nombre %></span>
                    <button type="button" class="btn btn-sm btn-primary btn-guardar-rol" data-rol-id="<%= rol.id %>">Guardar</button>
                </div>
                <div class="card-body p-0">
                    <% if (rol.nombre === 'superadmin') { %>
                    <div class="p-3 text-muted small">
                        <i class="bi bi-info-circle me-1"></i>El superadmin tiene acceso total; no es necesario asignar permisos concretos.
                    </div>
                    <% } else { %>
                    <div class="permiso-list">
                        <% permisos.forEach(function(p) { %>
                        <label class="permiso-item mb-0 cursor-pointer">
                            <input type="checkbox" class="form-check-input permiso-check" 
                                   data-rol-id="<%= rol.id %>" 
                                   value="<%= p.id %>" 
                                   <%= (permisosPorRol[rol.id] || []).indexOf(p.id) >= 0 ? 'checked' : '' %>>
                            <div class="flex-grow-1">
                                <strong><%= p.nombre %></strong>
                                <% if (p.descripcion) { %><br><small><%= p.descripcion %></small><% } %>
                            </div>
                        </label>
                        <% }); %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
        <% }); %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
(function() {
    document.querySelectorAll('.btn-guardar-rol').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var rolId = this.getAttribute('data-rol-id');
            var checks = document.querySelectorAll('.permiso-check[data-rol-id="' + rolId + '"]:checked');
            var permisoIds = Array.from(checks).map(function(c) { return c.value; });
            fetch('/admin/permisos/roles/' + rolId, {
                method: 'PUT',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ permiso_ids: permisoIds })
            })
            .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
            .then(function(o) {
                if (o.ok) Swal.fire({ icon: 'success', title: o.data.message || 'Permisos guardados' });
                else Swal.fire({ icon: 'error', title: o.data.error || 'Error' });
            })
            .catch(function() { Swal.fire({ icon: 'error', title: 'Error de conexión' }); });
        });
    });
})();
</script>
</body>
</html>

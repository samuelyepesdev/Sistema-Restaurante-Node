<div class="tab-pane fade show active" id="temas-pane" role="tabpanel">
    <p class="text-muted small mb-3">Temas agrupan parámetros (ej: "Unidades de masa" → kg, lb, g; "Alimentos" →
        bebidas, comidas). Asigná parámetros a cada tema.</p>
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-collection me-2"></i>Temas</span>
                    <button type="button" class="btn btn-sm btn-primary" id="btnNuevoTema"><i class="bi bi-plus"></i>
                        Nuevo</button>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush" id="listaTemas"></ul>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-tags me-2"></i>Parámetros</span>
                    <button type="button" class="btn btn-sm btn-primary" id="btnNuevoParametro"><i
                            class="bi bi-plus"></i> Nuevo</button>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush" id="listaParametros"></ul>
                </div>
            </div>
        </div>
    </div>
    <div class="card d-none" id="cardTemaParametros">
        <div class="card-header">
            <i class="bi bi-link-45deg me-2"></i>Parámetros del tema: <strong id="temaParametrosNombre"></strong>
        </div>
        <div class="card-body">
            <p class="small text-muted">Seleccioná los parámetros que pertenecen a este tema.</p>
            <div id="checkboxesParametrosTema"></div>
            <button type="button" class="btn btn-sm btn-primary mt-2" id="btnGuardarTemaParametros">Guardar</button>
        </div>
    </div>
</div>
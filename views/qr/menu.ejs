<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= tenant.nombre %> - Menú Digital</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="/css/modulos/menu-qr.css" rel="stylesheet">
    <style>
        /* CSS Premium Mobile-First */
        :root {
            --primary-color: <%= tenant.theme_colors.primary %>;
            --navbar-bg: <%= tenant.theme_colors.navbar %>;
            --navbar-text: <%= tenant.theme_colors.navbarText %>;
            --secondary-color: <%= tenant.theme_colors.secondary %>;
            --theme-font: <%= tenant.theme_font || "'Inter', sans-serif" %>;
        }
    </style>
</head>
<body>

    <!-- Top Header -->
    <div class="header-top">
        <div class="d-flex align-items-center">
            <% if (tenant.logo_src) { %>
                <img src="<%= tenant.logo_src %>" alt="Logo" class="tenant-logo me-2">
            <% } else { %>
                <h4 class="mb-0 fw-bold" style="color: var(--navbar-text);"><%= tenant.nombre %></h4>
            <% } %>
        </div>
        <div class="table-badge" style="color: var(--navbar-text);">
            <i class="bi bi-geo-alt-fill me-1"></i> Mesa <%= mesa.numero %>
        </div>
    </div>

    <!-- Categorías Horizontales -->
    <div class="categories-wrapper" id="catScroll">
        <% categorias.forEach((cat, idx) => { %>
            <a href="#cat-<%= cat.id %>" class="category-pill <%= idx === 0 ? 'active' : '' %>" data-id="<%= cat.id %>"><%= cat.nombre %></a>
        <% }) %>
    </div>

    <!-- Listado de Productos -->
    <div class="container-fluid p-0">
        <% if (categorias.length === 0) { %>
            <div class="text-center py-5 mt-5">
                <i class="bi bi-emoji-frown fs-1 text-muted mb-3 d-block"></i>
                <h5 class="text-muted fw-bold">No hay productos disponibles.</h5>
            </div>
        <% } %>

        <% categorias.forEach(cat => { %>
            <div class="category-section" id="cat-<%= cat.id %>">
                <h3 class="category-title"><%= cat.nombre %></h3>
                
                <% cat.productos.forEach(prod => { %>
                    <div class="product-card" data-id="<%= prod.id %>" data-nombre="<%= prod.nombre %>" data-precio="<%= prod.precio %>" data-descripcion="<%= prod.descripcion %>" data-imagen="<%= prod.imagen_url || '' %>" onclick="showProductDetails(this, event)">
                        <% if (prod.imagen_url) { %>
                            <img src="<%= prod.imagen_url %>" class="product-img" alt="<%= prod.nombre %>">
                        <% } else { %>
                            <div class="product-img-placeholder">
                                <i class="bi bi-cup-hot"></i>
                            </div>
                        <% } %>
                        <div class="product-info">
                            <h4 class="product-name"><%= prod.nombre %></h4>
                            <p class="product-desc"><%= prod.descripcion %></p>
                            <p class="product-price">$<%= Number(prod.precio).toLocaleString('es-CO') %></p>
                        </div>
                        
                        <!-- Add Button -->
                        <button class="add-btn" onclick="event.stopPropagation(); addToCart('<%= prod.id %>')">
                            <i class="bi bi-plus"></i>
                        </button>

                        <!-- QTY Controls -->
                        <div class="qty-controls" id="qty-<%= prod.id %>" onclick="event.stopPropagation()">
                            <button class="qty-btn text-danger" onclick="updateCart('<%= prod.id %>', -1)"><i class="bi bi-dash"></i></button>
                            <span class="qty-value" id="val-<%= prod.id %>">0</span>
                            <button class="qty-btn" style="color: var(--primary-color);" onclick="updateCart('<%= prod.id %>', 1)"><i class="bi bi-plus"></i></button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% }) %>
    </div>

    <!-- Bottom Action Bar -->
    <div class="bottom-cart" id="bottomCart">
        <div class="cart-info">
            <span class="cart-total-price" id="cartTotal">$0</span>
            <span class="cart-items-count" id="cartItems">0 items</span>
        </div>
        <button class="btn-ver-pedido" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
            Ver Pedido
        </button>
    </div>

    <!-- Offcanvas Cart Review -->
    <div class="offcanvas offcanvas-bottom" tabindex="-1" id="cartOffcanvas">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title"><i class="bi bi-cart3 me-2"></i>Tu Pedido</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <div id="cartList"></div>
            
            <div class="mt-4 pt-3 border-top">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="fs-5 fw-bold text-secondary">Total a Pagar:</span>
                    <span id="offcanvasTotal" class="fs-3 fw-black" style="color: var(--primary-color); font-weight: 900;">$0</span>
                </div>
                <!-- Observaciones -->
                <div class="mb-4">
                    <label class="form-label fw-bold small text-muted">¿Alguna indicación para la cocina? (Opcional)</label>
                    <textarea id="pedidoNotas" class="form-control bg-light border-0" rows="2" placeholder="Ej: Sin cebolla, extra salsa..."></textarea>
                </div>
                <button class="btn btn-ver-pedido w-100 py-3" id="btnEnviarPedido">
                    <i class="bi bi-send-fill me-2"></i> Confirmar y Pedir
                </button>
            </div>
        </div>
    </div>

    <!-- Product Detail Modal -->
    <div class="modal fade" id="productDetailModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
                <div class="modal-header border-bottom-0 pb-0" style="background: transparent;">
                    <button type="button" class="btn-close ms-auto bg-white p-2 border rounded-circle shadow-sm" data-bs-dismiss="modal" aria-label="Close" style="z-index: 10; margin-top: -5px; margin-right: -5px; opacity: 0.85;"></button>
                </div>
                <div class="modal-body pt-0 px-4 pb-4">
                    <div class="text-center mb-3">
                        <div id="modalProductImgPlaceholder" class="mx-auto rounded-4 mb-3 d-flex align-items-center justify-content-center text-secondary bg-light" style="width: 140px; height: 140px; font-size: 3rem;">
                            <i class="bi bi-cup-hot"></i>
                        </div>
                        <img id="modalProductImg" src="" alt="" class="img-fluid rounded-4 mx-auto mb-3 shadow-sm d-none" style="max-height: 200px; object-fit: cover; width: 100%;">
                        <h4 id="modalProductName" class="fw-bold mb-1" style="color: #2b2b2b;"></h4>
                        <p id="modalProductPrice" class="fs-4 fw-black mb-2" style="color: var(--primary-color); font-weight: 800;"></p>
                    </div>
                    <div class="bg-light p-3 rounded-4 mb-3">
                        <h6 class="text-uppercase small fw-bold text-muted mb-2"><i class="bi bi-info-circle me-1"></i> Descripción / Contenido</h6>
                        <p id="modalProductDesc" class="text-secondary mb-0" style="font-size: 0.95rem; line-height: 1.5; white-space: pre-wrap;"></p>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-secondary flex-grow-1 py-3" data-bs-dismiss="modal" style="border-radius: 12px; font-weight: 600;">Cerrar</button>
                        <button type="button" class="btn btn-primary flex-grow-1 py-3" id="modalAddBtn" style="border-radius: 12px; font-weight: 600; background-color: var(--primary-color); border-color: var(--primary-color);">
                            <i class="bi bi-plus-lg me-1"></i> Agregar al Pedido
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script type="application/json" id="qr-page-data"><%- JSON.stringify({ qrToken: qrToken }) %></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/modulos/menu-qr.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'Iniciar Sesión' %> - Sistema de Restaurante
    </title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/css/auth-login.css">
</head>

<body>

    <!-- ── Panel izquierdo: marca ── -->
    <aside class="login-brand">
        <div class="brand-top">
            <div class="brand-icon"><i class="bi bi-shop"></i></div>
            <span class="brand-name">Restaurante SaaS</span>
        </div>

        <div class="brand-center">
            <h2 class="brand-headline">
                Gestiona tu<br>negocio <span>sin límites</span>
            </h2>
            <p class="brand-sub">
                Control total de mesas, ventas, inventario y facturación
                desde un solo lugar.
            </p>
        </div>

        <div class="brand-features">
            <div class="feat-item">
                <div class="feat-icon"><i class="bi bi-grid-3x3-gap"></i></div>
                Gestión de mesas en tiempo real
            </div>
            <div class="feat-item">
                <div class="feat-icon"><i class="bi bi-receipt"></i></div>
                Facturación rápida e intuitiva
            </div>
            <div class="feat-item">
                <div class="feat-icon"><i class="bi bi-boxes"></i></div>
                Control de inventario y costos
            </div>
            <div class="feat-item">
                <div class="feat-icon"><i class="bi bi-bar-chart-line"></i></div>
                Analítica y reportes en vivo
            </div>
        </div>
    </aside>

    <!-- ── Panel derecho: formulario ── -->
    <main class="login-form-side">
        <div class="login-card">

            <!-- Logo visible en móvil -->
            <div class="mobile-logo">
                <div class="mobile-logo-icon"><i class="bi bi-shop"></i></div>
                <span class="mobile-logo-text">Restaurante SaaS</span>
            </div>

            <h1 class="login-title">Bienvenido</h1>
            <p class="login-subtitle">Ingresa tus credenciales para continuar</p>

            <!-- Alerta de error -->
            <div id="errorAlert" class="login-alert error" style="display:none;" role="alert">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span id="errorMsg"></span>
            </div>

            <!-- Mensaje de tenant / sesión expirada -->
            <% if (typeof mensaje !=='undefined' && mensaje) { %>
                <div class="login-alert warning" role="alert" id="mensajeTenant">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <%= mensaje %>
                </div>
                <% } %>

                    <!-- Formulario -->
                    <form id="loginForm" autocomplete="off" novalidate>

                        <div>
                            <label for="username" class="field-label">Usuario</label>
                            <div class="field-wrap">
                                <input type="text" class="field-input" id="username" name="username"
                                    placeholder="tu_usuario" required autofocus autocomplete="username">
                                <i class="bi bi-person field-icon"></i>
                            </div>
                        </div>

                        <div>
                            <label for="password" class="field-label">Contraseña</label>
                            <div class="field-wrap">
                                <input type="password" class="field-input has-toggle" id="password" name="password"
                                    placeholder="••••••••" required autocomplete="current-password">
                                <i class="bi bi-lock field-icon"></i>
                                <button type="button" class="pwd-toggle" id="togglePwd" aria-label="Mostrar contraseña"
                                    tabindex="-1">
                                    <i class="bi bi-eye" id="togglePwdIcon"></i>
                                </button>
                            </div>
                        </div>

                        <button type="submit" class="btn-login" id="btnLogin">
                            <i class="bi bi-box-arrow-in-right"></i>
                            Iniciar sesión
                        </button>
                    </form>

                    <p class="login-footer">
                        &copy; <%= new Date().getFullYear() %> Restaurante SaaS · Todos los derechos reservados
                    </p>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <%- include('_scripts_login') %>
</body>

</html>
<!-- Panel de Variación B: Focus -->
<div id="panelVariationB" style="display:none;">
    <!-- Tarjeta Premium Gradient Grande -->
    <div style="border-radius:18px;padding:26px 28px;background:linear-gradient(135deg,var(--accentDark),var(--accent));color:#fff;box-shadow:0 14px 30px -16px rgba(16,24,40,.5);display:flex;align-items:center;justify-content:space-between;gap:28px;flex-wrap:wrap;margin-bottom:20px;">
        <div style="min-width:240px;">
            <span style="font-size:13px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:rgba(255,255,255,.78);">Ventas del mes</span>
            <div style="font-size:42px;font-weight:800;letter-spacing:-.02em;line-height:1.05;margin:8px 0 12px;font-variant-numeric:tabular-nums;" id="focusVentasMesVal">$0</div>
            <span id="focusDeltaMes"></span>
        </div>
        <div style="display:flex;align-items:center;gap:30px;flex-wrap:wrap;">
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div>
                    <div style="font-size:12px;font-weight:600;color:rgba(255,255,255,.7);">Facturas</div>
                    <div style="font-size:20px;font-weight:800;font-variant-numeric:tabular-nums;" id="focusFacturasMesVal">0</div>
                </div>
                <div style="cursor:pointer;" data-action="modal-promedio" class="clickable">
                    <div style="font-size:12px;font-weight:600;color:rgba(255,255,255,.7);">Ticket prom.</div>
                    <div style="font-size:20px;font-weight:800;font-variant-numeric:tabular-nums;" id="focusTicketPromVal">$0</div>
                </div>
            </div>
            <div style="padding:14px 16px;border-radius:14px;background:rgba(255,255,255,.12);display:flex;flex-direction:column;align-items:center;">
                <div style="font-size:12px;font-weight:600;color:rgba(255,255,255,.78);margin-bottom:6px;">Últimos 30 días</div>
                <div id="sparkBigContainer" style="width:200px;height:40px;"></div>
            </div>
        </div>
    </div>

    <!-- Fila de Tarjetas de Pago y Stock (Focus) -->
    <div class="row g-3 mb-4">
        <!-- Efectivo -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:16px 18px;box-shadow:0 1px 2px rgba(16,24,40,.04);height:100%;">
                <div style="display:flex;align-items:center;gap:9px;margin-bottom:10px;">
                    <span style="width:30px;height:30px;border-radius:8px;background:var(--accentSoft);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:14px;"><i class="bi bi-cash"></i></span>
                    <span style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;color:#7a8499;">Efectivo Mes</span>
                </div>
                <div style="font-size:22px;font-weight:800;color:#0f172a;font-variant-numeric:tabular-nums;" id="focusEfectivoMesVal">$0</div>
                <div style="font-size:12px;color:#8a94a6;font-weight:600;margin-top:3px;" id="focusEfectivoMesPct">0% del total</div>
            </div>
        </div>
        <!-- Transferencia -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:16px 18px;box-shadow:0 1px 2px rgba(16,24,40,.04);height:100%;">
                <div style="display:flex;align-items:center;gap:9px;margin-bottom:10px;">
                    <span style="width:30px;height:30px;border-radius:8px;background:#eef2fb;color:#3257b0;display:flex;align-items:center;justify-content:center;font-size:14px;"><i class="bi bi-bank"></i></span>
                    <span style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;color:#7a8499;">Transferencia Mes</span>
                </div>
                <div style="font-size:22px;font-weight:800;color:#0f172a;font-variant-numeric:tabular-nums;" id="focusTransferenciaMesVal">$0</div>
                <div style="font-size:12px;color:#8a94a6;font-weight:600;margin-top:3px;" id="focusTransferenciaMesPct">0% del total</div>
            </div>
        </div>
        <!-- Servicios Externos -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:16px 18px;box-shadow:0 1px 2px rgba(16,24,40,.04);height:100%;">
                <div style="display:flex;align-items:center;gap:9px;margin-bottom:10px;">
                    <span style="width:30px;height:30px;border-radius:8px;background:var(--accentSoft);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:14px;"><i class="bi bi-box-arrow-up-right"></i></span>
                    <span style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;color:#7a8499;">Servicios Ext. Mes</span>
                </div>
                <div style="font-size:22px;font-weight:800;color:#0f172a;font-variant-numeric:tabular-nums;" id="focusServiciosMesVal">$0</div>
                <div style="font-size:12px;color:#8a94a6;font-weight:600;margin-top:3px;">Domicilios y apps</div>
            </div>
        </div>
        <!-- Bajo stock -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="clickable" data-action="go-inventario" style="background:#fff8ed;border:1px solid #fde7c7;border-radius:16px;padding:16px 18px;box-shadow:0 1px 2px rgba(16,24,40,.04);height:100%;cursor:pointer;">
                <div style="display:flex;align-items:center;gap:9px;margin-bottom:10px;">
                    <span style="width:30px;height:30px;border-radius:8px;background:#fdecca;color:#c2410c;display:flex;align-items:center;justify-content:center;font-size:14px;"><i class="bi bi-exclamation-triangle"></i></span>
                    <span style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;color:#9a3412;">Bajo stock</span>
                </div>
                <div style="font-size:22px;font-weight:800;color:#9a3412;font-variant-numeric:tabular-nums;" id="focusLowStockVal">0</div>
                <div style="font-size:12px;color:#b45309;font-weight:600;margin-top:3px;">Insumos por reponer</div>
            </div>
        </div>
    </div>

    <!-- Botones de Navegación de Pestañas (Focus) -->
    <div style="margin-top:20px;margin-bottom:16px;">
        <div style="display:inline-flex;gap:3px;padding:4px;background:#eceff2;border-radius:12px;">
            <button type="button" class="btn-focus-tab active" data-tab="resumen">
                <i class="bi bi-columns-gap"></i>Resumen
            </button>
            <button type="button" class="btn-focus-tab" data-tab="ventas">
                <i class="bi bi-graph-up"></i>Ventas
            </button>
            <button type="button" class="btn-focus-tab" data-tab="productos">
                <i class="bi bi-box-seam"></i>Productos
            </button>
            <button type="button" class="btn-focus-tab" data-tab="eventos">
                <i class="bi bi-calendar-event"></i>Eventos
            </button>
        </div>
    </div>

    <!-- Paneles de Pestañas (Focus) -->
    <div id="focusTabPanels">
        <!-- Panel Resumen -->
        <div id="focusPanelResumen">
            <div class="row">
                <div class="col-12 col-lg-8 mb-4" id="focusResumenChartCol"></div>
                <div class="col-12 col-lg-4 mb-4" id="focusResumenPaymentCol"></div>
            </div>
            <div class="row">
                <div class="col-12 mb-4" id="focusResumenCategoryCol"></div>
            </div>
        </div>

        <!-- Panel Ventas -->
        <div id="focusPanelVentas" style="display:none;">
            <div class="row">
                <div class="col-12 mb-4" id="focusVentasChartCol"></div>
                <div class="col-12 mb-4">
                    <div style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:20px;box-shadow:0 1px 2px rgba(16,24,40,.04);">
                        <h3 style="margin:0 0 14px;font-size:16px;font-weight:700;color:#0f172a;"><i class="bi bi-receipt me-2"></i>Facturas recientes</h3>
                        <div id="invoicesListContainer">
                            <!-- La tabla de facturas se insertará aquí mediante JS -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel Productos -->
        <div id="focusPanelProductos" style="display:none;">
            <div class="row">
                <div class="col-12 col-lg-6 mb-4" id="focusProductosListCol"></div>
                <div class="col-12 col-lg-6 mb-4" id="focusProductosCategoryCol"></div>
            </div>
        </div>

        <!-- Panel Eventos -->
        <div id="focusPanelEventos" style="display:none;">
            <div class="row">
                <div class="col-12 col-lg-6 mb-4" id="focusEventosCalendarCol"></div>
                <div class="col-12 col-lg-6 mb-4">
                    <div style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:20px;box-shadow:0 1px 2px rgba(16,24,40,.04);height:100%;">
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                            <h3 style="margin:0;font-size:16px;font-weight:700;color:#0f172a;"><i class="bi bi-calendar-check me-2"></i>Eventos del mes</h3>
                            <span style="font-size:13px;font-weight:700;color:var(--accent);" id="ventasEventosMesTotal">$0</span>
                        </div>
                        <div id="eventsListContainer">
                            <!-- El listado de eventos se insertará aquí mediante JS -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

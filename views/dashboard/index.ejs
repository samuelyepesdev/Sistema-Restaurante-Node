<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistema de Facturación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null }) %>

        <div class="container mt-4">
            <h1 class="mb-4">
                <i class="bi bi-graph-up-arrow me-2"></i>
                Dashboard de Estadísticas
            </h1>

            <!-- Filtros de fecha -->
            <div class="filter-section">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-3">
                        <label class="form-label">Desde</label>
                        <input type="date" id="filtroDesde" class="form-control">
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Hasta</label>
                        <input type="date" id="filtroHasta" class="form-control">
                    </div>
                    <div class="col-12 col-md-3">
                        <button id="aplicarFiltros" class="btn btn-primary w-100">
                            <i class="bi bi-funnel me-2"></i>Aplicar Filtros
                        </button>
                    </div>
                    <div class="col-12 col-md-3">
                        <button id="limpiarFiltros" class="btn btn-secondary w-100">
                            <i class="bi bi-x-circle me-2"></i>Limpiar
                        </button>
                    </div>
                </div>
            </div>

            <%- include('_stats_cards', { allowedByPlan: typeof allowedByPlan !=='undefined' ? allowedByPlan : null })
                %>

                <!-- Gr?ficos principales: en tablet/m?vil se apilan (col-lg para que debajo de 992px cada uno vaya a ancho completo) -->
                <div class="row">
                    <div class="col-12 col-lg-8">
                        <div class="card">
                            <div class="card-header">
                                <i class="bi bi-graph-up me-2"></i>
                                Ventas Diarias (últimos 30 días)
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="dailySalesChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-4">
                        <div class="card">
                            <div class="card-header">
                                <i class="bi bi-calendar3 me-2"></i>
                                Calendario: días del mes con evento
                            </div>
                            <div class="card-body">
                                <div id="miniCalendarioEventos" class="mini-calendario-container">
                                    <div class="text-muted small text-center py-3">Cargando...</div>
                                </div>
                                <p class="small text-muted mb-0 mt-2">Cada día del mes que tenga al menos un evento se
                                    marca
                                    en violeta. Hoy en azul. Usó las flechas para ver otros meses.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">
                                <i class="bi bi-calendar-event me-2"></i>
                                Ventas en eventos
                            </div>
                            <div class="card-body">
                                <div class="chart-container-small">
                                    <canvas id="ventasEnEventosChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">
                                <i class="bi bi-bar-chart me-2"></i>
                                Ventas por Categoría
                            </div>
                            <div class="card-body">
                                <div class="chart-container-small">
                                    <canvas id="salesByCategoryChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">
                                <i class="bi bi-trophy me-2"></i>
                                Top 10 Productos Más Vendidos
                            </div>
                            <div class="card-body">
                                <div class="chart-container-small">
                                    <canvas id="topProductsChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabla de productos m?s vendidos por categor?a -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <i class="bi bi-list-ul me-2"></i>
                                Productos Más Vendidos por Categoría
                            </div>
                            <div class="card-body">
                                <div id="topProductsByCategoryTable">
                                    <div class="loading-spinner">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Cargando...</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
        </div>

        <%- include('_modales') %>

            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
            <script src="/js/dashboard.js"></script>
</body>

</html>
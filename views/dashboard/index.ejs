<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistema de Facturación</title>
    <!-- Fonts and Styles -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/modulos/dashboard.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant !=='undefined' ? tenant : null }) %>

    <div id="dashboardRoot">
        <div class="container py-4">
            
            <!-- Encabezado y Selector de Tema/Variación -->
            <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-4">
                <div>
                    <div class="d-flex align-items-center gap-2">
                        <span style="width:40px;height:40px;border-radius:11px;background:var(--accentSoft);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:20px;">
                            <i class="bi bi-graph-up-arrow"></i>
                        </span>
                        <h1 class="mb-0 fw-bold" style="font-size:26px; letter-spacing:-.02em; color:#0f172a;">Panel de control</h1>
                    </div>
                    <p class="mb-0 text-muted fw-semibold" style="margin-left: 48px; font-size:13.5px;" id="currentDateLabel">Cargando fecha...</p>
                </div>
                
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <!-- Variaciones: Analytics o Focus -->
                    <div style="display:inline-flex;gap:3px;padding:4px;background:#eceff2;border-radius:12px;">
                        <button type="button" class="btn-variation active" data-variation="A">
                            <i class="bi bi-grid-1x2-fill"></i>Analytics
                        </button>
                        <button type="button" class="btn-variation" data-variation="B">
                            <i class="bi bi-bullseye"></i>Focus
                        </button>
                    </div>

                    <% if (user.permisos && user.permisos.includes('reporte_mensual.test')) { %>
                        <button class="btn btn-outline-success border-2 px-3 fw-bold" id="btnTestReporteMensual" style="border-radius:11px; font-size:13.5px; height: 38px;">
                            <i class="bi bi-file-earmark-pdf me-2"></i>Reporte Prueba
                        </button>
                    <% } %>
                </div>
            </div>

            <!-- Alertas de Eventos -->
            <% if (typeof proximosEventos !== 'undefined' && proximosEventos.length > 0) { %>
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card border-0 shadow-sm rounded-4" style="background: linear-gradient(135deg, #f0fdf4 0%, #e0f2fe 100%);">
                            <div class="card-body p-4">
                                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-bell-fill text-warning me-2"></i>Notificaciones de Eventos Principales</h5>
                                <div class="row g-3">
                                    <% 
                                    const formatYMD = (d) => typeof d === 'string' ? d.split('T')[0] : d.toISOString().split('T')[0];
                                    const parseLocalDate = (dStr) => new Date(formatYMD(dStr) + 'T00:00:00');
                                    
                                    const hoyStr = new Date(Date.now() - new Date().getTimezoneOffset() * 60000).toISOString().split('T')[0];
                                    const todayMidnight = new Date(hoyStr + 'T00:00:00');
                                    
                                    proximosEventos.forEach(ev => { 
                                        const inicioStr = formatYMD(ev.fecha_inicio);
                                        const finStr = formatYMD(ev.fecha_fin);
                                        const fInicio = parseLocalDate(ev.fecha_inicio);
                                        
                                        const estaEnCursoHoy = (hoyStr >= inicioStr && hoyStr <= finStr);
                                    %>
                                        <div class="col-md-6 col-xxl-4 event-card-item" data-nombre="<%= ev.nombre %>" data-curso="<%= estaEnCursoHoy %>" data-inicio="<%= inicioStr %>">
                                            <div class="p-3 bg-white rounded-4 border-start border-4 <%= estaEnCursoHoy ? 'border-primary' : 'border-info' %> shadow-sm h-100">
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <h6 class="fw-bold mb-0 text-dark text-truncate" style="max-width: 70%;" title="<%= ev.nombre %>"><%= ev.nombre %></h6>
                                                    <% if (estaEnCursoHoy) { %>
                                                        <span class="badge bg-primary rounded-pill"><i class="bi bi-stars me-1"></i>¡HOY!</span>
                                                    <% } else { %>
                                                        <%
                                                            const diffTime = Math.abs(fInicio - todayMidnight);
                                                            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                                                        %>
                                                        <span class="badge bg-info text-dark rounded-pill">En <%= diffDays %> días</span>
                                                    <% } %>
                                                </div>
                                                <p class="small text-muted mb-2">
                                                    <i class="bi bi-calendar3 me-1"></i>
                                                    <%= inicioStr %> <% if (inicioStr !== finStr) { %> al <%= finStr %> <% } %>
                                                </p>
                                                <% if (ev.descripcion) { %>
                                                    <p class="small text-secondary mb-0 text-truncate" title="<%= ev.descripcion %>"><%= ev.descripcion %></p>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>

            <!-- Banner Alerta Insumos Bajo Stock -->
            <div id="lowStockAlertBanner" style="display:none; align-items:center; gap:12px; padding:11px 16px; border-radius:12px; background:#fff8ed; border:1px solid #fde7c7; margin-bottom:20px;">
                <span style="width:30px;height:30px;border-radius:8px;background:#fdecca;color:#c2410c;display:flex;align-items:center;justify-content:center;font-size:15px;"><i class="bi bi-exclamation-triangle"></i></span>
                <div style="flex:1;min-width:0;">
                    <span style="font-size:13.5px;font-weight:700;color:#9a3412;"><span id="lowStockCount">0</span> insumos por debajo del stock mínimo</span>
                    <span style="font-size:13px;color:#b45309;font-weight:500;" id="lowStockNames"></span>
                </div>
                <a href="/inventario" style="font-size:13px;font-weight:700;color:#c2410c;display:flex;align-items:center;gap:5px;cursor:pointer;text-decoration:none;">Ver inventario<i class="bi bi-arrow-right"></i></a>
            </div>

            <!-- Filtros de fecha -->
            <div style="background:white; padding:16px; border-radius:16px; border:1px solid #e9ebef; box-shadow:0 1px 2px rgba(16,24,40,.04); margin-bottom:20px;">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-3">
                        <label class="form-label mb-1" style="font-size:12.5px;font-weight:700;color:#5b6573;">Desde</label>
                        <input type="date" id="filtroDesde" class="form-control" style="border-radius:10px;font-size:13.5px;border-color:#eceff2;">
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label mb-1" style="font-size:12.5px;font-weight:700;color:#5b6573;">Hasta</label>
                        <input type="date" id="filtroHasta" class="form-control" style="border-radius:10px;font-size:13.5px;border-color:#eceff2;">
                    </div>
                    <div class="col-12 col-md-3">
                        <button id="aplicarFiltros" class="btn w-100 text-white" style="background:var(--accent); border-radius:10px; font-size:13.5px; font-weight:700; border:none; height:38px;">
                            <i class="bi bi-funnel me-2"></i>Aplicar Filtros
                        </button>
                    </div>
                    <div class="col-12 col-md-3">
                        <button id="limpiarFiltros" class="btn btn-secondary w-100" style="border-radius:10px; font-size:13.5px; font-weight:700; border:none; height:38px;">
                            <i class="bi bi-x-circle me-2"></i>Limpiar
                        </button>
                    </div>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- VARIACIÓN A: ANALYTICS                     -->
            <!-- ========================================== -->
            <%- include('_panel_analytics') %>

            <!-- ========================================== -->
            <!-- VARIACIÓN B: FOCUS                         -->
            <!-- ========================================== -->
            <%- include('_panel_focus') %>

            <!-- ========================================== -->
            <!-- ELEMENTOS COMPARTIDOS (WIDGETS MÓVILES)   -->
            <!-- ========================================== -->
            <%- include('_shared_widgets') %>

        </div>
    </div>

    <%- include('_modales') %>

    <!-- External libraries -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Custom scripts -->
    <script src="/js/modulos/dashboard/dashboard_core.js"></script>
    <script src="/js/modulos/dashboard/dashboard_helpers.js"></script>
    <script src="/js/modulos/dashboard/dashboard_ui.js"></script>

    <!-- Script para Modal de Eventos -->
    <% if (typeof proximosEventos !== 'undefined' && proximosEventos.length > 0) { %>
        <script src="/js/modulos/dashboard-eventos.js"></script>
    <% } %>
</body>

</html>
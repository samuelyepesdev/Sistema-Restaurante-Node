<!-- Modal: detalle Promedio por Factura -->
<div class="modal fade" id="modalDetallePromedio" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="bi bi-bar-chart me-2"></i>Promedio por Factura</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">El promedio por factura se calcula as?:</p>
                <div class="bg-light rounded p-3 mb-2 font-monospace text-center">
                    <span id="modalPromedioFormula">Total ventas / Cantidad de facturas = Promedio</span>
                </div>
                <ul class="list-unstyled mb-0">
                    <li><strong>Total ventas (período):</strong> <span id="modalPromedioTotal">$0</span></li>
                    <li><strong>Cantidad de facturas:</strong> <span id="modalPromedioCantidad">0</span></li>
                    <li><strong>Promedio:</strong> <span id="modalPromedioValor" class="text-primary fw-bold">$0</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Modal: detalle Ventas en eventos -->
<div class="modal fade" id="modalDetalleVentasEventos" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-white" style="background: linear-gradient(135deg, #fd7e14 0%, #e8590c 100%);">
                <h5 class="modal-title"><i class="bi bi-calendar-event me-2"></i>Ventas en eventos</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Resumen de ventas asociadas a eventos en el período seleccionado:</p>
                <ul class="list-unstyled mb-0">
                    <li><strong>Total vendido en eventos:</strong> <span id="modalVentasEventosTotal"
                            class="text-primary fw-bold">$0</span></li>
                    <li><strong>Cantidad de ventas (facturas) en eventos:</strong> <span
                            id="modalVentasEventosCantidad">0</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>
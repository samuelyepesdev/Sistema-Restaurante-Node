<!-- Panel de Variación A: Analytics -->
<div id="panelVariationA">
    <!-- Tarjetas de Estadísticas Principales -->
    <div class="row g-3 mb-4">
        <!-- Ventas de hoy -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="clickable" data-action="go-ventas" style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:18px;box-shadow:0 1px 2px rgba(16,24,40,.04);display:flex;flex-direction:column;gap:12px;height:100%;transition:transform .2s,box-shadow .2s;cursor:pointer;" onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0, 0, 0, .08)'" onmouseleave="this.style.transform='none';this.style.boxShadow='0 1px 2px rgba(16,24,40,.04)'">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <span style="font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#7a8499;">Ventas de hoy</span>
                    <span style="width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;background:var(--accentSoft);color:var(--accent);font-size:15px;"><i class="bi bi-cash-coin"></i></span>
                </div>
                <div style="font-size:29px;font-weight:800;letter-spacing:-.02em;color:#0f172a;font-variant-numeric:tabular-nums;line-height:1;" id="statsVentasHoyVal">$0</div>
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                    <span id="deltaVentasHoy"></span>
                    <div id="sparkVentasHoy" style="width:108px;height:36px;display:flex;justify-content:flex-end;"></div>
                </div>
            </div>
        </div>
        <!-- Facturas hoy -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="clickable" data-action="go-ventas" style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:18px;box-shadow:0 1px 2px rgba(16,24,40,.04);display:flex;flex-direction:column;gap:12px;height:100%;transition:transform .2s,box-shadow .2s;cursor:pointer;" onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0, 0, 0, .08)'" onmouseleave="this.style.transform='none';this.style.boxShadow='0 1px 2px rgba(16,24,40,.04)'">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <span style="font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#7a8499;">Facturas hoy</span>
                    <span style="width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;background:var(--accentSoft);color:var(--accent);font-size:15px;"><i class="bi bi-receipt"></i></span>
                </div>
                <div style="font-size:29px;font-weight:800;letter-spacing:-.02em;color:#0f172a;font-variant-numeric:tabular-nums;line-height:1;" id="statsFacturasHoyVal">0</div>
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                    <span id="deltaFacturasHoy"></span>
                    <div id="sparkFacturasHoy" style="width:108px;height:36px;display:flex;justify-content:flex-end;"></div>
                </div>
            </div>
        </div>
        <!-- Ticket promedio -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="clickable" data-action="modal-promedio" style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:18px;box-shadow:0 1px 2px rgba(16,24,40,.04);display:flex;flex-direction:column;gap:12px;height:100%;transition:transform .2s,box-shadow .2s;cursor:pointer;" onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0, 0, 0, .08)'" onmouseleave="this.style.transform='none';this.style.boxShadow='0 1px 2px rgba(16,24,40,.04)'">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <span style="font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#7a8499;">Ticket promedio</span>
                    <span style="width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;background:var(--accentSoft);color:var(--accent);font-size:15px;"><i class="bi bi-graph-up"></i></span>
                </div>
                <div style="font-size:29px;font-weight:800;letter-spacing:-.02em;color:#0f172a;font-variant-numeric:tabular-nums;line-height:1;" id="statsTicketPromVal">$0</div>
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                    <span id="deltaTicketProm"></span>
                    <div id="sparkTicketProm" style="width:108px;height:36px;display:flex;justify-content:flex-end;"></div>
                </div>
            </div>
        </div>
        <!-- Venta neta del mes -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="clickable" data-action="go-ventas" style="background:#fff;border:1px solid #e9ebef;border-radius:16px;padding:18px;box-shadow:0 1px 2px rgba(16,24,40,.04);display:flex;flex-direction:column;gap:12px;height:100%;transition:transform .2s,box-shadow .2s;cursor:pointer;" onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(0, 0, 0, .08)'" onmouseleave="this.style.transform='none';this.style.boxShadow='0 1px 2px rgba(16,24,40,.04)'">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <span style="font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#7a8499;">Venta neta del mes</span>
                    <span style="width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;background:var(--accentSoft);color:var(--accent);font-size:15px;"><i class="bi bi-wallet2"></i></span>
                </div>
                <div style="font-size:29px;font-weight:800;letter-spacing:-.02em;color:#0f172a;font-variant-numeric:tabular-nums;line-height:1;" id="statsVentaNetaMesVal">$0</div>
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                    <span id="deltaVentaNetaMes"></span>
                    <div id="sparkVentaNetaMes" style="width:108px;height:36px;display:flex;justify-content:flex-end;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Columna para Gráfico de Línea -->
        <div class="col-12 col-lg-8 mb-4" id="analyticsChartCol">
            <!-- El contenedor del gráfico diario se insertará aquí mediante JS -->
        </div>
        <!-- Columna para Métodos de Pago -->
        <div class="col-12 col-lg-4 mb-4" id="analyticsPaymentCol">
            <!-- El contenedor del gráfico de métodos de pago se insertará aquí mediante JS -->
        </div>
    </div>

    <div class="row">
        <!-- Ventas por Categoría -->
        <div class="col-12 col-lg-6 mb-4" id="analyticsCategoryCol">
            <!-- El contenedor de categorías se insertará aquí mediante JS -->
        </div>
        <!-- Top Productos -->
        <div class="col-12 col-lg-6 mb-4" id="analyticsProductsCol">
            <!-- El contenedor de productos más vendidos se insertará aquí mediante JS -->
        </div>
    </div>

    <div class="row">
        <!-- Resumen del Mes -->
        <div class="col-12 col-lg-7 mb-4" id="analyticsResumenCol">
            <!-- El resumen mensual se insertará aquí mediante JS -->
        </div>
        <!-- Calendario -->
        <div class="col-12 col-lg-5 mb-4" id="analyticsCalendarCol">
            <!-- El mini-calendario se insertará aquí mediante JS -->
        </div>
    </div>
</div>

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Productos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/modulos/productos.css">
    <style>
        <% 
        const activeAccent = (typeof tenant !== 'undefined' && tenant && tenant.config && tenant.config.colores && tenant.config.colores.primary) 
            ? tenant.config.colores.primary 
            : '#2e7d46';
        %>
        :root {
            --accent: <%= activeAccent %>;
            --accentDark: color-mix(in srgb, <%= activeAccent %> 80%, black);
            --accentSoft: color-mix(in srgb, <%= activeAccent %> 8%, white);
            --accentSofter: color-mix(in srgb, <%= activeAccent %> 4%, white);
        }
    </style>
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null, tenant: typeof tenant !== 'undefined' ? tenant : null }) %>

    <div class="container animate__animated animate__fadeIn">
        
        <!-- Header Section -->
        <div class="page-header-container">
            <div class="page-title-section">
                <span class="page-title-icon">
                    <i class="bi bi-box-seam"></i>
                </span>
                <div class="page-title-text">
                    <h1>Gestión de productos</h1>
                    <p id="productCountLabel"><%= productos.length %> de <%= productos.length %> productos en catálogo</p>
                </div>
            </div>
            
            <div class="header-actions">
                <% if (typeof allowedByPlan !== 'undefined' && allowedByPlan && allowedByPlan.plantillas && user && user.permisos && user.permisos.includes('plantillas.ver')) { %>
                    <button id="btnDescargarPlantilla" class="btn-premium-outline">
                        <i class="bi bi-file-earmark-excel"></i> Plantilla Excel
                    </button>
                    <button id="btnImportarProductos" class="btn-premium-outline">
                        <i class="bi bi-upload"></i> Importar Excel
                    </button>
                    <input type="file" id="archivoImport" accept=".xlsx" class="d-none">
                <% } %>
                <% if (user && user.permisos && user.permisos.includes('productos.crear')) { %>
                    <button class="btn-premium-action" data-bs-toggle="modal" data-bs-target="#nuevoProductoModal">
                        <i class="bi bi-plus-lg"></i> Nuevo producto
                    </button>
                <% } %>
            </div>
        </div>

        <!-- Search & Filter Controls -->
        <div class="filters-row">
            <div class="search-input-wrapper">
                <i class="bi bi-search"></i>
                <input type="text" id="buscarProducto" placeholder="Buscar producto por nombre o código...">
            </div>
            
            <!-- Category Filter Chips -->
            <%- include('_category_filter') %>
        </div>

        <!-- Products Table -->
        <%- include('_table', { productos: productos, recetasPorProducto: typeof recetasPorProducto !== 'undefined' ? recetasPorProducto : {} }) %>

    </div>

    <!-- Modals -->
    <%- include('_modal_costeo') %>
    <%- include('_modal_form', { categorias: categorias }) %>

    <!-- Base Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Load modules -->
    <script src="/js/core/modules/Utils.js"></script>
    <script src="/js/core/modules/ApiClient.js"></script>
    <script src="/js/core/modules/AlertManager.js"></script>
    <script src="/js/core/modules/SearchManager.js"></script>
    <script src="/js/core/modules/FormManager.js"></script>
    <script src="/js/core/modules/TableManager.js"></script>
    
    <!-- Load main script -->
    <script src="/js/modulos/productos/productos_core.js"></script>
    <script src="/js/modulos/productos/productos_ui.js"></script>
</body>

</html>
<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th class="text-end">Precio Unitario</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody id="productosTabla">
            <% const recetasMap=typeof recetasPorProducto !=='undefined' ? recetasPorProducto : {};
                productos.forEach(function(producto) { const tieneReceta=recetasMap[producto.id]; %>
                <tr data-categoria-id="<%= producto.categoria_id || '' %>" data-producto-id="<%= producto.id %>">
                    <td>
                        <%= producto.codigo %>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-link p-0 me-1 btn-toggle-favorito" data-id="<%= producto.id %>"
                            data-favorito="<%= producto.es_favorito %>"
                            title="<%= producto.es_favorito ? 'Quitar de favoritos' : 'Agregar a favoritos' %>">
                            <i
                                class="bi <%= producto.es_favorito ? 'bi-star-fill text-warning' : 'bi-star text-muted' %>"></i>
                        </button>
                        <%= producto.nombre %>
                    </td>
                    <td><span class="badge bg-secondary">
                            <%= producto.categoria_nombre || 'Sin categoría' %>
                        </span></td>
                    <td class="text-end">$<%= (Number(producto.precio_unidad) || 0).toLocaleString('es-CO', {
                            minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </td>
                    <td class="text-center">
                        <div class="action-buttons">
                            <% if (user && user.permisos && user.permisos.includes('costeo.ver') && tieneReceta) { %>
                                <button class="btn btn-sm btn-outline-info me-1" data-id="<%= producto.id %>"
                                    data-action="costeo" title="Ver costeo y precio sugerido">
                                    <i class="bi bi-calculator"></i>
                                </button>
                                <% } %>
                                    <% if (user && user.permisos && user.permisos.includes('productos.editar')) { %>
                                        <button class="btn btn-sm btn-outline-primary me-1" data-id="<%= producto.id %>"
                                            data-action="editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <% } %>
                                            <% if (user && user.permisos &&
                                                user.permisos.includes('productos.eliminar')) { %>
                                                <button class="btn btn-sm btn-outline-danger"
                                                    data-id="<%= producto.id %>" data-action="eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                                <% } %>
                        </div>
                    </td>
                </tr>
                <% }); %>
        </tbody>
    </table>
</div>
<!-- Modal Costeo (precio sugerido) -->
<div class="modal fade" id="costeoProductoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-calculator me-2"></i>
                    Costeo y precio sugerido
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="costeoModalBody">
                <div class="text-center py-3" id="costeoLoading">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2 mb-0 small text-muted">Cargando costeo...</p>
                </div>
                <div id="costeoContent" class="d-none">
                    <div class="row small mb-2">
                        <div class="col-6 text-muted">Costo materia prima</div>
                        <div class="col-6 text-end"><strong id="costeoDirecto">-</strong></div>
                    </div>
                    <div class="row small mb-2">
                        <div class="col-6 text-muted">Merma (<span id="costeoMermaPct">0</span>%)</div>
                        <div class="col-6 text-end"><strong id="costeoIndirecto">-</strong></div>
                    </div>
                    <div class="row small mb-2">
                        <div class="col-6 text-muted">Costo total porción</div>
                        <div class="col-6 text-end"><strong id="costeoTotal">-</strong></div>
                    </div>
                    <hr>
                    <div class="row mb-2">
                        <div class="col-6">Precio sugerido</div>
                        <div class="col-6 text-end"><strong class="text-success" id="costeoPrecioSug">-</strong></div>
                    </div>
                    <div class="row small mb-2">
                        <div class="col-6 text-muted">Precio actual</div>
                        <div class="col-6 text-end" id="costeoPrecioActual">-</div>
                    </div>
                    <div class="row small">
                        <div class="col-6 text-muted">Margen de contribución</div>
                        <div class="col-6 text-end" id="costeoMargen">-</div>
                    </div>
                </div>
                <div id="costeoError" class="alert alert-warning d-none mb-0"></div>
            </div>
            <div class="modal-footer d-none" id="costeoFooter">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <% if (user && user.permisos && user.permisos.includes('productos.editar')) { %>
                    <button type="button" class="btn btn-success" id="btnAplicarPrecioSugerido">
                        <i class="bi bi-check-lg me-1"></i>Aplicar precio sugerido
                    </button>
                    <% } %>
            </div>
        </div>
    </div>
</div>
<%
const formatDateUTC = (d) => {
    if (!d) return '—';
    return new Date(d).toLocaleDateString('es-CO', { timeZone: 'UTC', day: '2-digit', month: '2-digit', year: 'numeric' });
};
const formatYMD = (d) => {
    if (!d) return '';
    return typeof d === 'string' ? d.split('T')[0] : d.toISOString().split('T')[0];
};
%>
<!-- Vista móvil: solo nombre + botones -->
<div class="d-block d-md-none eventos-mobile">
    <% (eventos || []).forEach(function(e) { %>
        <div class="evento-mobile-item border rounded p-3 mb-3 bg-white">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="fw-semibold">
                    <%= e.nombre %>
                </span>
                <span class="badge bg-<%= (e.tipo || 'permanente') === 'ocasional' ? 'warning text-dark' : 'info' %>">
                    <%= (e.tipo || 'permanente' )==='ocasional' ? 'Ocasional' : 'Permanente' %>
                </span>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a href="/facturas/facturar?evento_id=<%= e.id %>" class="btn btn-sm btn-success">
                    <i class="bi bi-cart-plus me-1"></i>Ventas
                </a>
                <a href="/ventas?evento_id=<%= e.id %>" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-list-ul me-1"></i>Ver
                </a>
                <% if (user && user.permisos && user.permisos.includes('eventos.editar')) { %>
                    <button type="button" class="btn btn-sm btn-outline-primary"
                        onclick="editarEvento(<%= e.id %>, '<%= (e.nombre || '').replace(/'/g, '\\\'') %>', '<%= formatYMD(e.fecha_inicio) %>', '<%= formatYMD(e.fecha_fin) %>', '<%= (e.descripcion || '').replace(/'/g, '\\\'') %>', <%= e.activo ? 'true' : 'false' %>, '<%= (e.tipo || 'permanente') %>')">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <% } %>
                        <% if (user && user.permisos && user.permisos.includes('eventos.eliminar')) { %>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                onclick="eliminarEvento(<%= e.id %>, '<%= (e.nombre || '').replace(/'/g, '\\\'') %>')">
                                <i class="bi bi-trash"></i>
                            </button>
                            <% } %>
            </div>
        </div>
        <% }); %>
            <% if (!eventos || eventos.length===0) { %>
                <p class="text-muted text-center py-4 mb-0">No hay eventos. Crea uno para asociar ventas.</p>
                <% } %>
</div>

<!-- Vista escritorio: tabla completa -->
<div class="table-responsive d-none d-md-block">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Fecha inicio</th>
                <th>Fecha fin</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th>Ventas</th>
                <% if (user && user.permisos && (user.permisos.includes('eventos.editar') ||
                    user.permisos.includes('eventos.eliminar'))) { %>
                    <th class="text-end">Acciones</th>
                    <% } %>
            </tr>
        </thead>
        <tbody>
            <% (eventos || []).forEach(function(e) { %>
                <tr>
                    <td><strong>
                            <%= e.nombre %>
                        </strong></td>
                    <td><span
                            class="badge bg-<%= (e.tipo || 'permanente') === 'ocasional' ? 'warning text-dark' : 'info' %>">
                            <%= (e.tipo || 'permanente' )==='ocasional' ? 'Ocasional' : 'Permanente' %>
                        </span></td>
                    <td>
                        <%= formatDateUTC(e.fecha_inicio) %>
                    </td>
                    <td>
                        <%= formatDateUTC(e.fecha_fin) %>
                    </td>
                    <td>
                        <%= e.descripcion ? e.descripcion.substring(0, 50) + (e.descripcion.length> 50 ? '…' : '') : '—'
                            %>
                    </td>
                    <td><span class="badge bg-<%= e.activo ? 'success' : 'secondary' %>">
                            <%= e.activo ? 'Activo' : 'Inactivo' %>
                        </span></td>
                    <td>
                        <a href="/facturas/facturar?evento_id=<%= e.id %>" class="btn btn-sm btn-success me-1"><i
                                class="bi bi-cart-plus me-1"></i>Realizar ventas</a>
                        <a href="/ventas?evento_id=<%= e.id %>" class="btn btn-sm btn-outline-secondary"><i
                                class="bi bi-list-ul me-1"></i>Ver ventas</a>
                    </td>
                    <% if (user && user.permisos && (user.permisos.includes('eventos.editar') ||
                        user.permisos.includes('eventos.eliminar'))) { %>
                        <td class="text-end">
                            <% if (user.permisos.includes('eventos.editar')) { %>
                                <button type="button" class="btn btn-sm btn-outline-primary me-1"
                                    onclick="editarEvento(<%= e.id %>, '<%= (e.nombre || '').replace(/'/g, '\\\'') %>', '<%= formatYMD(e.fecha_inicio) %>', '<%= formatYMD(e.fecha_fin) %>', '<%= (e.descripcion || '').replace(/'/g, '\\\'') %>', <%= e.activo ? 'true' : 'false' %>, '<%= (e.tipo || 'permanente') %>')"
                                    title="Editar"><i class="bi bi-pencil"></i></button>
                                <% } %>
                                    <% if (user.permisos.includes('eventos.eliminar')) { %>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="eliminarEvento(<%= e.id %>, '<%= (e.nombre || '').replace(/'/g, '\\\'') %>')"
                                            title="Eliminar"><i class="bi bi-trash"></i></button>
                                        <% } %>
                        </td>
                        <% } %>
                </tr>
                <% }); %>
                    <% if (!eventos || eventos.length===0) { %>
                        <tr>
                            <td colspan="<%= (user && user.permisos && (user.permisos.includes('eventos.editar') || user.permisos.includes('eventos.eliminar'))) ? 8 : 7 %>"
                                class="text-muted text-center py-4">No hay eventos. Crea uno para asociar ventas (sus estadísticas se mantendrán aisladas de la venta diaria).</td>
                        </tr>
                        <% } %>
        </tbody>
    </table>
</div>
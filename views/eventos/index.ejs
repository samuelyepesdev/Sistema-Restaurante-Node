<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eventos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/modulos/eventos.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null }) %>

        <div class="container mt-4">
            <div class="card">
                <div class="card-header">
                    <div
                        class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-3 w-100">
                        <div class="fw-semibold">
                            <i class="bi bi-calendar-event me-2"></i>Eventos
                        </div>
                        <% if (user && user.permisos && user.permisos.includes('eventos.crear')) { %>
                            <div class="d-flex flex-wrap gap-2">
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal"
                                    data-bs-target="#modalEvento" id="btnNuevoEvento">
                                    <i class="bi bi-plus-lg me-1"></i>Nuevo evento
                                </button>
                            </div>
                            <% } %>
                    </div>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Las ventas asociadas a eventos están <strong>separadas</strong> de la estadística de ventas general diaria/mensual (mostrador). Crea eventos y, al facturar, asocia la venta a
                        un evento si corresponde.</p>

                    <%- include('_table', { eventos: eventos }) %>
                </div>
            </div>
        </div>

        <%- include('_modal_form') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script src="/js/modulos/eventos.js"></script>
</body>

</html>
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Historial de Ventas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/ventas.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null }) %>

        <div class="container">
            <!-- Mesas Listas para Pagar -->
            <% if (typeof mesasListas !=='undefined' && mesasListas.length> 0) { %>
                <div class="card mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-cash-coin me-2"></i>Mesas Listas para Pagar</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <% mesasListas.forEach(function(mesa) { %>
                                <div class="col-md-4 col-lg-3">
                                    <div class="card border-success">
                                        <div class="card-body text-center">
                                            <h5 class="card-title">Mesa <%= mesa.mesa_numero %>
                                            </h5>
                                            <p class="card-text">
                                                <strong>Pedido #<%= mesa.pedido_id %></strong><br>
                                                <span class="text-muted">Total: $<%= (Number(mesa.pedido_total) ||
                                                        0).toLocaleString('es-CO', { minimumFractionDigits: 2,
                                                        maximumFractionDigits: 2 }) %></span>
                                            </p>
                                            <button class="btn btn-success btn-sm"
                                                onclick="window.location.href='/mesas?pedido=<%= mesa.pedido_id %>'">
                                                <i class="bi bi-cash-stack"></i> Facturar
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                    </div>
                </div>
                <% } %>

                    <!-- Historial de Ventas -->
                    <div class="card">
                        <div class="card-header">
                            <div class="d-flex flex-column gap-3 w-100">
                                <% if (typeof eventoFiltro !=='undefined' && eventoFiltro) { %>
                                    <div
                                        class="alert alert-info py-2 mb-0 d-flex align-items-center justify-content-between flex-wrap gap-2">
                                        <span><i class="bi bi-calendar-event me-2"></i>Ventas del evento: <strong>
                                                <%= eventoFiltro.nombre %>
                                            </strong></span>
                                        <a href="/ventas" class="btn btn-sm btn-outline-primary">Ver todas las
                                            ventas</a>
                                    </div>
                                    <% } %>
                                        <div
                                            class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-3">
                                            <div class="fw-semibold"><i class="bi bi-graph-up me-2"></i>Historial de
                                                Ventas</div>
                                            <div class="d-flex flex-wrap gap-2">
                                                <button class="btn btn-primary" id="filtrarVentas"><i
                                                        class="bi bi-funnel"></i> Filtrar</button>
                                                <button class="btn btn-outline-secondary" id="limpiarFiltrosVentas"
                                                    title="Quitar filtros y volver a cargar"><i
                                                        class="bi bi-x-circle"></i> Limpiar filtros</button>
                                                <% if (typeof allowedByPlan !=='undefined' && allowedByPlan &&
                                                    allowedByPlan.plantillas && user && user.permisos &&
                                                    user.permisos.includes('plantillas.ver')) { %>
                                                    <button class="btn btn-success" id="exportarVentas"><i
                                                            class="bi bi-file-earmark-excel"></i> Exportar</button>
                                                    <% } %>
                                            </div>
                                        </div>
                                        <div class="row g-2 align-items-center">
                                            <div class="col-12 col-md-3">
                                                <div class="input-group">
                                                    <span class="input-group-text"><i
                                                            class="bi bi-calendar3"></i></span>
                                                    <input type="date" id="fechaDesde" class="form-control"
                                                        placeholder="Desde">
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-3">
                                                <div class="input-group">
                                                    <span class="input-group-text"><i
                                                            class="bi bi-calendar3"></i></span>
                                                    <input type="date" id="fechaHasta" class="form-control"
                                                        placeholder="Hasta">
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-3">
                                                <div class="input-group">
                                                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                                                    <input type="text" id="buscarVentas" class="form-control"
                                                        placeholder="Buscar por cliente o # factura">
                                                </div>
                                            </div>
                                        </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <%- include('_table', { ventas: ventas }) %>

                                <%- include('_totales', { totalEfectivo: totalEfectivo, totalTransferencia:
                                    totalTransferencia, totalGeneral: totalGeneral }) %>
                        </div>
                    </div>
        </div>

        <%- include('_modales') %>

            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <%- include('_scripts') %>
</body>

</html>
<% if (typeof nav !=='undefined' && nav.primaryColor) { %>
    <style>
        :root {
            --n-primary: <%=nav.primaryColor %>;
            --bs-primary: <%=nav.primaryColor %>;
            --n-primary-dark: <%=nav.primaryColor %>;
            --n-bg-start: <%=nav.bgStart %>;
            --n-bg-end: <%=nav.bgEnd %>;
            --n-text-color: <%=nav.textColor || '#ffffff' %>;
        }

        .navbar {
            background: linear-gradient(135deg, var(--n-bg-start) 0%, var(--n-bg-end) 100%) !important;
        }

        .navbar .nav-link,
        .navbar .navbar-brand,
        .navbar .n-plan,
        .navbar .n-user {
            color: var(--n-text-color) !important;
        }

        .navbar .nav-link:hover {
            color: var(--n-text-color) !important;
            opacity: 0.8;
        }

        .btn-primary {
            background-color: var(--bs-primary) !important;
            border-color: var(--bs-primary) !important;
        }

        .btn-outline-primary {
            color: var(--bs-primary) !important;
            border-color: var(--bs-primary) !important;
        }

        .btn-outline-primary:hover {
            background-color: var(--bs-primary) !important;
            color: #fff !important;
        }

        .text-primary {
            color: var(--bs-primary) !important;
        }

        .bg-primary {
            background-color: var(--bs-primary) !important;
        }

        <% if (typeof tenant !=='undefined' && tenant && tenant.config && tenant.config.colores) {
            %><% if (tenant.config.colores.secondary) {
                %>.btn-secondary {
                    background-color: <%=tenant.config.colores.secondary %> !important;
                    border-color: <%=tenant.config.colores.secondary %> !important;
                }

                <%
            }

            %><% if (tenant.config.colores.mesaLibre) {
                %>.mesa-card.libre {
                    border-top-color: <%=tenant.config.colores.mesaLibre %> !important;
                }

                .pill-libre {
                    background-color: <%=tenant.config.colores.mesaLibre %>33 !important;
                    color: <%=tenant.config.colores.mesaLibre %> !important;
                }

                .mesa-estado-pill.pill-libre i {
                    color: <%=tenant.config.colores.mesaLibre %> !important;
                }

                .mesa-card.libre .btnAbrirPedido {
                    background-color: <%=tenant.config.colores.mesaLibre %> !important;
                    border-color: <%=tenant.config.colores.mesaLibre %> !important;
                    color: #fff !important;
                }

                <%
            }

            %><% if (tenant.config.colores.mesaOcupada) {
                %>.mesa-card.ocupada {
                    border-top-color: <%=tenant.config.colores.mesaOcupada %> !important;
                }

                .pill-ocupada {
                    background-color: <%=tenant.config.colores.mesaOcupada %>33 !important;
                    color: <%=tenant.config.colores.mesaOcupada %> !important;
                }

                .mesa-estado-pill.pill-ocupada i {
                    color: <%=tenant.config.colores.mesaOcupada %> !important;
                }

                .mesa-card.ocupada .btnAbrirPedido {
                    background-color: <%=tenant.config.colores.mesaOcupada %> !important;
                    border-color: <%=tenant.config.colores.mesaOcupada %> !important;
                    color: #fff !important;
                }

                <%
            }

            %><%
        }

        %><% if (typeof nav !=='undefined') {
            %><% if (nav.cardPrimary) {
                %>.stat-card.c-primary {
                    background: <%=nav.cardPrimary %> !important;
                }

                <%
            }

            %><% if (nav.cardSecondary) {
                %>.stat-card.c-teal {
                    background: <%=nav.cardSecondary %> !important;
                }

                <%
            }

            %><%
        }

        %>
    </style>
    <% } %>
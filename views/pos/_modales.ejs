<!-- Modal Nuevo Cliente -->
<div class="modal fade" id="nuevoClienteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus-fill me-2"></i>
                    Nuevo Cliente
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formNuevoCliente">
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="nombreCliente" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dirección</label>
                        <input type="text" class="form-control" id="direccionNuevoCliente">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="text" class="form-control" id="telefonoNuevoCliente">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="guardarCliente">
                    <i class="bi bi-save me-1"></i>
                    Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Pedidos Guardados -->
<div class="modal fade" id="pedidosModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Pedidos Guardados</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Productos</th>
                                <th>Total</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="pedidosGuardados">
                            <!-- Los pedidos se cargarán aquí dinámicamente -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Aplicar descuento (por línea de producto) -->
<div class="modal fade" id="descuentoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-percent me-2"></i>Aplicar descuento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                    aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <h6 id="descuentoModalProducto" class="fw-bold mb-1">Producto</h6>
                    <p class="text-muted small">Precio actual: $<span id="descuentoModalPrecioActual">0</span></p>
                </div>

                <!-- Tabs para elegir tipo de descuento -->
                <ul class="nav nav-pills nav-fill mb-3" id="descuentoTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="pct-tab" data-bs-toggle="pill" data-bs-target="#pct-panel"
                            type="button" role="tab"><i class="bi bi-percent me-1"></i>Porcentaje</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="fixed-tab" data-bs-toggle="pill" data-bs-target="#fixed-panel"
                            type="button" role="tab"><i class="bi bi-currency-dollar me-1"></i>Monto Fijo</button>
                    </li>
                </ul>

                <div class="tab-content" id="descuentoTabsContent">
                    <!-- Panel Porcentaje -->
                    <div class="tab-pane fade show active" id="pct-panel" role="tabpanel">
                        <p class="small text-muted mb-3 text-center">Seleccione un porcentaje rápido:</p>
                        <div class="d-flex flex-wrap gap-2 justify-content-center mb-4">
                            <button type="button" class="btn btn-outline-primary btn-descuento-quick"
                                data-pct="5">5%</button>
                            <button type="button" class="btn btn-outline-primary btn-descuento-quick"
                                data-pct="10">10%</button>
                            <button type="button" class="btn btn-outline-primary btn-descuento-quick"
                                data-pct="15">15%</button>
                            <button type="button" class="btn btn-outline-primary btn-descuento-quick"
                                data-pct="20">20%</button>
                            <button type="button" class="btn btn-outline-primary btn-descuento-quick"
                                data-pct="50">50%</button>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-pencil"></i></span>
                            <input type="number" id="descuentoPorcentajeManual" class="form-control"
                                placeholder="Otro porcentaje %" min="0" max="100">
                            <button class="btn btn-primary" type="button" id="btnAplicarPctManual">Aplicar</button>
                        </div>
                    </div>

                    <!-- Panel Precio Fijo -->
                    <div class="tab-pane fade" id="fixed-panel" role="tabpanel">
                        <p class="small text-muted mb-3 text-center">Modifique el precio unitario directamente:</p>
                        <div class="input-group input-group-lg mb-2">
                            <span class="input-group-text">$</span>
                            <input type="number" id="nuevoPrecioManual" class="form-control"
                                placeholder="Ingrese el nuevo precio unitario" min="0">
                        </div>
                        <p class="small text-center text-info"><i class="bi bi-info-circle me-1"></i>Esto solo afectará
                            a
                            este producto en esta venta actual.</p>
                        <button class="btn btn-primary w-100 mt-2" type="button" id="btnAplicarPrecioFijo">Establecer
                            nuevo precio</button>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top text-center">
                    <button type="button" class="btn btn-sm btn-outline-danger" id="quitarDescuentoBtn">
                        <i class="bi bi-x-circle me-1"></i>Quitar descuento y restaurar precio original
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para mostrar factura: en móvil fullscreen y altura controlada para poder cerrar -->
<div class="modal fade" id="facturaModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-fullscreen-md-down">
        <div class="modal-content d-flex flex-column h-100">
            <div class="modal-header py-2 flex-shrink-0">
                <h5 class="modal-title">Factura</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-0 flex-grow-1 overflow-auto" style="min-height: 0;">
                <iframe id="facturaFrame" class="factura-iframe-mobile"
                    style="width: 100%; height: 80vh; border: none;"></iframe>
            </div>
            <div class="modal-footer flex-shrink-0 py-2">
                <button type="button" class="btn btn-primary btn-sm"
                    onclick="document.getElementById('facturaFrame').contentWindow.print()">
                    <i class="bi bi-printer"></i> Imprimir
                </button>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
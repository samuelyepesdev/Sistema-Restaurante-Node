<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Facturación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css"
        rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/index.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null }) %>

        <input type="hidden" id="eventoId"
            value="<%= typeof eventoFiltro !== 'undefined' && eventoFiltro && eventoFiltro.id ? eventoFiltro.id : '' %>">
        <% if (typeof eventoFiltro !=='undefined' && eventoFiltro) { %>
            <div class="container mt-3">
                <div class="alert alert-info d-flex align-items-center justify-content-between flex-wrap gap-2 mb-0">
                    <span><i class="bi bi-calendar-event me-2"></i><strong>Venta para evento:</strong>
                        <%= eventoFiltro.nombre %>
                    </span>
                    <a href="/facturas/facturar" class="btn btn-sm btn-outline-primary">Quitar evento</a>
                </div>
            </div>
            <% } %>
                <div class="container mt-4">
                    <!-- Indicador de Pasos -->
                    <div class="step-indicator">
                        <div class="step active" id="step1">
                            <div class="step-number">1</div>
                            <div class="step-label">Cliente</div>
                        </div>
                        <div class="step" id="step2">
                            <div class="step-number">2</div>
                            <div class="step-label">Productos</div>
                        </div>
                        <div class="step" id="step3">
                            <div class="step-number">3</div>
                            <div class="step-label">Pago</div>
                        </div>
                        <div class="step" id="step4">
                            <div class="step-number">4</div>
                            <div class="step-label">Facturar</div>
                        </div>
                    </div>

                    <!-- Información del Cliente -->
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-person-fill"></i>
                            Paso 1: Seleccionar Cliente
                            <span class="shortcut-hint">(Ctrl+F o .)</span>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="search-container">
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text">
                                                <i class="bi bi-search"></i>
                                            </span>
                                            <input type="text" id="cliente" class="form-control"
                                                placeholder="Buscar cliente por nombre o teléfono...">
                                            <input type="hidden" id="cliente_id">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <button class="btn btn-outline-primary w-100 h-100" data-bs-toggle="modal"
                                        data-bs-target="#nuevoClienteModal">
                                        <i class="bi bi-person-plus"></i> Nuevo Cliente
                                    </button>
                                </div>
                            </div>
                            <div id="infoCliente" class="info-cliente-card" style="display: none;">
                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <i class="bi bi-geo-alt-fill text-primary"></i>
                                        <strong>Dirección:</strong>
                                        <span id="direccionCliente" class="ms-2"></span>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <i class="bi bi-telephone-fill text-primary"></i>
                                        <strong>Teléfono:</strong>
                                        <span id="telefonoCliente" class="ms-2"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Productos -->
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-cart-fill"></i>
                            Paso 2: Agregar Productos
                            <span class="shortcut-hint">(Ctrl+B o /)</span>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-12">
                                    <label class="form-label small text-muted mb-1">Buscar producto — escriba y
                                        seleccione para agregar a la venta</label>
                                    <div class="search-container position-relative">
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                                            <input type="text" id="producto" class="form-control"
                                                placeholder="Buscar por nombre o código..." autocomplete="off">
                                            <input type="hidden" id="producto_id">
                                        </div>
                                        <div id="resultadosProductos" class="search-results" style="display: none;">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div id="productosContainer">
                                <!-- Vista móvil: lista en tarjetas (nombre, cantidad +/- pequeños, unitario/subtotal, eliminar) -->
                                <div id="productosListaMobile" class="d-block d-md-none productos-mobile-list"></div>
                                <!-- Vista escritorio: tabla -->
                                <div class="table-responsive d-none d-md-block">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Producto</th>
                                                <th class="text-center">Cantidad</th>
                                                <th>Unidad</th>
                                                <th class="text-end">Precio Unit.</th>
                                                <th class="text-end">Subtotal</th>
                                                <th class="text-center">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody id="productosTabla">
                                            <tr>
                                                <td colspan="6" class="empty-state">
                                                    <i class="bi bi-cart-x"></i>
                                                    <div>No hay productos agregados</div>
                                                    <small class="text-muted">Busca y agrega productos usando el
                                                        formulario de arriba</small>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Forma de Pago -->
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-credit-card-fill"></i>
                            Paso 3: Forma de Pago
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <label class="form-label">Seleccione la forma de pago</label>
                                    <select id="formaPago" class="form-control form-control-lg">
                                        <option value="efectivo">💵 Efectivo</option>
                                        <option value="transferencia">💳 Transferencia</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer fijo con acciones -->
                <div class="footer-actions d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <span class="footer-total-label">Total:</span>
                        <span class="footer-total">$<span id="totalFactura">0.00</span></span>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <button type="button" class="btn btn-outline-secondary" id="nuevaVenta"
                            title="Limpiar y empezar nueva venta">
                            <i class="bi bi-plus-circle"></i> Nueva venta
                        </button>
                        <button class="btn btn-outline-secondary" id="verPedidos" data-bs-toggle="tooltip"
                            title="Ver Pedidos Guardados">
                            <i class="bi bi-list-check"></i> Pedidos
                        </button>
                        <button class="btn btn-outline-primary" id="guardarPedido" data-bs-toggle="tooltip"
                            title="Guardar Pedido (Ctrl+S)">
                            <i class="bi bi-save"></i> Guardar
                        </button>
                        <button class="btn btn-success btn-lg" id="generarFactura" data-bs-toggle="tooltip"
                            title="Generar Factura (Ctrl+G)">
                            <i class="bi bi-receipt"></i> Generar Factura
                        </button>
                    </div>
                </div>



                <%- include('_modales') %>

                    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
                    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
                    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
                    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/animate.css@4.1.1/animate.min.css">
                    <script src="/js/factura.js?v=2"></script>
</body>

</html>
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mesas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/modulos/mesas.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null }) %>

        <div class="container">
            <div
                class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-3 mb-3">
                <h4 class="mb-0 fw-semibold"><i class="bi bi-grid me-2"></i>Mesas</h4>
                <div class="d-flex flex-column flex-sm-row gap-2">
                    <% if (user.rol !=='mesero' && user.rol !=='cajero' ) { %>
                        <button id="btnCrearMasivas" class="btn btn-success flex-grow-1">
                            <i class="bi bi-plus-circle me-1"></i>Crear Múltiples Mesas
                        </button>
                        <button id="btnNuevaMesa" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-plus-lg me-1"></i>Nueva Mesa
                        </button>
                        <% } %>
                </div>
            </div>

            <!-- Sección de Mesas Virtuales (WhatsApp / Domicilios) -->
            <% if (typeof mesasVirtuales !=='undefined' && mesasVirtuales.length> 0) { %>
                <div class="mb-5">
                    <h5 class="mb-3 text-primary fw-bold"><i class="bi bi-whatsapp me-2"></i>Pedidos WhatsApp /
                        Domicilios</h5>
                    <%- include('_grid', { mesas: mesasVirtuales }) %>
                        <hr class="my-4">
                </div>
                <% } %>

                    <h5 class="mb-3 fw-bold text-secondary">Atención en Salón</h5>
                    <%- include('_grid', { mesas: mesas }) %>
        </div>

        <%- include('_modales') %>

            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            
            <!-- Core Modules -->
            <script src="/js/core/modules/Utils.js"></script>
            <script src="/js/core/modules/AlertManager.js"></script>
            
            <script src="/js/modulos/mesas.js?v=2"></script>
            <%- include('_scripts') %>
</body>

</html>
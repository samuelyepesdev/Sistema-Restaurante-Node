<div class="row" id="gridMesas">
    <% mesas.forEach(m=> { %>
        <div class="col-6 col-sm-6 col-md-4 col-lg-3 mb-3 px-1">
            <div class="card mesa-card <%= m.estado %>" data-mesa-id="<%= m.id %>" data-mesa-estado="<%= m.estado %>">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="mesa-num">Mesa <span class="text-primary">
                                <%= m.numero %>
                            </span></div>
                        <span class="mesa-estado-pill pill-<%= m.estado %>">
                            <% if (m.estado==='libre' ) { %><i class="bi bi-circle-fill"
                                    style="font-size:.5rem;"></i>Libre
                                <% } else if (m.estado==='ocupada' ) { %><i class="bi bi-circle-fill"
                                        style="font-size:.5rem;"></i>Ocupada
                                    <% } else { %><i class="bi bi-circle-fill" style="font-size:.5rem;"></i>Reservada<%
                                            } %>
                        </span>
                    </div>
                    <div class="mesa-desc mb-3">
                        <%= m.descripcion || '' %>
                    </div>
                    <div class="d-grid gap-2">
                        <% if (m.estado==='libre' ) { %>
                            <button class="btn btn-success btn-cta btnAbrirPedido">
                                <i class="bi bi-plus-circle me-1"></i>Abrir pedido
                            </button>
                            <% } else { %>
                                <button class="btn btn-warning btn-cta btnAbrirPedido">
                                    <i class="bi bi-pencil-square me-1"></i>Editar pedido
                                </button>
                                <% } %>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-outline-secondary btn-sec flex-fill btnVerPedido"
                                            title="Ver pedido">
                                            <i class="bi bi-list-ul me-1"></i>Ver
                                        </button>
                                        <% if (m.estado !=='libre' ) { %>
                                            <button class="btn btn-outline-secondary btn-sec flex-fill btnLiberarMesa"
                                                title="Liberar mesa">
                                                <i class="bi bi-unlock me-1"></i>Liberar
                                            </button>
                                            <% } %>
                                                <% if (user && user.permisos && user.permisos.includes('mesas.editar'))
                                                    { %>
                                                    <button class="btn btn-outline-secondary btn-sec btnEditarMesa"
                                                        data-mesa-numero="<%= m.numero %>"
                                                        data-mesa-descripcion="<%= (m.descripcion || '') %>"
                                                        title="Editar mesa">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <% } %>
                                    </div>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
</div>
<!-- Offcanvas Factura -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="canvasFactura" style="width: 650px; max-width: 90vw;">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title">
            <i class="bi bi-receipt-cutoff me-2"></i>Factura <span id="facturaNumero"></span>
        </h5>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-sm btn-outline-light" id="btnImprimirFactura" title="Imprimir factura">
                <i class="bi bi-printer me-1"></i>Imprimir
            </button>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
    </div>
    <div class="offcanvas-body p-0 position-relative">
        <div id="facturaLoading" class="d-flex align-items-center justify-content-center"
            style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.9); z-index: 10;">
            <div class="text-center">
                <div class="spinner-border text-primary mb-2" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <div>Cargando factura...</div>
            </div>
        </div>
        <iframe id="facturaFrame" style="width: 100%; height: 100%; border: none; min-height: 600px;"></iframe>
    </div>
</div>

<!-- Offcanvas Pedido -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="canvasPedido" style="width: 420px">
    <div class="offcanvas-header py-3 px-3 border-bottom bg-light">
        <h5 class="offcanvas-title fw-bold text-primary"><i class="bi bi-receipt-cutoff me-2"></i>Mesa <span id="pedidoMesa"></span></h5>
        <div class="d-flex align-items-center gap-2">
            <button type="button" id="btnMoverMesaHeader" class="btn btn-outline-secondary btn-sm"
                data-bs-toggle="tooltip" title="Mover a otra mesa">
                <i class="bi bi-arrow-left-right"></i>
            </button>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
    </div>
    <div class="offcanvas-body d-flex flex-column pt-3">
        <!-- Fila Superior: Buscador de Producto y Cliente Compacto -->
        <div class="row g-2 mb-2">
            <div class="col-7 col-sm-8 position-relative">
                <div class="input-group input-group-sm mb-0 shadow-sm border rounded-pill overflow-hidden">
                    <span class="input-group-text bg-white border-0 ps-2"><i
                            class="bi bi-search text-primary"></i></span>
                    <input id="buscarProductoMesa" class="form-control border-0 py-2" placeholder="Producto...">
                </div>
                <div id="resultadosProductoMesa" class="list-group search-results-premium" style="display: none;"></div>
            </div>
            <div class="col-5 col-sm-4">
                <button
                    class="btn btn-sm btn-outline-primary rounded-pill w-100 h-100 d-flex align-items-center justify-content-center py-2"
                    id="btnBuscarClienteMesa" title="Cambiar cliente">
                    <i class="bi bi-person-fill me-1"></i>
                    <span class="text-truncate" style="max-width: 50px;" id="btnClienteTexto">Final</span>
                </button>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-2 px-1">
            <div class="small text-muted fw-semibold">
                <span id="labelClienteActual" class="badge bg-light text-dark border-0">Cliente: Consumidor Final</span>
            </div>
            <button id="btnLiberarMesaHeader" class="btn btn-link btn-sm text-danger text-decoration-none p-0 fw-bold">
                <i class="bi bi-unlock me-1"></i>Liberar
            </button>
        </div>

        <div class="table-responsive flex-grow-1 border-top">
            <table class="table table-sm table-pedido-mesas align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Producto</th>
                        <th class="text-center">Cant</th>
                        <th class="text-end d-none d-sm-table-cell">P. unit.</th>
                        <th class="text-end">Subtotal</th>
                        <th class="text-center" style="width: 80px;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="tbodyItems"></tbody>
            </table>
        </div>
        <div class="mt-auto">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <strong>Total:</strong>
                <span id="totalPedido" class="fw-bold">$0</span>
            </div>
            <div id="propinaLinea"
                class="d-flex justify-content-between align-items-center mb-2 small text-muted d-none">
                <span>Propina:</span>
                <span id="propinaMonto">$0</span>
            </div>
            <div class="row g-2 mb-2">
                <div class="col-6 col-sm-3">
                    <button type="button" id="btnAplicarDescuentoMesa" class="btn btn-sm btn-outline-primary w-100" title="Descuento">
                        <i class="bi bi-percent"></i> <span class="d-none d-sm-inline">Desc.</span>
                    </button>
                </div>
                <div class="col-6 col-sm-3">
                    <button type="button" id="btnPropinaMesa" class="btn btn-sm btn-outline-success w-100" title="Propina">
                        <i class="bi bi-cash-stack"></i> <span class="d-none d-sm-inline">Propina</span>
                    </button>
                </div>
                <div class="col-6 col-sm-3">
                    <button type="button" id="btnAgregarServicioMesa" class="btn btn-sm btn-outline-info w-100" title="Servicio">
                        <i class="bi bi-truck"></i> <span class="d-none d-sm-inline">Serv.</span>
                    </button>
                </div>
                <div class="col-6 col-sm-3">
                    <button id="btnMoverMesa" class="btn btn-sm btn-outline-secondary w-100" title="Mover">
                        <i class="bi bi-arrow-left-right"></i> <span class="d-none d-sm-inline">Mover</span>
                    </button>
                </div>
            </div>
            <div class="d-grid gap-2">
                <button id="btnEnviarCocina" class="btn btn-warning py-2 fw-bold"><i class="bi bi-send me-1"></i>Enviar a Cocina</button>
                <button id="btnFacturarPedido" class="btn btn-success py-2 fw-bold"><i class="bi bi-cash-coin me-1"></i>Facturar</button>
            </div>
        </div>
    </div>
</div>

<!-- Panel de Favoritos Lateral (Aparece junto al offcanvas en Tablet/PC) -->
<div id="sidePanelFavoritos" class="d-none d-md-block shadow-lg">
    <div class="p-3">
        <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
            <h6 class="fw-bold mb-0 text-white">
                <i class="bi bi-star-fill me-2 text-warning"></i>Favoritos
            </h6>
            <select id="filtroCategoriaFav" class="form-select form-select-sm border-0 bg-white"
                style="width: auto; font-size: 0.75rem; border-radius: 8px;">
                <option value="todos">Todos</option>
                <% (typeof categorias !=='undefined' ? categorias : []).forEach(cat=> { %>
                    <option value="<%= cat.id %>">
                        <%= cat.nombre %>
                    </option>
                    <% }) %>
            </select>
        </div>
        <div id="gridFavoritos" class="row g-2 overflow-auto"
            style="max-height: calc(100vh - 120px); align-content: flex-start;">
            <% (typeof productos !=='undefined' ? productos : []).filter(p=> p.es_favorito).forEach(p => { %>
                <div class="col-6 col-lg-4 col-xl-3 mb-2">
                    <div class="card p-2 text-center producto-fav-card shadow-sm border-0 h-100" data-id="<%= p.id %>"
                        data-nombre="<%= p.nombre %>" data-precio="<%= p.precio_unidad %>"
                        data-categoria="<%= p.categoria_id %>" data-categoria-nombre="<%= p.categoria_nombre %>">
                        <div class="producto-fav-initials">
                            <%= p.nombre.substring(0,2).toUpperCase() %>
                        </div>
                        <div class="small fw-bold text-truncate w-100 mt-1" style="font-size: 0.7rem;">
                            <%= p.nombre %>
                        </div>
                        <div class="badge bg-primary-subtle text-primary border-0 mt-1" style="font-size: 0.65rem;">$<%=
                                Number(p.precio_unidad).toLocaleString('es-CO') %>
                        </div>
                    </div>
                </div>
                <% }) %>
                    <% if ((typeof productos !=='undefined' ? productos : []).filter(p=> p.es_favorito).length === 0) {
                        %>
                        <div class="col-12 text-center text-white-50 py-5">
                            <i class="bi bi-star d-block fs-1 mb-2"></i>
                            <p class="small">Marca productos como favoritos en el menú de productos para que aparezcan
                                aquí.</p>
                        </div>
                        <% } %>
        </div>
    </div>
</div>
</div>
</div>

<!-- Modal Aplicar descuento: paso 1 = elegir producto, paso 2 = elegir % (solo esta venta en mesas) -->
<div class="modal fade" id="descuentoModalMesa" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="descuentoModalMesaTitulo"><i class="bi bi-percent me-2"></i>Aplicar
                    descuento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <!-- Paso 1: Seleccionar producto -->
                <div id="descuentoMesaPaso1">
                    <p class="mb-3">Seleccione el producto al cual desea aplicar el descuento en esta venta:</p>
                    <div id="descuentoMesaListaProductos" class="list-group list-group-flush"
                        style="max-height: 280px; overflow-y: auto;"></div>
                </div>
                <!-- Paso 2: Elegir porcentaje -->
                <div id="descuentoMesaPaso2" style="display: none;">
                    <p class="text-muted small mb-2" id="descuentoModalProductoMesa">Producto</p>
                    <p class="small text-info mb-3"><i class="bi bi-info-circle me-1"></i>El descuento es solo
                        para esta venta.</p>
                    <p class="mb-3">Elija el porcentaje de descuento:</p>
                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                        <button type="button" class="btn btn-outline-primary btn-descuento-mesa"
                            data-pct="5">5%</button>
                        <button type="button" class="btn btn-outline-primary btn-descuento-mesa"
                            data-pct="10">10%</button>
                        <button type="button" class="btn btn-outline-primary btn-descuento-mesa"
                            data-pct="15">15%</button>
                        <button type="button" class="btn btn-outline-primary btn-descuento-mesa"
                            data-pct="20">20%</button>
                        <button type="button" class="btn btn-outline-primary btn-descuento-mesa"
                            data-pct="30">30%</button>
                    </div>
                    <div class="mt-3 text-center">
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                            id="quitarDescuentoMesaBtn">Quitar descuento</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Propina -->
<div class="modal fade" id="propinaModalMesa" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-cash-stack me-2"></i>Propina</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="small text-muted mb-2">Monto que deja el cliente como propina (se suma al total):</p>
                <div class="mb-3">
                    <label class="form-label">Monto ($)</label>
                    <input type="number" id="propinaInputMesa" class="form-control" min="0" step="100" placeholder="0"
                        value="0">
                </div>
                <div class="d-flex flex-wrap gap-2 justify-content-center mb-2">
                    <button type="button" class="btn btn-outline-secondary btn-propina-rapida"
                        data-val="1000">$1.000</button>
                    <button type="button" class="btn btn-outline-secondary btn-propina-rapida"
                        data-val="2000">$2.000</button>
                    <button type="button" class="btn btn-outline-secondary btn-propina-rapida"
                        data-val="5000">$5.000</button>
                    <button type="button" class="btn btn-outline-secondary btn-propina-rapida"
                        data-val="10000">$10.000</button>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary flex-grow-1" id="quitarPropinaMesaBtn">Quitar
                        propina</button>
                    <button type="button" class="btn btn-success flex-grow-1"
                        id="aplicarPropinaMesaBtn">Aplicar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Pago para Facturar -->
<div class="modal fade" id="modalPago" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-cash-coin me-2"></i>Seleccionar Forma de Pago
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <h4 class="mb-1">Total a Pagar</h4>
                    <h2 class="text-primary fw-bold" id="modalTotalPago">$0.00</h2>
                </div>

                <div class="row g-3 mb-4">
                    <!-- Card Efectivo -->
                    <div class="col-md-6">
                        <div class="card h-100 border-2 payment-card" data-payment-type="efectivo"
                            style="cursor: pointer; transition: all 0.3s;">
                            <div class="card-body text-center p-4">
                                <i class="bi bi-cash-stack display-4 text-success mb-3"></i>
                                <h5 class="card-title">Efectivo</h5>
                                <p class="text-muted small mb-0">Pago en efectivo</p>
                            </div>
                        </div>
                    </div>

                    <!-- Card Transferencia -->
                    <div class="col-md-6">
                        <div class="card h-100 border-2 payment-card" data-payment-type="transferencia"
                            style="cursor: pointer; transition: all 0.3s;">
                            <div class="card-body text-center p-4">
                                <i class="bi bi-credit-card display-4 text-primary mb-3"></i>
                                <h5 class="card-title">Transferencia</h5>
                                <p class="text-muted small mb-0">Pago por transferencia</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Panel de Efectivo (oculto inicialmente) -->
                <div id="panelEfectivo" style="display: none;">
                    <h6 class="mb-3"><i class="bi bi-cash-stack me-2"></i>Seleccione Denominación o Ingrese
                        Monto</h6>

                    <!-- Denominaciones -->
                    <div id="denominacionesContainer" class="row g-2 mb-3">
                        <!-- Se llenar dinámicamente -->
                    </div>

                    <!-- Campo manual -->
                    <div class="input-group input-group-lg">
                        <span class="input-group-text">
                            <i class="bi bi-keyboard"></i>
                        </span>
                        <input type="number" id="montoManual" class="form-control"
                            placeholder="Ingrese el monto recibido..." step="100" min="0">
                        <button class="btn btn-success" id="btnUsarMontoManual">
                            <i class="bi bi-check-lg"></i> Usar
                        </button>
                    </div>

                    <!-- Información de cambio -->
                    <div id="infoCambio" class="alert alert-info mt-3" style="display: none;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Cambio:</strong>
                                <span id="montoCambio" class="fs-4 ms-2">$0.00</span>
                            </div>
                            <div>
                                <strong>Recibido:</strong>
                                <span id="montoRecibido" class="ms-2">$0.00</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Panel de Transferencia (oculto inicialmente) -->
                <div id="panelTransferencia" style="display: none;">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        Se generará la factura con forma de pago: <strong>Transferencia</strong>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnConfirmarPago" disabled>
                    <i class="bi bi-check-lg me-2"></i>Confirmar Pago
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Seleccionar Servicio -->
<div class="modal fade" id="modalServiciosMesa" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-0 py-3">
                <h6 class="modal-title fw-bold"><i class="bi bi-truck me-2"></i>Servicios Disponibles</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div id="listaServiciosDisponibles" class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                    <div class="text-center py-4 text-muted">
                        <div class="spinner-border spinner-border-sm text-primary mb-2"></div>
                        <br><small>Cargando servicios...</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Buscar Cliente Mesa -->
<div class="modal fade" id="modalBuscarClienteMesa" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-0 py-3">
                <h6 class="modal-title fw-bold"><i class="bi bi-person-search me-2"></i>Seleccionar Cliente</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="position-relative mb-4">
                    <div class="input-group shadow-sm border rounded-pill overflow-hidden">
                        <span class="input-group-text bg-white border-0 ps-3"><i class="bi bi-search"></i></span>
                        <input id="buscarClienteInputMesa" class="form-control border-0 py-2"
                            placeholder="Nombre, NIT o documento...">
                    </div>
                </div>
                <div id="resultadosClienteMesa" class="list-group list-group-flush"
                    style="max-height: 300px; overflow-y: auto;">
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-keyboard fs-1 d-block mb-2"></i>
                        <small>Escriba al menos 2 caracteres para buscar</small>
                    </div>
                </div>
                <div id="loadingClienteMesa" class="text-center py-4 d-none">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light py-2">
                <button type="button" class="btn btn-sm btn-primary rounded-pill px-4"
                    id="btnResetClienteDefault">Consumidor Final</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Ajustes específicos para que no se sienta cargado */
    .offcanvas-body {
        scrollbar-width: thin;
    }

    .table-pedido-mesas thead th {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: #64748b;
        font-weight: 700;
        background: #f8fafc !important;
        border-bottom: 2px solid #e2e8f0;
        padding: 0.75rem 0.5rem !important;
    }

    .td-producto {
        font-weight: 600;
        color: #1e293b;
        font-size: 0.85rem;
    }

    .td-subtotal {
        color: #0f172a;
        font-size: 0.85rem;
    }

    #totalPedido {
        font-size: 1.25rem;
        color: #0d6efd;
    }

    /* Panel de Favoritos Lateral */
    #sidePanelFavoritos {
        position: fixed;
        top: 0;
        right: 420px;
        /* Ancho del offcanvas de pedido */
        width: calc(100vw - 420px);
        height: 100vh;
        background: rgba(33, 37, 41, 0.95);
        backdrop-filter: blur(10px);
        z-index: 1050;
        /* Un poco por debajo del offcanvas pero sobre casi todo */
        transition: all 0.3s ease-in-out;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        border-right: 1px solid rgba(255, 255, 255, 0.1);
    }

    body.offcanvas-open #sidePanelFavoritos {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }

    .bg-white-opacity {
        background: rgba(255, 255, 255, 0.1) !important;
        color: white !important;
    }

    .bg-white-opacity option {
        background: white;
        color: black;
    }

    .producto-fav-card {
        cursor: pointer;
        transition: all 0.2s;
        border-radius: 12px;
        background: white;
        border: 2px solid transparent !important;
    }

    .producto-fav-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2) !important;
        border-color: #0d6efd !important;
    }

    .producto-fav-initials {
        width: 35px;
        height: 35px;
        background: #f1f5f9;
        color: #64748b;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        font-weight: 800;
        font-size: 0.8rem;
    }

    @media (max-width: 992px) {
        #sidePanelFavoritos {
            right: 400px;
            width: 300px;
            /* Panel más estrecho en tablets */
        }
    }

    /* Scrollbar personalizado */
    #gridFavoritos::-webkit-scrollbar {
        width: 5px;
    }

    #gridFavoritos::-webkit-scrollbar-track {
        background: transparent;
    }

    #gridFavoritos::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
    }
</style>

<!-- Modal para crear múltiples mesas -->
<div class="modal fade" id="modalCrearMasivas" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Crear Múltiples Mesas
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formCrearMasivas">
                    <div class="mb-3">
                        <label for="cantidadMesas" class="form-label">Cantidad de Mesas</label>
                        <input type="number" class="form-control" id="cantidadMesas" min="1" max="100" value="10"
                            required>
                        <small class="text-muted">Se crearán mesas continuamente desde el siguiente número
                            disponible</small>
                    </div>
                    <div class="mb-3">
                        <label for="prefijoMesas" class="form-label">Prefijo (Opcional)</label>
                        <input type="text" class="form-control" id="prefijoMesas" placeholder="Ej: M, Mesa, T">
                        <small class="text-muted">Si se especifica, las mesas continuarán desde el siguiente
                            número con ese prefijo</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnConfirmarCrearMasivas">
                    <i class="bi bi-check-lg me-1"></i>Crear Mesas
                </button>

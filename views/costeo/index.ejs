<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Costeo de Platos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/modulos/costeo.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null }) %>

        <div class="container mt-4">
            <% if (typeof showTenantSelector !=='undefined' && showTenantSelector && tenants && tenants.length) { %>
                <div class="card">
                    <div class="card-header"><i class="bi bi-calculator me-2"></i>Costeo de Platos</div>
                    <div class="card-body">
                        <p class="text-muted">Seleccioná el restaurante para gestionar costeo (insumos, recetas, temas y
                            parámetros).</p>
                        <ul class="list-group list-group-flush">
                            <% tenants.forEach(function(t) { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>
                                        <%= t.nombre %>
                                    </span>
                                    <a href="/costeo?tenant_id=<%= t.id %>" class="btn btn-sm btn-primary">Entrar</a>
                                </li>
                                <% }); %>
                        </ul>
                    </div>
                </div>
                <% } else { %>
                    <div class="card">
                        <div class="card-header">
                            <div
                                class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-2 gap-md-3 w-100">
                                <div class="fw-semibold"><i class="bi bi-calculator me-2"></i>Costeo de Platos<% if
                                        (typeof tenant !=='undefined' && tenant) { %> — <%= tenant.nombre %>
                                            <% } %>
                                </div>
                                <ul class="nav nav-tabs card-header-tabs flex-nowrap overflow-auto" id="costeoTab"
                                    role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link active" id="insumos-tab" data-bs-toggle="tab"
                                            data-bs-target="#insumos" type="button">Insumos</button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="recetas-tab" data-bs-toggle="tab"
                                            data-bs-target="#recetas" type="button">Recetas</button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="alertas-tab" data-bs-toggle="tab"
                                            data-bs-target="#alertas" type="button">Alertas</button>
                                    </li>
                                    <% if (typeof costeoPlantillaReposteria==='undefined' || !costeoPlantillaReposteria)
                                        { %>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link" id="config-tab" data-bs-toggle="tab"
                                                data-bs-target="#config" type="button">Configuración</button>
                                        </li>
                                        <% } %>
                                </ul>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="tab-content" id="costeoTabContent">
                                <!-- Tab Insumos -->
                                <%- include('_tab_insumos') %>

                                    <!-- Tab Recetas -->
                                    <%- include('_tab_recetas') %>

                                        <!-- Tab Alertas -->
                                        <%- include('_tab_alertas') %>

                                            <%- include('_tab_config') %>
                            </div>
                        </div>
                    </div>
                    <% } %>
        </div>

        <%- include('_modales') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                window.USER_PERMISOS = <% - typeof user !== 'undefined' && user && user.permisos ? JSON.stringify(user.permisos) : '[]' %>;
                window.USER_ROL = <% - typeof user !== 'undefined' && user && user.rol ? JSON.stringify(user.rol) : '""' %>;
                window.COSTEO_TENANT_ID = <%= typeof tenant !== 'undefined' && tenant && tenant.id ? tenant.id : 'null' %>;
                window.COSTEO_SHOW_TENANT_SELECTOR = <%= typeof showTenantSelector !== 'undefined' && showTenantSelector ? 'true' : 'false' %>;
                window.COSTEO_PLANTILLA_REPOSTERIA = <%= typeof costeoPlantillaReposteria !== 'undefined' && costeoPlantillaReposteria ? 'true' : 'false' %>;
            </script>
            <script src="/js/costeo.js"></script>
            <% if (typeof costeoPlantillaReposteria !=='undefined' && costeoPlantillaReposteria) { %>
                <script src="/js/costeo-reposteria.js"></script>
                <% } %>
</body>

</html>
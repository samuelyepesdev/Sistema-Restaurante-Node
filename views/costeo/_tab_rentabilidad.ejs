<div class="tab-pane fade" id="rentabilidad" role="tabpanel" aria-labelledby="rentabilidad-tab">
    <div class="d-flex justify-content-between align-items-center mb-3 mt-2">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-bar-chart-line me-2 text-primary"></i>Resumen de Rentabilidad</h6>
        <button class="btn btn-sm btn-outline-primary" id="btnRefreshRentabilidad">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
    </div>

    <div id="rentabilidadLoading" class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted small">Calculando márgenes...</p>
    </div>

    <div id="rentabilidadContent" style="display:none;">
        <!-- KPIs superiores -->
        <div class="row g-3 mb-4" id="rentabilidadKpis"></div>

        <!-- Gráfica de márgenes por producto -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h6 class="fw-semibold mb-3"><i class="bi bi-pie-chart me-2"></i>Margen de contribución por producto</h6>
                <div style="position:relative;height:280px;">
                    <canvas id="chartRentabilidad"></canvas>
                </div>
            </div>
        </div>

        <!-- Tabla detalle productos -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="tablaRentabilidad">
                        <thead class="table-light">
                            <tr>
                                <th>Producto</th>
                                <th class="text-end">Precio venta</th>
                                <th class="text-end">Costo variable</th>
                                <th class="text-end">Margen contrib.</th>
                                <th class="text-center">Margen %</th>
                                <th class="text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyRentabilidad"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div id="rentabilidadEmpty" style="display:none;" class="text-center py-5 text-muted">
        <i class="bi bi-clipboard-x fs-2 d-block mb-2"></i>
        No hay recetas con costeo configurado. Agrega recetas en la pestaña <strong>Recetas</strong>.
    </div>
</div>

<script src="/js/modulos/costeo/costeo_rentabilidad.js"></script>

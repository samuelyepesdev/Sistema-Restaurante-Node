    <!-- Modal Insumo -->
    <div class="modal fade" id="insumoModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="insumoModalTitle">Nuevo Insumo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="insumoId">
                    <div class="mb-2">
                        <label class="form-label">Código</label>
                        <input type="text" class="form-control" id="insumoCodigo" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="insumoNombre" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Presentación</label>
                        <small class="text-muted d-block mb-1">Tamaño en que comprás el producto (ej: aceite 450 ml, arroz 1 kg, huevos 12 unidades)</small>
                        <div class="d-flex gap-2 align-items-center flex-wrap">
                            <input type="number" class="form-control" id="insumoCantidadCompra" step="0.0001" min="0.0001" value="1" placeholder="Ej: 450" style="max-width: 140px;" title="Cantidad según la presentación">
                            <select class="form-select" id="insumoUnidad" style="max-width: 100px;" title="Unidad de la presentación">
                                <option value="UND">UND</option>
                                <option value="kg">kg</option>
                                <option value="g">g</option>
                                <option value="L">L</option>
                                <option value="ml">ml</option>
                                <option value="lb">lb</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Precio de compra</label>
                        <input type="number" class="form-control" id="insumoPrecioCompra" step="0.01" min="0" value="0" title="Precio que pagás por esa presentación">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarInsumo">Guardar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Nueva Receta -->
    <div class="modal fade" id="recetaNuevaModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nueva Receta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Producto</label>
                        <select class="form-select" id="recetaProductoId" required>
                            <option value="">Seleccione producto</option>
                            <% (productos || []).forEach(function(p) { %>
                            <option value="<%= p.id %>"><%= p.codigo %> - <%= p.nombre %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Nombre de la receta</label>
                        <input type="text" class="form-control" id="recetaNombreNueva" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Porciones</label>
                        <input type="number" class="form-control" id="recetaPorcionesNueva" step="0.01" min="0.01" value="1">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnCrearReceta">Crear</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Editar Receta (ingredientes) -->
    <div class="modal fade" id="recetaEditarModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="recetaEditarTitle">Editar Receta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="recetaId">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Nombre receta</label>
                            <input type="text" class="form-control" id="recetaNombre">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Porciones</label>
                            <input type="number" class="form-control" id="recetaPorciones" step="0.01" min="0.01">
                        </div>
                    </div>
                    <h6 class="mt-3">Ingredientes</h6>
                    <div class="table-responsive">
                        <table class="table table-sm ingredientes-table" id="tablaIngredientes">
                            <thead><tr><th>Insumo</th><th>Cantidad</th><th>Unidad</th><th></th></tr></thead>
                            <tbody id="ingredientesBody"></tbody>
                        </table>
                    </div>
                    <div id="ingredienteAgregarEstandar" class="d-flex align-items-center gap-2 mt-2 flex-wrap">
                        <select class="form-select form-select-sm" id="ingredienteInsumo" style="max-width: 220px;" title="Elegí el insumo; la unidad se ajusta: peso → g, líquido → ml, unidad → UND"></select>
                        <input type="number" class="form-control form-control-sm" id="ingredienteCantidad" placeholder="Cantidad" step="0.001" style="max-width: 100px;">
                        <select class="form-select form-select-sm" id="ingredienteUnidad" style="max-width: 90px;" title="Peso en g, líquido en ml, unidades en UND. Se define según el insumo elegido.">
                            <option value="g">g</option>
                            <option value="ml">ml</option>
                            <option value="UND">UND</option>
                        </select>
                        <button type="button" class="btn btn-outline-primary btn-sm" id="btnAgregarIngrediente"><i class="bi bi-plus"></i> Agregar</button>
                    </div>
                    <% if (typeof costeoPlantillaReposteria !== 'undefined' && costeoPlantillaReposteria) { %>
                    <div id="ingredienteAgregarReposteria" class="mt-2 d-none">
                        <div class="small text-muted mb-2">Ingresar en tazas/cucharadas (se convierte a gramos para el costeo)</div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <select class="form-select form-select-sm" id="ingredienteInsumoRep" style="max-width: 220px;"></select>
                            <input type="text" class="form-control form-control-sm" id="ingredienteCantidadRep" placeholder="Ej: 2, 1/2, 1 1/2" style="max-width: 110px;" title="Número o fracción (ej. 1 1/2)">
                            <select class="form-select form-select-sm" id="ingredienteUnidadEntrada" style="max-width: 90px;">
                                <option value="g">g</option>
                                <option value="kg">kg</option>
                                <option value="ml">ml</option>
                                <option value="L">L</option>
                                <option value="cup">taza</option>
                                <option value="tbsp">cda</option>
                                <option value="tsp">cdta</option>
                                <option value="oz">oz</option>
                                <option value="lb">lb</option>
                                <option value="UND">UND</option>
                            </select>
                            <select class="form-select form-select-sm" id="ingredienteTipoRep" style="max-width: 140px;" title="Tipo para convertir taza/cda a gramos">
                                <option value="flour">Harina</option>
                                <option value="sugar">Azúcar</option>
                                <option value="brown-sugar">Azúcar morena</option>
                                <option value="powdered-sugar">Azúcar glass</option>
                                <option value="butter">Mantequilla</option>
                                <option value="milk">Leche</option>
                                <option value="water">Agua</option>
                                <option value="oil">Aceite</option>
                                <option value="cocoa">Cacao</option>
                                <option value="salt">Sal</option>
                                <option value="eggs">Huevos</option>
                                <option value="cream">Crema</option>
                                <option value="honey">Miel</option>
                                <option value="custom-solid">Otro sólido</option>
                                <option value="custom-liquid">Otro líquido</option>
                            </select>
                            <span class="small" id="ingredienteConvertidoRep"></span>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="btnAgregarIngredienteRep"><i class="bi bi-plus"></i> Agregar</button>
                        </div>
                    </div>
                    <% } %>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarReceta">Guardar receta</button>
                </div>
            </div>
        </div>
    </div>

    <% if (typeof costeoPlantillaReposteria !== 'undefined' && costeoPlantillaReposteria) { %>
    <!-- Modal Calculadora de precios - Repostería (pastelería/panadería) -->
    <div class="modal fade" id="modalCalculadoraReposteria" tabindex="-1" aria-labelledby="modalCalculadoraReposteriaLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalCalculadoraReposteriaLabel"><i class="bi bi-calculator me-2"></i>Calculadora de precios</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="calcRecetaId" value="">

                    <!-- Datos básicos -->
                    <div class="calc-seccion">
                        <div class="calc-seccion-titulo"><i class="bi bi-pencil-square"></i> Datos de la receta</div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Producto</label>
                                <select class="form-select" id="calcProductoId">
                                    <option value="">Seleccione producto</option>
                                    <% (productos || []).forEach(function(p) { %>
                                    <option value="<%= p.id %>"><%= p.codigo %> - <%= p.nombre %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Nombre de la receta</label>
                                <input type="text" class="form-control" id="calcNombreReceta" placeholder="Ej: Torta de chocolate">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Porciones</label>
                                <input type="number" class="form-control" id="calcPorciones" step="0.01" min="0.01" value="1">
                            </div>
                        </div>
                    </div>

                    <!-- 1. Ingredientes -->
                    <div class="calc-seccion">
                        <div class="calc-seccion-titulo"><i class="bi bi-list-ul"></i> 1. Ingredientes</div>
                        <div class="table-responsive mb-2">
                            <table class="table table-sm table-hover align-middle" id="calcTablaIngredientes">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ingrediente</th>
                                        <th>Cantidad</th>
                                        <th>Unidad</th>
                                        <th class="text-end">Costo</th>
                                        <th width="40"></th>
                                    </tr>
                                </thead>
                                <tbody id="calcIngredientesBody"></tbody>
                            </table>
                        </div>
                        <div class="d-flex flex-wrap align-items-end gap-2">
                            <select class="form-select form-select-sm" id="calcInsumo" style="max-width: 220px;"></select>
                            <input type="text" class="form-control form-control-sm" id="calcCantidad" placeholder="Ej: 2, 1/2" style="max-width: 100px;">
                            <select class="form-select form-select-sm" id="calcUnidad" style="max-width: 90px;">
                                <option value="g">g</option>
                                <option value="kg">kg</option>
                                <option value="ml">ml</option>
                                <option value="L">L</option>
                                <option value="cup">taza</option>
                                <option value="tbsp">cda</option>
                                <option value="tsp">cdta</option>
                                <option value="oz">oz</option>
                                <option value="lb">lb</option>
                                <option value="UND">UND</option>
                            </select>
                            <select class="form-select form-select-sm" id="calcTipoIngrediente" style="max-width: 130px;">
                                <option value="flour">Harina</option>
                                <option value="sugar">Azúcar</option>
                                <option value="butter">Mantequilla</option>
                                <option value="milk">Leche</option>
                                <option value="water">Agua</option>
                                <option value="oil">Aceite</option>
                                <option value="eggs">Huevos</option>
                                <option value="custom-solid">Otro sólido</option>
                                <option value="custom-liquid">Otro líquido</option>
                            </select>
                            <button type="button" class="btn btn-primary btn-sm" id="calcBtnAgregarIng"><i class="bi bi-plus-lg me-1"></i>Agregar</button>
                        </div>
                    </div>

                    <!-- 2. Costos adicionales -->
                    <div class="calc-seccion">
                        <div class="calc-seccion-titulo"><i class="bi bi-wallet2"></i> 2. Costos adicionales</div>
                        <button class="calc-ayuda-btn mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAyudaCostos" aria-expanded="false">
                            <span><i class="bi bi-info-circle me-1"></i> Cómo calcular cada costo</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>
                        <div class="collapse" id="collapseAyudaCostos">
                            <div class="calc-ayuda-body">
                                <p class="mb-2">Incluye los gastos que a veces se olvidan: tu tiempo, servicios, empaque y envío.</p>
                                <p class="mb-1"><strong>Horas de trabajo:</strong> Preparación + horneado + decoración + limpieza.</p>
                                <p class="mb-1"><strong>Valor por hora:</strong> En Colombia suele ser $8.000–$15.000/h. Sugerencia: $10.000/h.</p>
                                <p class="mb-1"><strong>Desgaste:</strong> Se calcula solo (2% de ingredientes).</p>
                                <p class="mb-1"><strong>Servicios:</strong> Luz/gas del horno. Ej: horno 1 h ≈ $2.000–3.000.</p>
                                <p class="mb-1"><strong>Empaque:</strong> Caja, moño, etiqueta, bolsa.</p>
                                <p class="mb-0"><strong>Envío:</strong> Gasolina si entregas tú, o costo de mensajería.</p>
                            </div>
                        </div>
                        <div class="calc-costos-grid">
                            <div class="calc-costo-item">
                                <label><i class="bi bi-clock"></i> Horas de trabajo</label>
                                <input type="number" class="form-control form-control-sm" id="calcHorasTrabajo" step="0.25" min="0" value="0" placeholder="0">
                                <div class="texto-ayuda">Preparación + horneado + decoración</div>
                            </div>
                            <div class="calc-costo-item">
                                <label><i class="bi bi-currency-dollar"></i> Valor por hora ($)</label>
                                <input type="number" class="form-control form-control-sm" id="calcValorHora" step="500" min="0" value="10000" placeholder="10000">
                                <div class="texto-ayuda">Sugerencia: $10.000 en Colombia</div>
                            </div>
                            <div class="calc-costo-item readonly">
                                <label><i class="bi bi-tools"></i> Desgaste (2%)</label>
                                <input type="number" class="form-control form-control-sm" id="calcDesgaste" step="0.01" min="0" value="0" readonly>
                                <div class="texto-ayuda">Automático sobre ingredientes</div>
                            </div>
                            <div class="calc-costo-item">
                                <label><i class="bi bi-lightning"></i> Servicios (luz/gas)</label>
                                <input type="number" class="form-control form-control-sm" id="calcServicios" step="100" min="0" value="0" placeholder="0">
                                <div class="texto-ayuda">Ver guía arriba</div>
                            </div>
                            <div class="calc-costo-item">
                                <label><i class="bi bi-box-seam"></i> Empaque ($)</label>
                                <input type="number" class="form-control form-control-sm" id="calcEmpaque" step="100" min="0" value="0" placeholder="0">
                                <div class="texto-ayuda">Caja, moño, etiqueta</div>
                            </div>
                            <div class="calc-costo-item">
                                <label><i class="bi bi-truck"></i> Envío ($)</label>
                                <input type="number" class="form-control form-control-sm" id="calcEnvio" step="100" min="0" value="0" placeholder="0">
                                <div class="texto-ayuda">Si aplica para el cliente</div>
                            </div>
                        </div>
                    </div>

                    <!-- 3. Resumen -->
                    <div class="calc-seccion">
                        <div class="calc-seccion-titulo"><i class="bi bi-pie-chart"></i> 3. Resumen de costos</div>
                        <div class="calc-resumen-grid">
                            <div class="calc-resumen-item"><div class="titulo">Ingredientes</div><div class="valor" id="calcResumenIngredientes">$0</div></div>
                            <div class="calc-resumen-item"><div class="titulo">Mano de obra</div><div class="valor" id="calcResumenManoObra">$0</div></div>
                            <div class="calc-resumen-item"><div class="titulo">Desgaste</div><div class="valor" id="calcResumenDesgaste">$0</div></div>
                            <div class="calc-resumen-item"><div class="titulo">Otros</div><div class="valor" id="calcResumenOtros">$0</div></div>
                            <div class="calc-resumen-item total"><div class="titulo">Costo total</div><div class="valor" id="calcResumenTotal">$0</div></div>
                        </div>
                    </div>

                    <!-- 4. Margen -->
                    <div class="calc-seccion">
                        <div class="calc-seccion-titulo"><i class="bi bi-graph-up"></i> 4. Margen de ganancia</div>
                        <div class="calc-margen-guia">
                            <span>30–50% Básico</span>
                            <span>50–80% Estándar</span>
                            <span>80–100% Premium</span>
                            <span>100%+ Lujo</span>
                        </div>
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <label class="form-label mb-0 fw-semibold">Porcentaje:</label>
                            <input type="range" class="form-range flex-grow-1" id="calcMargenPct" min="0" max="150" value="50" step="5" style="max-width: 300px;">
                            <span class="fw-bold" id="calcMargenPctVal">50</span>%
                        </div>
                        <div class="row g-2 small">
                            <div class="col-md-3"><span class="text-muted">Costo/porción</span> <strong id="calcCostoPorcion">$0</strong></div>
                            <div class="col-md-3"><span class="text-muted">Precio/porción</span> <strong id="calcPrecioPorcion">$0</strong></div>
                            <div class="col-md-3"><span class="text-muted">Ganancia/porción</span> <strong id="calcGananciaPorcion">$0</strong></div>
                            <div class="col-md-3"><span class="text-muted">Margen</span> <strong id="calcMargenVentas">0%</strong></div>
                        </div>
                    </div>

                    <!-- 5. Resultados -->
                    <div class="calc-seccion">
                        <div class="calc-seccion-titulo"><i class="bi bi-currency-dollar"></i> 5. Resultados finales</div>
                        <div class="calc-resultados">
                            <div class="calc-resultado-precio">
                                <div class="text-muted small mb-1">Precio de venta total</div>
                                <div class="valor" id="calcPrecioVentaTotal">$0</div>
                            </div>
                            <div class="calc-resultado-ganancia">
                                <div class="text-muted small mb-1">Ganancia neta</div>
                                <div class="valor" id="calcGananciaNeta">$0</div>
                            </div>
                        </div>
                    </div>

                    <!-- Convertidor -->
                    <div class="calc-seccion">
                        <button class="calc-ayuda-btn w-100" type="button" data-bs-toggle="collapse" data-bs-target="#collapseConvertidor">
                            <span><i class="bi bi-arrow-left-right me-1"></i> Convertidor de medidas (tazas → gramos)</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>
                        <div class="collapse" id="collapseConvertidor">
                            <div class="pt-3">
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-2"><label class="form-label small">Cantidad</label><input type="text" class="form-control form-control-sm" id="convCantidad" placeholder="2 1/2 o 2.5"></div>
                                    <div class="col-md-2"><label class="form-label small">Medida</label><select class="form-select form-select-sm" id="convMedida"><option value="cup">Taza</option><option value="tbsp">Cda</option><option value="tsp">Cdta</option><option value="g">g</option><option value="ml">ml</option></select></div>
                                    <div class="col-md-2"><label class="form-label small">Ingrediente</label><select class="form-select form-select-sm" id="convTipo"><option value="flour">Harina</option><option value="sugar">Azúcar</option><option value="butter">Mantequilla</option><option value="milk">Leche</option><option value="custom-solid">Otro</option></select></div>
                                    <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-primary" id="convCalcular">Calcular</button></div>
                                    <div class="col"><span class="small text-muted">Resultado:</span> <strong id="convResultado">0 g / 0 ml</strong></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-primary" id="calcBtnGuardar"><i class="bi bi-save me-1"></i> Guardar receta</button>
                </div>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Modal Tema -->
    <div class="modal fade" id="temaModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="temaModalTitle">Nuevo Tema</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="temaId">
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="temaNombre" placeholder="ej: Unidades de masa, Alimentos">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarTema">Guardar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Parámetro -->
    <div class="modal fade" id="parametroModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="parametroModalTitle">Nuevo Parámetro</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="parametroId">
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="parametroNombre" placeholder="ej: kg, bebidas, comidas">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarParametro">Guardar</button>
                </div>
            </div>
        </div>
    </div>

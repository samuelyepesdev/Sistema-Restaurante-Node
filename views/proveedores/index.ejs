<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Proveedores - <%= tenant.nombre %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/modulos/proveedores.css">
</head>

<body class="bg-light">
    <%- include('../partials/navbar', { user: user, tenant: tenant }) %>

        <div class="container py-4">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h2 class="fw-bold"><i class="bi bi-truck me-2 text-primary"></i>Proveedores</h2>
                    <p class="text-muted">Gestiona las empresas que suministran tus insumos.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#proveedorModal"
                        onclick="resetForm()">
                        <i class="bi bi-plus-lg me-1"></i>Nuevo Proveedor
                    </button>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <%- include('_table', { proveedores: proveedores }) %>
                </div>
            </div>
        </div>

        <%- include('_modal_form') %>

            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script src="/js/modulos/proveedores.js"></script>
</body>

</html>
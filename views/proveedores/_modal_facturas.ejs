<!-- Modal de Facturas de Proveedor -->
<div class="modal fade" id="modalFacturasProveedor" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 bg-light-subtle py-3 ps-4">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-receipt me-2 text-primary"></i>Facturas de: <span id="facturaProveedorNombre"
                        class="text-primary"></span>
                </h5>
                <button type="button" class="btn-close me-2" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">

                <!-- Formulario de carga rápida -->
                <div class="card border-0 bg-primary-subtle rounded-3 mb-4">
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-3"><i class="bi bi-upload me-2"></i>Cargar nueva factura (PDF o Imagen)
                        </h6>
                        <form id="formCargarFactura" enctype="multipart/form-data">
                            <input type="hidden" id="facturaProveedorId">
                            <div class="row g-2">
                                <div class="col-6 col-md-4">
                                    <label class="small text-muted mb-1">N° Factura</label>
                                    <input type="text" class="form-control form-control-sm" name="numero_factura"
                                        placeholder="Ej: FAC-123" required>
                                </div>
                                <div class="col-6 col-md-4">
                                    <label class="small text-muted mb-1">Fecha</label>
                                    <input type="date" class="form-control form-control-sm" name="fecha_emision"
                                        required>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="small text-muted mb-1">Monto Total</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">$</span>
                                        <input type="number" step="0.01" class="form-control" name="monto_total"
                                            placeholder="0.00" required>
                                    </div>
                                </div>
                                <div class="col-12 col-md-9">
                                    <label class="small text-muted mb-1">Archivo (PDF o Imagen)</label>
                                    <input type="file" class="form-control form-control-sm" name="archivo"
                                        accept="application/pdf,image/*" required>
                                </div>
                                <div class="col-12 col-md-3 d-flex align-items-end">
                                    <button type="submit" class="btn btn-primary btn-sm w-100 py-2">
                                        <i class="bi bi-cloud-arrow-up me-1"></i>Subir
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Listado de facturas - Escritorio -->
                <div class="d-none d-md-block table-responsive" style="max-height: 300px;">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="bg-light sticky-top">
                            <tr>
                                <th>Fecha</th>
                                <th>N° Factura</th>
                                <th class="text-end">Monto</th>
                                <th class="text-center">Archivo</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="listaFacturasCuerpo">
                            <!-- Se llena vía JS -->
                        </tbody>
                    </table>
                </div>

                <!-- Listado de facturas - Móvil -->
                <div class="d-md-none" id="listaFacturasMovil" style="max-height: 350px; overflow-y: auto;">
                    <!-- Se llena vía JS con cards compactos -->
                </div>

                <div id="sinFacturasMsg" class="text-center py-4 d-none">
                    <i class="bi bi-file-earmark-x display-6 text-muted mb-2 d-inline-block"></i>
                    <p class="text-muted small">No hay facturas cargadas para este proveedor.</p>
                </div>

            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary btn-sm px-4"
                    data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-subtle {
        background-color: #e7f1ff;
    }

    .btn-white {
        background: #fff;
        border: 1px solid #dee2e6;
    }

    .btn-white:hover {
        background: #f8f9fa;
    }
</style>
<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
            <tr>
                <th class="ps-4">Nombre</th>
                <th>NIT / Doc</th>
                <th>Contacto</th>
                <th>Teléfono</th>
                <th>Email</th>
                <th>Estado</th>
                <th class="text-end pe-4">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% if (proveedores.length===0) { %>
                <tr>
                    <td colspan="7" class="text-center py-5 text-muted">
                        <i class="bi bi-inbox display-4 d-block mb-3"></i>
                        No hay proveedores registrados aún.
                    </td>
                </tr>
                <% } else { %>
                    <% proveedores.forEach(p=> { %>
                        <tr id="row-<%= p.id %>">
                            <td class="ps-4">
                                <div class="fw-bold text-dark">
                                    <%= p.nombre %>
                                </div>
                                <div class="small text-muted">
                                    <%= p.direccion || 'Sin dirección' %>
                                </div>
                            </td>
                            <td>
                                <%= p.nit || 'N/A' %>
                            </td>
                            <td>
                                <%= p.contacto || 'N/A' %>
                            </td>
                            <td>
                                <%= p.telefono || 'N/A' %>
                            </td>
                            <td>
                                <%= p.email || 'N/A' %>
                            </td>
                            <td>
                                <% if (p.activo) { %>
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3">Activo</span>
                                    <% } else { %>
                                        <span
                                            class="badge bg-danger-subtle text-danger rounded-pill px-3">Inactivo</span>
                                        <% } %>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm">
                                    <button class="btn btn-white btn-sm btn-facturas" data-id="<%= p.id %>"
                                        data-nombre="<%= p.nombre %>" title="Facturas">
                                        <i class="bi bi-receipt text-success"></i>
                                    </button>
                                    <button class="btn btn-white btn-sm btn-editar" data-id="<%= p.id %>"
                                        title="Editar">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                    </button>
                                    <button class="btn btn-white btn-sm btn-eliminar" data-id="<%= p.id %>"
                                        title="Eliminar">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                            <% } %>
        </tbody>
    </table>
</div>
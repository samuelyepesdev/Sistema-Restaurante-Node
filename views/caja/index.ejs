<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Control de Caja - <%= tenant.nombre %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/modulos/caja.css">
</head>

<body class="bg-light">
    <%- include('../partials/navbar', { user: user, tenant: tenant }) %>

        <div class="container py-4">
            <div class="row mb-4 align-items-center">
                <div class="col-md-6">
                    <h2 class="fw-bold"><i class="bi bi-wallet2 me-2 text-primary"></i>Control de Caja</h2>
                    <p class="text-muted mb-0">Gestión de turnos, arqueos y base inicial.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="/caja/historial" class="btn btn-outline-secondary rounded-pill">
                        <i class="bi bi-clock-history me-2"></i>Ver Historial de Turnos
                    </a>
                </div>
            </div>

            <% if (!estado.abierta) { %>
                <!-- Pantalla de Caja Cerrada -->
                <div class="row justify-content-center py-5">
                    <div class="col-md-6 text-center">
                        <div class="card border-0 shadow-lg rounded-4 p-4">
                            <div class="display-1 text-muted mb-4"><i class="bi bi-door-closed"></i></div>
                            <h3 class="fw-bold">Turno Cerrado</h3>
                            <p class="text-muted mb-4">Para comenzar a registrar ventas y movimientos, debes abrir el
                                turno de caja con una base inicial.</p>

                            <form id="formAbrirCaja">
                                <div class="row gx-2">
                                    <div class="col-6 mb-3 text-start">
                                        <label class="form-label fw-bold small text-muted"><i class="bi bi-cash me-1"></i>Base Efectivo (Físico)</label>
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text bg-white border-end-0 text-success fw-bold">$</span>
                                            <input type="number" step="0.01" class="form-control border-start-0 ps-0 fw-bold" name="monto_inicial_efectivo" placeholder="0.00" required autofocus>
                                        </div>
                                    </div>
                                    <div class="col-6 mb-3 text-start">
                                        <label class="form-label fw-bold small text-muted"><i class="bi bi-bank me-1"></i>Base Transferencias</label>
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text bg-white border-end-0 text-primary fw-bold">$</span>
                                            <input type="number" step="0.01" class="form-control border-start-0 ps-0 fw-bold" name="monto_inicial_transferencia" placeholder="0.00" value="0" required>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-4 text-start">
                                    <label class="form-label fw-bold small text-muted">Notas de apertura (Opcional)</label>
                                    <textarea class="form-control rounded-3" name="notas" rows="2" placeholder="Ej: Recibido por Samuel..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm py-3">
                                    <i class="bi bi-unlock me-2"></i>Abrir Turno de Caja
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                <% } else { %>
                    <!-- Pantalla de Caja Abierta -->
                    <div class="row g-4">
                        <!-- Estado Actual -->
                        <div class="col-lg-8">
                            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                                <div class="card-header bg-primary text-white py-3 border-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Turno Activo
                                        </h5>
                                        <span class="badge bg-white text-primary rounded-pill px-3">ABIERTA</span>
                                    </div>
                                </div>
                                <div class="card-body p-4">
                                    <!-- Sección de Resumen Agrupado -->
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <!-- Tarjeta Efectivo -->
                                            <div class="card bg-white border-0 border-start border-4 border-success h-100 shadow-sm rounded-4">
                                                <div class="card-body">
                                                    <h6 class="text-success fw-bold mb-3 d-flex align-items-center"><i class="bi bi-cash-stack me-2 fs-5"></i>Dinero Físico (Efectivo)</h6>
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span class="text-muted small">Caja Fuerte / Base:</span>
                                                        <span class="fw-bold text-dark">$<%= new Intl.NumberFormat('es-CO').format(estado.sesion.monto_inicial_efectivo) %></span>
                                                    </div>
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span class="text-muted small">Ventas (Efectivo):</span>
                                                        <span class="fw-bold text-success">+$<%= new Intl.NumberFormat('es-CO').format(estado.sesion.ventas_efectivo) %></span>
                                                    </div>
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span class="text-muted small">Mvs. Manuales:</span>
                                                        <span class="fw-bold"><span class="text-success">+<%= estado.sesion.entradas %></span> | <span class="text-danger">-<%= estado.sesion.salidas %></span></span>
                                                    </div>
                                                    <hr class="text-muted opacity-25">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="fw-bold text-dark">Efectivo en Caja:</span>
                                                        <span class="h4 fw-bold text-success mb-0">$<%= new Intl.NumberFormat('es-CO').format(estado.sesion.monto_final_teorico_efectivo) %></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <!-- Tarjeta Bancos/Transferencias -->
                                            <div class="card bg-white border-0 border-start border-4 border-primary h-100 shadow-sm rounded-4">
                                                <div class="card-body">
                                                    <h6 class="text-primary fw-bold mb-3 d-flex align-items-center"><i class="bi bi-bank me-2 fs-5"></i>Medios Digitales (Transferencias)</h6>
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span class="text-muted small">Saldo Inicial:</span>
                                                        <span class="fw-bold text-dark">$<%= new Intl.NumberFormat('es-CO').format(estado.sesion.monto_inicial_transferencia) %></span>
                                                    </div>
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span class="text-muted small">Ventas (Transferencias):</span>
                                                        <span class="fw-bold text-primary">+$<%= new Intl.NumberFormat('es-CO').format(estado.sesion.ventas_transferencia) %></span>
                                                    </div>
                                                    <!-- Se espacio para que quede parejo a nivel de altura sino pones algo aquí -->
                                                    <div class="d-flex justify-content-between mb-2 invisible">
                                                        <span class="text-muted small">...</span>
                                                        <span class="fw-bold">...</span>
                                                    </div>
                                                    <hr class="text-muted opacity-25">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="fw-bold text-dark">Saldo en Bancos:</span>
                                                        <span class="h4 fw-bold text-primary mb-0">$<%= new Intl.NumberFormat('es-CO').format(estado.sesion.monto_final_teorico_transferencia) %></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-4 pt-4 border-top">
                                        <div class="d-flex flex-wrap gap-2">
                                            <button class="btn btn-success rounded-pill px-4 py-2"
                                                data-bs-toggle="modal" data-bs-target="#modalMovimiento"
                                                onclick="setTipoMov('entrada')">
                                                <i class="bi bi-plus-circle me-1"></i> Entrada de Dinero
                                            </button>
                                            <button class="btn btn-outline-danger rounded-pill px-4 py-2"
                                                data-bs-toggle="modal" data-bs-target="#modalMovimiento"
                                                onclick="setTipoMov('salida')">
                                                <i class="bi bi-dash-circle me-1"></i> Gasto / Salida
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-header bg-white border-0 py-3">
                                    <h6 class="mb-0 fw-bold">Detalles del Turno</h6>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="bg-light">
                                                <tr class="small text-muted">
                                                    <th class="ps-4">Apertura</th>
                                                    <th>Usuario</th>
                                                    <th>Total Ventas</th>
                                                    <th>Total Mvs.</th>
                                                    <th class="text-end pe-4">Total General</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td class="ps-4">
                                                        <div class="fw-bold">
                                                            <%= new
                                                                Date(estado.sesion.fecha_apertura).toLocaleTimeString()
                                                                %>
                                                        </div>
                                                        <div class="small text-muted">
                                                            <%= new
                                                                Date(estado.sesion.fecha_apertura).toLocaleDateString()
                                                                %>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <%= user.nombre %>
                                                    </td>
                                                    <td class="text-success fw-bold">+$<%= new
                                                            Intl.NumberFormat('es-CO').format(estado.sesion.ventas) %>
                                                        <br><small class="text-muted">Ef: <%= estado.sesion.ventas_efectivo %> | Tr: <%= estado.sesion.ventas_transferencia %></small>
                                                    </td>
                                                    <td>
                                                        <div class="small text-success">+$<%= new
                                                                Intl.NumberFormat('es-CO').format(estado.sesion.entradas)
                                                                %>
                                                        </div>
                                                        <div class="small text-danger">-$<%= new
                                                                Intl.NumberFormat('es-CO').format(estado.sesion.salidas)
                                                                %>
                                                        </div>
                                                    </td>
                                                    <td class="text-end pe-4 fw-bold h5">
                                                        $<%= new
                                                            Intl.NumberFormat('es-CO').format(estado.sesion.monto_final_teorico)
                                                            %>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Acciones de Cierre -->
                        <div class="col-lg-4">
                            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 1rem;">
                                <div class="card-body p-4 text-center">
                                    <h5 class="fw-bold mb-3">Arqueo y Cierre</h5>
                                    <p class="text-muted small">Al finalizar el día, cuenta el efectivo físico y
                                        compáralo con el total del sistema.</p>

                                    <form id="formCerrarCaja" data-id="<%= estado.sesion.id %>">
                                        <div class="mb-3 text-start">
                                            <label class="form-label small fw-bold"><i class="bi bi-cash me-1"></i>Efectivo Físico Contado</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white">$</span>
                                                <input type="number" step="0.01" name="monto_final_real"
                                                    class="form-control fw-bold fs-5 text-success" required placeholder="0.00" value="<%= estado.sesion.monto_final_teorico_efectivo %>">
                                            </div>
                                            <div class="form-text text-muted small">Cuenta todos los billetes/monedas reales.</div>
                                        </div>
                                        <div class="mb-4 text-start">
                                            <label class="form-label small fw-bold">Notas de cierre</label>
                                            <textarea class="form-control" name="notas" rows="3"
                                                placeholder="Ej: Todo cuadra perfecto..."></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-danger w-100 rounded-pill py-3 fw-bold shadow-sm">
                                            <i class="bi bi-lock-fill me-2"></i>Cerrar Turno
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
        </div>

        <!-- Modales -->
        <div class="modal fade" id="modalMovimiento" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow rounded-4">
                    <form id="formMovimiento" data-id="<%= estado.abierta ? estado.sesion.id : '' %>">
                        <div class="modal-header border-0">
                            <h5 class="modal-title fw-bold" id="titleMov">Registrar Movimiento</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="tipo" id="tipoMov">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Monto</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" step="0.01" name="monto" class="form-control" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Motivo / Descripción</label>
                                <input type="text" name="motivo" class="form-control"
                                    placeholder="Ej: Compra de hielo, Pago propina..." required>
                            </div>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-primary px-4">Guardar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="/js/modulos/caja.js"></script>
</body>

</html>
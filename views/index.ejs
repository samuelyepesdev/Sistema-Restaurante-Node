<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Facturación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/index.css">
</head>
<body>
    <%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null, tenant: typeof tenant !== 'undefined' ? tenant : null }) %>

    <input type="hidden" id="eventoId" value="<%= typeof eventoFiltro !== 'undefined' && eventoFiltro && eventoFiltro.id ? eventoFiltro.id : '' %>">
    <% if (typeof eventoFiltro !== 'undefined' && eventoFiltro) { %>
    <div class="container mt-3">
        <div class="alert alert-info d-flex align-items-center justify-content-between flex-wrap gap-2 mb-0">
            <span><i class="bi bi-calendar-event me-2"></i><strong>Venta para evento:</strong> <%= eventoFiltro.nombre %></span>
            <a href="/facturas/facturar" class="btn btn-sm btn-outline-primary">Quitar evento</a>
        </div>
    </div>
    <% } %>
    <div class="container mt-4">
        <!-- Indicador de Pasos -->
        <div class="step-indicator">
            <div class="step active" id="step1">
                <div class="step-number">1</div>
                <div class="step-label">Cliente</div>
            </div>
            <div class="step" id="step2">
                <div class="step-number">2</div>
                <div class="step-label">Productos</div>
            </div>
            <div class="step" id="step3">
                <div class="step-number">3</div>
                <div class="step-label">Pago</div>
            </div>
            <div class="step" id="step4">
                <div class="step-number">4</div>
                <div class="step-label">Facturar</div>
            </div>
        </div>

        <!-- Información del Cliente -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-person-fill"></i>
                Paso 1: Seleccionar Cliente
                <span class="shortcut-hint">(Ctrl+F o .)</span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div class="search-container">
                            <div class="input-group input-group-lg">
                                <span class="input-group-text">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input type="text" id="cliente" class="form-control" placeholder="Buscar cliente por nombre o teléfono...">
                                <input type="hidden" id="cliente_id">
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-outline-primary w-100 h-100" data-bs-toggle="modal" data-bs-target="#nuevoClienteModal">
                            <i class="bi bi-person-plus"></i> Nuevo Cliente
                        </button>
                    </div>
                </div>
                <div id="infoCliente" class="info-cliente-card" style="display: none;">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <i class="bi bi-geo-alt-fill text-primary"></i>
                            <strong>Dirección:</strong>
                            <span id="direccionCliente" class="ms-2"></span>
                        </div>
                        <div class="col-md-6 mb-2">
                            <i class="bi bi-telephone-fill text-primary"></i>
                            <strong>Teléfono:</strong>
                            <span id="telefonoCliente" class="ms-2"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Productos -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-cart-fill"></i>
                Paso 2: Agregar Productos
                <span class="shortcut-hint">(Ctrl+B o /)</span>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-12">
                        <label class="form-label small text-muted mb-1">Buscar producto — escriba y seleccione para agregar a la venta</label>
                        <div class="search-container position-relative">
                            <div class="input-group input-group-lg">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" id="producto" class="form-control" placeholder="Buscar por nombre o código..." autocomplete="off">
                                <input type="hidden" id="producto_id">
                            </div>
                            <div id="resultadosProductos" class="search-results list-group" style="display: none;"></div>
                        </div>
                    </div>
                </div>

                <div id="productosContainer">
                    <!-- Vista móvil: lista en tarjetas (nombre, cantidad +/- pequeños, unitario/subtotal, eliminar) -->
                    <div id="productosListaMobile" class="d-block d-md-none productos-mobile-list"></div>
                    <!-- Vista escritorio: tabla -->
                    <div class="table-responsive d-none d-md-block">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-center">Cantidad</th>
                                    <th>Unidad</th>
                                    <th class="text-end">Precio Unit.</th>
                                    <th class="text-end">Subtotal</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="productosTabla">
                                <tr>
                                    <td colspan="6" class="empty-state">
                                        <i class="bi bi-cart-x"></i>
                                        <div>No hay productos agregados</div>
                                        <small class="text-muted">Busca y agrega productos usando el formulario de arriba</small>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Forma de Pago -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-credit-card-fill"></i>
                Paso 3: Forma de Pago
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <label class="form-label">Seleccione la forma de pago</label>
                        <select id="formaPago" class="form-control form-control-lg">
                            <option value="efectivo">💵 Efectivo</option>
                            <option value="transferencia">💳 Transferencia</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer fijo con acciones -->
    <div class="footer-actions d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <span class="footer-total-label">Total:</span>
            <span class="footer-total">$<span id="totalFactura">0.00</span></span>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button type="button" class="btn btn-outline-secondary" id="nuevaVenta" title="Limpiar y empezar nueva venta">
                <i class="bi bi-plus-circle"></i> Nueva venta
            </button>
            <button class="btn btn-outline-secondary" id="verPedidos" data-bs-toggle="tooltip" title="Ver Pedidos Guardados">
                <i class="bi bi-list-check"></i> Pedidos
            </button>
            <button class="btn btn-outline-primary" id="guardarPedido" data-bs-toggle="tooltip" title="Guardar Pedido (Ctrl+S)">
                <i class="bi bi-save"></i> Guardar
            </button>
            <button class="btn btn-success btn-lg" id="generarFactura" data-bs-toggle="tooltip" title="Generar Factura (Ctrl+G)">
                <i class="bi bi-receipt"></i> Generar Factura
            </button>
        </div>
    </div>

   

    <!-- Modal Nuevo Cliente -->
    <div class="modal fade" id="nuevoClienteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person-plus-fill me-2"></i>
                        Nuevo Cliente
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formNuevoCliente">
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" id="nombreCliente" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Dirección</label>
                            <input type="text" class="form-control" id="direccionNuevoCliente">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="text" class="form-control" id="telefonoNuevoCliente">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="guardarCliente">
                        <i class="bi bi-save me-1"></i>
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de Pedidos Guardados -->
    <div class="modal fade" id="pedidosModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Pedidos Guardados</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Productos</th>
                                    <th>Total</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="pedidosGuardados">
                                <!-- Los pedidos se cargarán aquí dinámicamente -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Aplicar descuento (por línea de producto) -->
    <div class="modal fade" id="descuentoModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-percent me-2"></i>Aplicar descuento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-2" id="descuentoModalProducto">Producto</p>
                    <p class="small text-info mb-3"><i class="bi bi-info-circle me-1"></i>El descuento es solo para esta venta. En la siguiente venta el producto tendrá su precio normal.</p>
                    <p class="mb-3">Seleccione el porcentaje de descuento para esta línea:</p>
                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                        <button type="button" class="btn btn-outline-primary btn-descuento" data-pct="5">5%</button>
                        <button type="button" class="btn btn-outline-primary btn-descuento" data-pct="10">10%</button>
                        <button type="button" class="btn btn-outline-primary btn-descuento" data-pct="15">15%</button>
                        <button type="button" class="btn btn-outline-primary btn-descuento" data-pct="20">20%</button>
                        <button type="button" class="btn btn-outline-primary btn-descuento" data-pct="30">30%</button>
                    </div>
                    <div class="mt-3 text-center">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="quitarDescuentoBtn">Quitar descuento</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal para mostrar factura: en móvil fullscreen y altura controlada para poder cerrar -->
    <div class="modal fade" id="facturaModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-fullscreen-md-down">
            <div class="modal-content d-flex flex-column h-100">
                <div class="modal-header py-2 flex-shrink-0">
                    <h5 class="modal-title">Factura</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body p-0 flex-grow-1 overflow-auto" style="min-height: 0;">
                    <iframe id="facturaFrame" class="factura-iframe-mobile" style="width: 100%; height: 80vh; border: none;"></iframe>
                </div>
                <div class="modal-footer flex-shrink-0 py-2">
                    <button type="button" class="btn btn-primary btn-sm" onclick="document.getElementById('facturaFrame').contentWindow.print()">
                        <i class="bi bi-printer"></i> Imprimir
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/animate.css@4.1.1/animate.min.css">
    <script src="/js/factura.js?v=2"></script>
</body>
</html> 
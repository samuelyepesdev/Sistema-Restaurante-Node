<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistema de Facturación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>
    <%- include('partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant !=='undefined' ? tenant : null }) %>

        <div class="container mt-4">
            <h1 class="mb-4">
                <i class="bi bi-graph-up-arrow me-2"></i>
                Dashboard de EstadÃ­sticas
            </h1>

            <!-- Filtros de fecha -->
            <div class="filter-section">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-3">
                        <label class="form-label">Desde</label>
                        <input type="date" id="filtroDesde" class="form-control">
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Hasta</label>
                        <input type="date" id="filtroHasta" class="form-control">
                    </div>
                    <div class="col-12 col-md-3">
                        <button id="aplicarFiltros" class="btn btn-primary w-100">
                            <i class="bi bi-funnel me-2"></i>Aplicar Filtros
                        </button>
                    </div>
                    <div class="col-12 col-md-3">
                        <button id="limpiarFiltros" class="btn btn-secondary w-100">
                            <i class="bi bi-x-circle me-2"></i>Limpiar
                        </button>
                    </div>
                </div>
            </div>

            <!-- Ventas de hoy (estadÃ­sticas del dÃ­a) -->
            <div class="row mb-2">
                <div class="col-12">
                    <h5 class="text-muted mb-2 small text-uppercase fw-bold">Ventas de hoy</h5>
                </div>
                <div class="col-md-6">
                    <div class="card stat-card c-primary text-white clickable" id="cardVentasHoy"
                        data-action="go-ventas" title="Ir a Ventas">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="stat-label">Ventas hoy ($)</div>
                                    <div class="stat-value" id="ventasHoyTotal">$0</div>
                                    <small class="opacity-75" style="font-size: 0.75rem;">Lo llevado en el dÃ­a</small>
                                </div>
                                <i class="bi bi-currency-dollar stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card stat-card c-teal text-white clickable" id="cardFacturasHoy" data-action="go-ventas"
                        title="Ir a Ventas">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="stat-label">Facturas hoy</div>
                                    <div class="stat-value" id="ventasHoyCantidad">0</div>
                                    <small class="opacity-75" style="font-size: 0.75rem;">Cantidad en el dÃ­a</small>
                                </div>
                                <i class="bi bi-receipt stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Totales del perÃ­odo (segÃºn filtros) -->
            <div class="row" id="statsCards">
                <div class="col-12 mb-2">
                    <h5 class="text-muted mb-2 small text-uppercase fw-bold">Totales del perÃ­odo</h5>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card c-blue text-white clickable" id="cardTotalVentas" data-action="go-ventas"
                        title="Ir a Ventas">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="stat-label">Total Ventas</div>
                                    <div class="stat-value" id="totalSales">$0.00</div>
                                </div>
                                <i class="bi bi-currency-dollar stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card c-slate text-white clickable" id="cardTotalFacturas"
                        data-action="go-ventas" title="Ir a Ventas">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="stat-label">Total Facturas</div>
                                    <div class="stat-value" id="totalInvoices">0</div>
                                </div>
                                <i class="bi bi-receipt stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card c-indigo text-white clickable" id="cardPromedio"
                        data-action="modal-promedio" title="Ver detalle del promedio">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="stat-label">Promedio por Factura</div>
                                    <div class="stat-value" id="avgInvoice">$0.00</div>
                                </div>
                                <i class="bi bi-bar-chart stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Eventos del mes e insumos bajo stock -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="card stat-card c-indigo text-white clickable" id="cardEventos" data-action="go-eventos"
                        title="Ir a Eventos">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="stat-label">Eventos del mes</div>
                                    <div class="stat-value" id="eventosCount">0</div>
                                    <small class="opacity-75" style="font-size: 0.7rem;">Del mes actual</small>
                                </div>
                                <i class="bi bi-calendar-event stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card stat-card c-slate text-white clickable" id="cardVentasEventos"
                        data-action="modal-ventas-eventos" title="Ver detalle de ventas en eventos">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="stat-label">Ventas en eventos</div>
                                    <div class="stat-value" id="ventasEventosTotal">$0.00</div>
                                </div>
                                <i class="bi bi-currency-dollar stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4" id="wrapCardInsumosBajoStock"
                    style="<%= (typeof allowedByPlan !== 'undefined' && allowedByPlan.inventario) ? '' : 'display:none;' %>">
                    <div class="card stat-card c-danger text-white clickable" id="cardInsumosBajoStock"
                        data-action="go-inventario" title="Ver inventario">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="stat-label">Insumos bajo stock</div>
                                    <div class="stat-value" id="insumosBajoStock">0</div>
                                    <small class="opacity-75" style="font-size: 0.7rem;">Ir a inventario</small>
                                </div>
                                <i class="bi bi-exclamation-triangle stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- GrÃ¡ficos principales: en tablet/mÃ³vil se apilan (col-lg para que debajo de 992px cada uno vaya a ancho completo) -->
            <div class="row">
                <div class="col-12 col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-graph-up me-2"></i>
                            Ventas Diarias (Ãšltimos 30 dÃ­as)
                        </div>
                        <div class="card-body">
                            <div class="chart-container">
                                <canvas id="dailySalesChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-calendar3 me-2"></i>
                            Calendario: dÃ­as del mes con evento
                        </div>
                        <div class="card-body">
                            <div id="miniCalendarioEventos" class="mini-calendario-container">
                                <div class="text-muted small text-center py-3">Cargando...</div>
                            </div>
                            <p class="small text-muted mb-0 mt-2">Cada dÃ­a del mes que tenga al menos un evento se
                                marca
                                en violeta. Hoy en azul. UsÃ¡ las flechas para ver otros meses.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-calendar-event me-2"></i>
                            Ventas en eventos
                        </div>
                        <div class="card-body">
                            <div class="chart-container-small">
                                <canvas id="ventasEnEventosChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-bar-chart me-2"></i>
                            Ventas por CategorÃ­a
                        </div>
                        <div class="card-body">
                            <div class="chart-container-small">
                                <canvas id="salesByCategoryChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-trophy me-2"></i>
                            Top 10 Productos MÃ¡s Vendidos
                        </div>
                        <div class="card-body">
                            <div class="chart-container-small">
                                <canvas id="topProductsChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabla de productos mÃ¡s vendidos por categorÃ­a -->
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <i class="bi bi-list-ul me-2"></i>
                            Productos MÃ¡s Vendidos por CategorÃ­a
                        </div>
                        <div class="card-body">
                            <div id="topProductsByCategoryTable">
                                <div class="loading-spinner">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Cargando...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal: detalle Promedio por Factura -->
        <div class="modal fade" id="modalDetallePromedio" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-info text-white">
                        <h5 class="modal-title"><i class="bi bi-bar-chart me-2"></i>Promedio por Factura</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-2">El promedio por factura se calcula asÃ­:</p>
                        <div class="bg-light rounded p-3 mb-2 font-monospace text-center">
                            <span id="modalPromedioFormula">Total ventas Ã· Cantidad de facturas = Promedio</span>
                        </div>
                        <ul class="list-unstyled mb-0">
                            <li><strong>Total ventas (perÃ­odo):</strong> <span id="modalPromedioTotal">$0</span></li>
                            <li><strong>Cantidad de facturas:</strong> <span id="modalPromedioCantidad">0</span></li>
                            <li><strong>Promedio:</strong> <span id="modalPromedioValor"
                                    class="text-primary fw-bold">$0</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal: detalle Ventas en eventos -->
        <div class="modal fade" id="modalDetalleVentasEventos" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header text-white"
                        style="background: linear-gradient(135deg, #fd7e14 0%, #e8590c 100%);">
                        <h5 class="modal-title"><i class="bi bi-calendar-event me-2"></i>Ventas en eventos</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-3">Resumen de ventas asociadas a eventos en el perÃ­odo seleccionado:</p>
                        <ul class="list-unstyled mb-0">
                            <li><strong>Total vendido en eventos:</strong> <span id="modalVentasEventosTotal"
                                    class="text-primary fw-bold">$0</span></li>
                            <li><strong>Cantidad de ventas (facturas) en eventos:</strong> <span
                                    id="modalVentasEventosCantidad">0</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script src="/js/dashboard.js"></script>
</body>

</html>
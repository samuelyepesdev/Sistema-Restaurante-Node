<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistema de Facturación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-size: 16px;
        }
        .navbar {
            background-color: #2c3e50;
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
        }
        .navbar-brand {
            color: white !important;
            font-weight: bold;
        }
        .stat-card {
            border: none;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.05);
            margin-bottom: 1.5rem;
            transition: transform 0.2s;
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }
        .stat-card.clickable {
            cursor: pointer;
        }
        .stat-card .card-body {
            padding: 1.5rem;
        }
        .stat-icon {
            font-size: 2.5rem;
            opacity: 0.8;
        }
        .stat-value {
            font-size: 2rem;
            font-weight: bold;
            margin: 0.5rem 0;
        }
        .stat-label {
            color: #1a1a1a;
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .chart-container {
            position: relative;
            height: 400px;
            margin-bottom: 2rem;
        }
        .chart-container-small {
            position: relative;
            height: 300px;
            margin-bottom: 2rem;
        }
        .card {
            border: none;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.05);
            margin-bottom: 1.5rem;
        }
        .card-header {
            background-color: #fff;
            border-bottom: 2px solid #f8f9fa;
            font-weight: 600;
            font-size: 1.2rem;
        }
        .table {
            background-color: white;
            font-size: 1rem;
        }
        .loading-spinner {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 400px;
        }
        .filter-section {
            background: white;
            padding: 1rem;
            border-radius: 0.5rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.05);
            margin-bottom: 1.5rem;
        }
        .mini-calendario-container {
            min-height: 260px;
        }
        .mini-calendario-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.75rem;
            gap: 0.5rem;
        }
        .mini-calendario-nav .mes-titulo {
            font-weight: 700;
            font-size: 1rem;
            color: #2c3e50;
            margin: 0;
            flex: 1;
            text-align: center;
        }
        .mini-calendario-nav .btn-sm {
            padding: 0.35rem 0.6rem;
        }
        .mini-calendario {
            font-size: 0.875rem;
            width: 100%;
            table-layout: fixed;
            border-collapse: separate;
            border-spacing: 2px;
        }
        .mini-calendario th {
            padding: 0.4rem 0.25rem;
            text-align: center;
            color: #5a6c7d;
            font-weight: 600;
            font-size: 0.75rem;
        }
        .mini-calendario td {
            padding: 0.4rem;
            text-align: center;
            border-radius: 6px;
            min-width: 28px;
            height: 32px;
            vertical-align: middle;
            background: #f8f9fa;
        }
        .mini-calendario td:not(.dia-evento):hover {
            background: #e9ecef;
        }
        .mini-calendario .dia-evento {
            background: rgba(111, 66, 193, 0.25);
            color: #5a32a3;
            font-weight: 700;
            cursor: pointer;
        }
        .mini-calendario .dia-evento:hover {
            background: rgba(111, 66, 193, 0.4);
        }
        .mini-calendario .dia-hoy {
            border: 2px solid #0d6efd;
            background: rgba(13, 110, 253, 0.08) !important;
            font-weight: 700;
        }
        .mini-calendario .dia-otro-mes {
            visibility: hidden;
            pointer-events: none;
        }
        @media (max-width: 992px) {
            .filter-section .row .col-md-3 {
                flex: 0 0 100%;
                max-width: 100%;
            }
            .filter-section .row .col-md-3:not(:first-child) {
                margin-top: 0.75rem;
            }
            .stat-card {
                margin-bottom: 1rem;
            }
            .chart-container,
            .chart-container-small {
                height: 230px;
            }
            .card-header {
                font-size: 1rem;
            }
        }
        @media (max-width: 576px) {
            .stat-card .card-body {
                padding: 1rem;
            }
            .filter-section .btn {
                font-size: 0.9rem;
            }
            .chart-container,
            .chart-container-small {
                height: 220px;
            }
            /* Tablas de datos: en móvil se apilan por fila */
            .table:not(.mini-calendario) tbody tr {
                display: block;
                border-bottom: 1px solid #e9ecef;
            }
            .table:not(.mini-calendario) tbody td {
                display: flex;
                justify-content: space-between;
                padding: 0.5rem;
            }
            .table:not(.mini-calendario) thead {
                display: none;
            }
            /* Calendario: siempre en grilla 7 columnas en móvil */
            .mini-calendario {
                font-size: 0.8rem;
            }
            .mini-calendario th,
            .mini-calendario td {
                padding: 0.25rem;
                min-width: 0;
                height: 28px;
            }
            .mini-calendario .mes-titulo {
                font-size: 0.9rem;
            }
            .card:not(.no-card-dark) {
                background-color: #e2e8f0;
                border-color: #cbd5f5;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null, tenant: typeof tenant !== 'undefined' ? tenant : null }) %>

    <div class="container mt-4">
        <h1 class="mb-4">
            <i class="bi bi-graph-up-arrow me-2"></i>
            Dashboard de Estadísticas
        </h1>

        <!-- Filtros de fecha -->
        <div class="filter-section">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Desde</label>
                    <input type="date" id="filtroDesde" class="form-control">
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Hasta</label>
                    <input type="date" id="filtroHasta" class="form-control">
                </div>
                <div class="col-12 col-md-3">
                    <button id="aplicarFiltros" class="btn btn-primary w-100">
                        <i class="bi bi-funnel me-2"></i>Aplicar Filtros
                    </button>
                </div>
                <div class="col-12 col-md-3">
                    <button id="limpiarFiltros" class="btn btn-secondary w-100">
                        <i class="bi bi-x-circle me-2"></i>Limpiar
                    </button>
                </div>
            </div>
        </div>

        <!-- Tarjetas de estadísticas generales (clicables: navegación o modal con detalle) -->
        <div class="row" id="statsCards">
            <div class="col-md-3">
                <div class="card stat-card text-white bg-primary clickable" id="cardTotalVentas" data-action="go-ventas" title="Ir a Ventas">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-label">Total Ventas</div>
                                <div class="stat-value" id="totalSales">$0.00</div>
                            </div>
                            <i class="bi bi-currency-dollar stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card text-white bg-success clickable" id="cardTotalFacturas" data-action="go-ventas" title="Ir a Ventas">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-label">Total Facturas</div>
                                <div class="stat-value" id="totalInvoices">0</div>
                            </div>
                            <i class="bi bi-receipt stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card text-white bg-info clickable" id="cardPromedio" data-action="modal-promedio" title="Ver detalle del promedio">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-label">Promedio por Factura</div>
                                <div class="stat-value" id="avgInvoice">$0.00</div>
                            </div>
                            <i class="bi bi-bar-chart stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Eventos del mes mostrado en el calendario -->
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="card stat-card text-white clickable" id="cardEventos" data-action="go-eventos" style="background: linear-gradient(135deg, #6f42c1 0%, #5a32a3 100%);" title="Ir a Eventos">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-label">Eventos del mes</div>
                                <div class="stat-value" id="eventosCount">0</div>
                                <small class="opacity-75" style="font-size: 0.7rem;">Del mes actual</small>
                            </div>
                            <i class="bi bi-calendar-event stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card stat-card text-white clickable" id="cardVentasEventos" data-action="modal-ventas-eventos" style="background: linear-gradient(135deg, #fd7e14 0%, #e8590c 100%);" title="Ver detalle de ventas en eventos">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="stat-label">Ventas en eventos</div>
                                <div class="stat-value" id="ventasEventosTotal">$0.00</div>
                            </div>
                            <i class="bi bi-currency-dollar stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráficos principales: en tablet/móvil se apilan (col-lg para que debajo de 992px cada uno vaya a ancho completo) -->
        <div class="row">
            <div class="col-12 col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-graph-up me-2"></i>
                        Ventas Diarias (Últimos 30 días)
                    </div>
                    <div class="card-body">
                        <div class="chart-container">
                            <canvas id="dailySalesChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-calendar3 me-2"></i>
                        Calendario: días del mes con evento
                    </div>
                    <div class="card-body">
                        <div id="miniCalendarioEventos" class="mini-calendario-container">
                            <div class="text-muted small text-center py-3">Cargando...</div>
                        </div>
                        <p class="small text-muted mb-0 mt-2">Cada día del mes que tenga al menos un evento se marca en violeta. Hoy en azul. Usá las flechas para ver otros meses.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-calendar-event me-2"></i>
                        Ventas en eventos
                    </div>
                    <div class="card-body">
                        <div class="chart-container-small">
                            <canvas id="ventasEnEventosChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-bar-chart me-2"></i>
                        Ventas por Categoría
                    </div>
                    <div class="card-body">
                        <div class="chart-container-small">
                            <canvas id="salesByCategoryChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-trophy me-2"></i>
                        Top 10 Productos Más Vendidos
                    </div>
                    <div class="card-body">
                        <div class="chart-container-small">
                            <canvas id="topProductsChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de productos más vendidos por categoría -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-list-ul me-2"></i>
                        Productos Más Vendidos por Categoría
                    </div>
                    <div class="card-body">
                        <div id="topProductsByCategoryTable">
                            <div class="loading-spinner">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Cargando...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: detalle Promedio por Factura -->
    <div class="modal fade" id="modalDetallePromedio" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="bi bi-bar-chart me-2"></i>Promedio por Factura</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">El promedio por factura se calcula así:</p>
                    <div class="bg-light rounded p-3 mb-2 font-monospace text-center">
                        <span id="modalPromedioFormula">Total ventas ÷ Cantidad de facturas = Promedio</span>
                    </div>
                    <ul class="list-unstyled mb-0">
                        <li><strong>Total ventas (período):</strong> <span id="modalPromedioTotal">$0</span></li>
                        <li><strong>Cantidad de facturas:</strong> <span id="modalPromedioCantidad">0</span></li>
                        <li><strong>Promedio:</strong> <span id="modalPromedioValor" class="text-primary fw-bold">$0</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: detalle Ventas en eventos -->
    <div class="modal fade" id="modalDetalleVentasEventos" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header text-white" style="background: linear-gradient(135deg, #fd7e14 0%, #e8590c 100%);">
                    <h5 class="modal-title"><i class="bi bi-calendar-event me-2"></i>Ventas en eventos</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">Resumen de ventas asociadas a eventos en el período seleccionado:</p>
                    <ul class="list-unstyled mb-0">
                        <li><strong>Total vendido en eventos:</strong> <span id="modalVentasEventosTotal" class="text-primary fw-bold">$0</span></li>
                        <li><strong>Cantidad de ventas (facturas) en eventos:</strong> <span id="modalVentasEventosCantidad">0</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="/js/dashboard.js"></script>
</body>
</html>


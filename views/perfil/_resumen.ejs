<!-- Columna Resumen General -->
<div class="col-lg-5">
    <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white border-0 pt-4 pb-0">
            <h5 class="card-title mb-0"><i class="bi bi-bar-chart-fill text-primary me-2"></i>Resumen General</h5>
        </div>
        <div class="card-body">
            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                    <span><i class="bi bi-building me-2 text-muted"></i>Nombre del Negocio</span>
                    <span class="fw-bold">
                        <%= tenant.nombre %>
                    </span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                    <span><i class="bi bi-geo-alt me-2 text-muted"></i>Dirección</span>
                    <span>
                        <%= tenant.direccion || 'No especificada' %>
                    </span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                    <span><i class="bi bi-telephone me-2 text-muted"></i>Teléfono</span>
                    <span>
                        <%= tenant.telefono || 'No especificado' %>
                    </span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                    <span><i class="bi bi-envelope me-2 text-muted"></i>Correo Reportes</span>
                    <span>
                        <%= tenant.email || 'No especificado' %>
                    </span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                    <span><i class="bi bi-file-earmark-text me-2 text-muted"></i>NIT</span>
                    <span>
                        <%= tenant.nit || 'No especificado' %>
                    </span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                    <span><i class="bi bi-layers text-muted me-2"></i>Plan Actual</span>
                    <span class="badge bg-primary rounded-pill">
                        <%= tenant.plan ? tenant.plan.nombre : (tenant.plan_nombre || 'Desconocido' ) %>
                    </span>
                </li>
            </ul>

            <div class="row g-3">
                <div class="col-6">
                    <div class="p-3 border rounded text-center bg-light">
                        <h3 class="mb-1 text-primary">
                            <%= stats.ventasMesCantidad || 0 %>
                        </h3>
                        <span class="text-muted small">Ventas (Mes)</span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 border rounded text-center bg-light">
                        <h3 class="mb-1 text-primary">
                            <%= stats.totalMesas || 0 %>
                        </h3>
                        <span class="text-muted small">Mesas Activas</span>
                    </div>
                </div>
            </div>

            <hr class="my-4">
            <div class="mt-4">
                <label class="form-label small fw-bold text-muted mb-2"><i class="bi bi-calendar-check me-1"></i>Generar Reporte de un Mes Específico</label>
                <div class="row g-2 mb-3">
                    <div class="col-8">
                        <select id="reportMonth" class="form-select form-select-sm">
                            <% const meses = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre']; %>
                            <% const currentMonth = new Date().getMonth() + 1; %>
                            <% meses.forEach((m, i) => { %>
                                <option value="<%= i + 1 %>" <%= (i + 1) === currentMonth ? 'selected' : '' %>><%= m %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-4">
                        <select id="reportYear" class="form-select form-select-sm">
                            <% const currentYear = new Date().getFullYear(); %>
                            <% for(let y = currentYear; y >= currentYear - 2; y--) { %>
                                <option value="<%= y %>"><%= y %></option>
                            <% } %>
                        </select>
                    </div>
                </div>
                <button type="button" class="btn btn-outline-success w-100 py-2" onclick="testReport()">
                    <i class="bi bi-whatsapp me-2"></i>Enviar Reporte Seleccionado
                </button>
                <small class="text-muted d-block mt-2 text-center" style="font-size: 0.75rem;">Se enviará a tu Email y WhatsApp registrado.</small>
            </div>
        </div>
    </div>
</div>
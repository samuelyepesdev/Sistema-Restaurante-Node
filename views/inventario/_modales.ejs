<!-- Modal Nuevo Insumo -->
<div class="modal fade" id="modalNuevoInsumo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-boxes me-2"></i>Nuevo insumo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- ─── Sección principal (simple) ─── -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nombre del insumo <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="nuevoNombre" placeholder="Ej: Pollo, Tomate, Harina..."
                        required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Código <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="nuevoCodigo" placeholder="Ej: PLL-001" required>
                    <div class="form-text">Referencia corta para identificar el insumo.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Categoría</label>
                    <select class="form-select" id="nuevoCategoriaId">
                        <option value="">Sin categoría</option>
                        <% categoriasInsumo.forEach(c=> { %>
                            <option value="<%= c.id %>">
                                <%= c.name %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <!-- Campo dinámico para Cerámicas -->
                <div class="mb-3 d-none" id="containerPrecioVenta">
                    <label class="form-label fw-semibold text-primary">Precio de Venta Unitario <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" class="form-control" id="nuevoPrecioVenta" placeholder="0.00">
                    </div>
                    <div class="form-text">Este es el precio al que se venderá la cerámica en las mesas.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Proveedor Principal</label>
                    <select class="form-select" id="nuevoProveedorId">
                        <option value="">Sin proveedor</option>
                        <% (typeof proveedores !=='undefined' ? proveedores : []).forEach(p=> { %>
                            <option value="<%= p.id %>">
                                <%= p.nombre %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-4">
                        <label class="form-label fw-semibold">Unidad</label>
                        <select class="form-select" id="nuevoUnidadBase">
                            <option value="g">g (gramos)</option>
                            <option value="ml">ml (mililitros)</option>
                            <option value="UND">UND (unidades)</option>
                        </select>
                        <div class="form-text">¿Cómo se mide este insumo?</div>
                    </div>
                    <div class="col-4">
                        <label class="form-label fw-semibold">Stock inicial</label>
                        <input type="number" step="0.01" class="form-control" id="nuevoStockInicial" value="0" min="0"
                            placeholder="0">
                        <div class="form-text">Cuánto tienes ahora.</div>
                    </div>
                    <div class="col-4">
                        <label class="form-label fw-semibold">Stock mínimo</label>
                        <input type="number" step="0.01" class="form-control" id="nuevoStockMinimo" value="0" min="0"
                            placeholder="0">
                        <div class="form-text">Alerta si baja de este nivel.</div>
                    </div>
                </div>

                <!-- ─── Sección avanzada (costeo) ─── -->
                <div class="accordion accordion-flush" id="accordionCosteo">
                    <div class="accordion-item border rounded">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-2 px-3 text-muted small fw-semibold"
                                type="button" data-bs-toggle="collapse" data-bs-target="#colapseCosteo"
                                aria-expanded="false">
                                <i class="bi bi-calculator me-2 text-primary"></i>
                                Opciones avanzadas — Cálculo automático de costos
                                <span class="badge bg-light text-secondary border ms-2 fw-normal">Opcional</span>
                            </button>
                        </h2>
                        <div id="colapseCosteo" class="accordion-collapse collapse">
                            <div class="accordion-body pt-2 pb-3">
                                <p class="text-muted small mb-3">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Completa esto solo si quieres que el sistema calcule automáticamente cuánto cuesta
                                    producir cada plato que usa este insumo (módulo de Costeo).
                                </p>
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label small">Unidad de compra</label>
                                        <select class="form-select form-select-sm" id="nuevoUnidadMedidaId">
                                            <option value="">Seleccione...</option>
                                            <% unidadesCompra.forEach(u=> { %>
                                                <option value="<%= u.id %>" data-name="<%= u.name %>">
                                                    <%= u.name %>
                                                </option>
                                                <% }) %>
                                        </select>
                                        <input type="text" class="form-control form-control-sm d-none mt-1"
                                            id="nuevoUnidadCompraText" placeholder="Otra..." value="UND">
                                        <div class="form-text">Ej: bolsa, litro, kilo...</div>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small">Presentación (cantidad en unidad base)</label>
                                        <input type="number" step="0.01" class="form-control form-control-sm"
                                            id="nuevoCantidadCompra" value="1" min="0.01"
                                            title="Cuántas unidades base trae cada presentación de compra. Ej: 1 bolsa = 1000g">
                                        <div class="form-text">Ej: 1 kg = 1000 <span class="fw-bold">g</span></div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Precio de compra (por presentación)</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">$</span>
                                        <input type="number" step="0.01" class="form-control" id="nuevoPrecioCompra"
                                            value="0" min="0">
                                    </div>
                                    <div class="form-text">Lo que pagas cuando compras una presentación de este insumo.
                                    </div>
                                </div>
                                <div id="previewCostoPorUnidad" class="alert alert-info py-1 px-2 small mt-2"
                                    style="display:none;">
                                    <i class="bi bi-tag me-1"></i> Costo estimado por <span
                                        id="previewUnidadBase">g</span>: <strong id="previewCosto">—</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnCrearInsumo">
                    <i class="bi bi-plus-lg me-1"></i> Crear insumo
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Entrada -->
<div class="modal fade" id="modalEntrada" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header fw-bold">🛒 Registrar Compra / Entrada - <span id="entradaInsumoNombre"></span>
            </div>
            <div class="modal-body">
                <input type="hidden" id="entradaInsumoId">

                <div class="mb-2">
                    <label class="form-label small fw-bold">¿Cuánto entró? (Cantidad)</label>
                    <input type="number" step="0.0001" class="form-control" id="entradaCantidad">
                </div>

                <div class="mb-2">
                    <label class="form-label small fw-bold">Precio de compra (por unidad)</label>
                    <input type="number" step="0.01" class="form-control" id="entradaCosto"
                        placeholder="Dejar vacío para usar costo actual">
                </div>

                <div class="row g-2 mb-2">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Proveedor</label>
                        <select class="form-select" id="entradaProveedorId">
                            <option value="">Seleccione proveedor...</option>
                            <% (typeof proveedores !=='undefined' ? proveedores : []).forEach(p=> { %>
                                <option value="<%= p.id %>">
                                    <%= p.nombre %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">N° Factura / Referencia</label>
                        <input type="text" class="form-control" id="entradaFactura" placeholder="Ej: F-123">
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label small fw-bold">Notas o descripción</label>
                    <input type="text" class="form-control" id="entradaRef" placeholder="Ej: Compra mensual">
                </div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary"
                    data-bs-dismiss="modal">Cerrar</button><button type="button" class="btn btn-success"
                    id="btnConfirmarEntrada">Guardar Movimiento</button></div>
        </div>
    </div>
</div>

<!-- Modal Salida -->
<div class="modal fade" id="modalSalida" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header fw-bold">📤 Registrar Gasto / Salida - <span id="salidaInsumoNombre"></span></div>
            <div class="modal-body"><input type="hidden" id="salidaInsumoId">
                <p class="small text-muted">Disponible: <span id="salidaDisponible">0</span></p><label
                    class="form-label">¿Cuánto salió / se gastó?</label><input type="number" step="0.0001"
                    class="form-control" id="salidaCantidad"><label class="form-label mt-2">Referencia</label><input
                    type="text" class="form-control" id="salidaRef">
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary"
                    data-bs-dismiss="modal">Cerrar</button><button type="button" class="btn btn-danger"
                    id="btnConfirmarSalida">Registrar Gasto</button></div>
        </div>
    </div>
</div>

<!-- Modal Ajuste -->
<div class="modal fade" id="modalAjuste" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"><i class="bi bi-sliders me-2"></i>Ajuste Manual - <span
                        id="ajusteInsumoNombre"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="ajusteInsumoId">
                <p class="small text-muted mb-3">
                    <i class="bi bi-info-circle me-1"></i> Stock actual:
                    <span id="ajusteDisponible" class="fw-bold">0</span>
                </p>

                <div class="mb-3">
                    <label class="form-label fw-bold">¿Qué acción deseas realizar?</label>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="ajusteTipo" id="adjSuma" value="suma"
                                checked>
                            <label class="form-check-label text-success fw-bold" for="adjSuma">
                                <i class="bi bi-plus-circle me-1"></i> Sumar (Entrada)
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="ajusteTipo" id="adjResta" value="resta">
                            <label class="form-check-label text-danger fw-bold" for="adjResta">
                                <i class="bi bi-dash-circle me-1"></i> Restar (Salida)
                            </label>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Cantidad a ajustar</label>
                    <input type="number" step="0.0001" class="form-control form-control-lg" id="ajusteCantidad"
                        placeholder="0.00">
                    <div class="form-text">Ingresa el valor absoluto. El sistema lo sumará o restará según tu elección
                        arriba.</div>
                </div>

                <div class="mb-1">
                    <label class="form-label fw-bold">Motivo / Referencia</label>
                    <input type="text" class="form-control" id="ajusteRef" value="Ajuste manual">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary px-4" id="btnConfirmarAjuste">
                    Aplicar ajuste
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Lista de mercado -->
<div class="modal fade" id="modalListaMercado" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-cart-check me-2"></i>Lista de mercado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-1">
                    <i class="bi bi-info-circle me-1"></i>
                    Estos son los insumos que <strong>necesitan reponerse</strong> porque su cantidad actual está por
                    debajo del nivel mínimo que definiste.
                </p>
                <p class="text-muted small mb-3">
                    Cada fila muestra <strong>cuánto tienes</strong>, <strong>cuánto deberías tener como
                        mínimo</strong>, y <strong>cuánto te falta comprar</strong>.
                </p>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="listaMercadoIncluirCerca">
                    <label class="form-check-label" for="listaMercadoIncluirCerca">
                        <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                        Incluir también los que están <strong>cerca del mínimo</strong> (menos del 120% del mínimo)
                    </label>
                </div>
                <div id="listaMercadoContenido">
                    <ul class="list-group list-group-flush" id="listaMercadoItems"></ul>
                    <p class="text-muted small mt-2 mb-0" id="listaMercadoVacio" style="display:none;">No hay
                        insumos bajo stock.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" id="btnListaMercadoCopiar"
                    title="Copiar lista al portapapeles"><i class="bi bi-clipboard"></i> Copiar lista</button>
                <button type="button" class="btn btn-outline-primary" id="btnListaMercadoImprimir"
                    title="Imprimir lista"><i class="bi bi-printer"></i> Imprimir</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Movimientos -->
<div class="modal fade" id="modalMovimientos" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">Historial de movimientos - <span id="movInsumoNombre" class="fw-bold"></span>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive" style="max-height: 400px;">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="bg-light sticky-top">
                            <tr>
                                <th class="ps-3">Fecha</th>
                                <th>Tipo</th>
                                <th class="text-end">Cantidad</th>
                                <th>Ref / Factura</th>
                                <th>Proveedor</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyMovimientos">
                            <!-- Se llena vía JS -->
                        </tbody>
                    </table>
                </div>
                <div id="movimientosCargando" class="text-center py-4" style="display:none;">
                    <div class="spinner-border spinner-border-sm text-primary"></div> Cargando historial...
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
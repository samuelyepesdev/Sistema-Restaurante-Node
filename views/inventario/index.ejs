<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventario</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/css/modulos/inventario.css">

</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null, allowedByPlan: typeof allowedByPlan !=='undefined' ? allowedByPlan : {} }) %>

        <div class="container-fluid py-4">
            <div
                class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
                <div>
                    <h1 class="h4 mb-1"><i class="bi bi-boxes me-2"></i>Inventario</h1>
                    <div class="text-muted small">Control de insumos, stock y valorización.</div>
                </div>
                <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2">
                    <div class="search-box">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" id="buscarInsumo" class="form-control"
                                placeholder="Buscar por código o nombre">
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <span class="badge bg-secondary">Insumos: <%= (insumos || []).length %></span>
                        <span class="badge bg-success">Valor total: $<%= (resumen.valor_total !=null ?
                                Number(resumen.valor_total).toLocaleString('es-CO', { minimumFractionDigits: 2 })
                                : '0,00' ) %></span>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <div class="kpi-card">
                        <div class="kpi-label">Total insumos</div>
                        <div class="kpi-value">
                            <%= resumen.total_insumos !=null ? resumen.total_insumos : 0 %>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="kpi-card kpi-success">
                        <div class="kpi-label">Con stock</div>
                        <div class="kpi-value">
                            <%= resumen.con_stock !=null ? resumen.con_stock : 0 %>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="kpi-card kpi-warning">
                        <div class="kpi-label">Valor inventario</div>
                        <div class="kpi-value text-success">$<%= (resumen.valor_total !=null ?
                                Number(resumen.valor_total).toLocaleString('es-CO', { minimumFractionDigits: 0,
                                maximumFractionDigits: 0 }) : '0' ) %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-table">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="fw-bold text-slate-700"><i class="bi bi-list-ul me-2"></i>Insumos y stock</span>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-outline-warning rounded-pill px-3"
                            id="btnListaMercado" title="Ver insumos bajo stock o cerca del mínimo">
                            <i class="bi bi-cart-check"></i> Lista de mercado
                        </button>
                        <% if (user && user.permisos && user.permisos.includes('inventario.editar')) { %>
                            <button type="button" class="btn btn-sm btn-primary rounded-pill px-3"
                                data-bs-toggle="modal" data-bs-target="#modalNuevoInsumo">
                                <i class="bi bi-plus"></i> Nuevo insumo
                            </button>
                            <% } %>
                    </div>
                </div>
                <div class="card-body p-0">
                    <%- include('_table', { insumos: typeof insumos !=='undefined' ? insumos : [] }) %>
                </div>
            </div>
        </div>

        <%- include('_modales', { categoriasInsumo: typeof categoriasInsumo !=='undefined' ? categoriasInsumo : [],
            unidadesCompra: typeof unidadesCompra !=='undefined' ? unidadesCompra : [] }) %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script src="/js/ui-utils.js"></script>
            <%- include('_scripts') %>
</body>

</html>
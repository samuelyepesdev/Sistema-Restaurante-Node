<!-- Modal Receta -->
<div class="modal fade" id="modalReceta" tabindex="-1">
        <div class="modal-dialog modal-lg">
                <div class="modal-content">
                        <div class="modal-header">
                                <h5 class="modal-title" id="modalRecetaTitulo">
                                        <i class="bi bi-journal-text me-2"></i>Nueva receta
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                                <input type="hidden" id="recetaId">

                                <div class="mb-3">
                                        <label class="form-label fw-semibold">Producto <span
                                                        class="text-danger">*</span></label>
                                        <select class="form-select" id="recetaProductoId" required></select>
                                        <div class="form-text">El plato o producto del menú que prepara esta receta.
                                        </div>
                                </div>

                                <div class="mb-3">
                                        <label class="form-label fw-semibold">Nombre de la receta <span
                                                        class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="recetaNombre"
                                                placeholder="Ej: Hamburguesa clásica con papas">
                                        <div class="form-text">Puede ser el mismo nombre del producto o una variación.
                                        </div>
                                </div>

                                <div class="mb-3">
                                        <label class="form-label fw-semibold">
                                                Porciones (rendimiento)
                                                <i class="bi bi-question-circle text-muted ms-1"
                                                        data-bs-toggle="tooltip"
                                                        title="¿Cuántas unidades del producto produce esta receta? Ej: si la receta da para 2 hamburguesas, pon 2."></i>
                                        </label>
                                        <input type="number" step="0.01" class="form-control" id="recetaPorciones"
                                                value="1" min="1">
                                        <div class="form-text">Normalmente es 1 (la receta produce 1 plato). Cambia si
                                                la receta produce más de uno.</div>
                                </div>

                                <hr class="my-3">

                                <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div>
                                                <label class="form-label fw-semibold mb-0">Ingredientes</label>
                                                <div class="form-text mt-0">Los insumos del inventario que se usan para
                                                        preparar este plato.</div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                id="btnAgregarIngrediente">
                                                <i class="bi bi-plus-lg me-1"></i> Agregar ingrediente
                                        </button>
                                </div>

                                <div class="table-responsive">
                                        <table class="table table-sm mb-0">
                                                <thead>
                                                        <tr class="table-light small text-muted">
                                                                <th>Insumo</th>
                                                                <th style="width:120px">Cantidad</th>
                                                                <th style="width:80px">Unidad</th>
                                                                <th style="width:60px"></th>
                                                        </tr>
                                                </thead>
                                                <tbody id="recetaIngredientesContainer"></tbody>
                                        </table>
                                </div>
                                <div class="form-text mt-1">
                                        <i class="bi bi-info-circle me-1"></i>
                                        Al vender este producto, el sistema descontará automáticamente estas cantidades
                                        del inventario.
                                </div>
                        </div>
                        <div class="modal-footer">
                                <button type="button" class="btn btn-secondary"
                                        data-bs-dismiss="modal">Cancelar</button>
                                <button type="button" class="btn btn-primary" id="btnGuardarReceta">
                                        <i class="bi bi-check-lg me-1"></i> Guardar receta
                                </button>
                        </div>
                </div>
        </div>
</div>
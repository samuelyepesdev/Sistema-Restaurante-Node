<!-- Modal Receta (simplificado: producto, nombre, porciones, ingredientes) -->
<div class="modal fade" id="modalReceta" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalRecetaTitulo">Nueva receta</h5><button type="button" class="btn-close"
                    data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="recetaId">
                <div class="mb-2"><label class="form-label">Producto</label><select class="form-select"
                        id="recetaProductoId" required></select></div>
                <div class="mb-2"><label class="form-label">Nombre de la receta</label><input type="text"
                        class="form-control" id="recetaNombre" placeholder="Ej: Hamburguesa clásica"></div>
                <div class="mb-3"><label class="form-label">Porciones (rendimiento)</label><input type="number"
                        step="0.01" class="form-control" id="recetaPorciones" value="1"></div>
                <label class="form-label">Ingredientes (insumos del inventario)</label>
                <div id="recetaIngredientesContainer"></div>
                <button type="button" class="btn btn-sm btn-outline-secondary mt-2" id="btnAgregarIngrediente"><i
                        class="bi bi-plus"></i> Agregar ingrediente</button>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary"
                    data-bs-dismiss="modal">Cerrar</button><button type="button" class="btn btn-primary"
                    id="btnGuardarReceta">Guardar</button></div>
        </div>
    </div>
</div>
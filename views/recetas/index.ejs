<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recetas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/css/recetas.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null, allowedByPlan: typeof allowedByPlan !=='undefined' ? allowedByPlan : {} }) %>

        <div class="container-fluid py-4">
            <div
                class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-3">
                <div>
                    <h1 class="h4 mb-1"><i class="bi bi-journal-text me-2"></i>Recetas</h1>
                    <p class="text-muted small mb-0">Cada receta descuenta insumos del inventario cuando se vende el
                        producto asociado.</p>
                </div>
                <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2">
                    <div class="search-box">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" id="buscarReceta" class="form-control"
                                placeholder="Buscar por producto o receta">
                        </div>
                    </div>
                    <% if (user && user.permisos && user.permisos.includes('recetas.editar')) { %>
                        <button type="button" id="btnNuevaReceta" class="btn btn-sm btn-primary" data-bs-toggle="modal"
                            data-bs-target="#modalReceta">
                            <i class="bi bi-plus-lg me-1"></i> Nueva receta
                        </button>
                        <% } %>
                </div>
            </div>

            <%- include('_table', { recetas: typeof recetas !=='undefined' ? recetas : [] }) %>
        </div>

        <%- include('_modal_form') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <%- include('_scripts') %>
</body>

</html>
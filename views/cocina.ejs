<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cocina</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .navbar {
            background-color: #2c3e50;
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
        }
        .navbar-brand {
            color: #fff !important;
            font-weight: bold;
        }
        .mesa-card {
            border: none;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
            margin-bottom: 1.5rem;
        }
        .mesa-card .card-header {
            font-size: 1.1rem;
            font-weight: 600;
            border-bottom: 2px solid rgba(255,255,255,0.2);
        }
        .item-card {
            border: 1px solid #e0e0e0;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            background-color: #fff;
        }
        .item-card:last-child {
            margin-bottom: 0 !important;
        }
        .producto {
            font-size: 1.1rem;
            font-weight: 600;
            color: #2c3e50;
        }
        .cantidad-badge {
            font-size: 0.9rem;
        }
        @media (max-width: 768px) {
            .nav-tabs .nav-link {
                padding: 0.5rem 0.75rem;
                font-size: 0.95rem;
            }
            .card {
                margin-bottom: 1rem;
            }
            #listaCola::before,
            #listaListos::before {
                content: '';
                display: block;
                height: 1rem;
            }
            .item-card {
                flex-direction: column;
                padding: 0.75rem;
            }
            .item-card .row {
                flex-direction: column;
            }
            .card:not(.no-card-dark) {
                background-color: #e2e8f0;
                border-color: #cbd5f5;
            }
        }
    </style>
</head>
<body data-user-role="<%= user && user.rol ? user.rol : '' %>">
    <%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

    <div class="container">
        <h4 class="mb-3"><i class="bi bi-egg-fried me-2"></i>Cola de Cocina</h4>
        <ul class="nav nav-tabs" id="tabsCocina" role="tablist">
            <% if (user && user.rol !== 'mesero') { %>
            <li class="nav-item" role="presentation">
                <a class="nav-link active" id="tabCola-tab" data-bs-toggle="tab" href="#tabCola" data-bs-target="#tabCola" role="tab" aria-controls="tabCola" aria-selected="true">
                    En cocina
                </a>
            </li>
            <% } %>
            <li class="nav-item" role="presentation">
                <a class="nav-link <%= user && user.rol === 'mesero' ? 'active' : '' %>" id="tabListos-tab" data-bs-toggle="tab" href="#tabListos" data-bs-target="#tabListos" role="tab" aria-controls="tabListos" aria-selected="<%= user && user.rol === 'mesero' ? 'true' : 'false' %>">
                    Listos
                </a>
            </li>
        </ul>
        <div class="tab-content pt-3">
            <% if (user && user.rol !== 'mesero') { %>
            <div class="tab-pane fade show active" id="tabCola" role="tabpanel" aria-labelledby="tabCola-tab">
                <div class="card">
                    <div class="card-header">En cola / Preparando</div>
                    <div class="card-body">
                        <div id="listaCola" class="vstack gap-2"></div>
                    </div>
                </div>
            </div>
            <% } %>
            <div class="tab-pane fade <%= user && user.rol === 'mesero' ? 'show active' : '' %>" id="tabListos" role="tabpanel" aria-labelledby="tabListos-tab">
                <div class="card">
                    <div class="card-header">Listos</div>
                    <div class="card-body">
                        <div id="listaListos" class="vstack gap-2"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cocina.js"></script>
</body>
</html>



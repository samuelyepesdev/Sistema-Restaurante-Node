<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Servicios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .page-title { font-size: 1.25rem; }
        .card { border: none; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .card-header { background: white; border-bottom: 1px solid #edf2f7; padding: 1.25rem; border-radius: 12px 12px 0 0 !important; }
        .badge-externo { background-color: #e2e8f0; color: #4a5568; }
        .badge-activo { background-color: #c6f6d5; color: #22543d; }
        .badge-inactivo { background-color: #fed7d7; color: #822727; }
    </style>
</head>

<body>
    <%- include('../partials/navbar', { user, tenant }) %>

    <div class="container py-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="page-title fw-bold">
                    <i class="bi bi-briefcase-fill me-2 text-primary"></i>Catálogo de Servicios
                </div>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalServicio">
                    <i class="bi bi-plus-lg me-1"></i>Nuevo Servicio
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Nombre</th>
                                <th>Descripción</th>
                                <th>Precio</th>
                                <th>Tipo</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (servicios.length === 0) { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No hay servicios registrados</td>
                                </tr>
                            <% } else { %>
                                <% servicios.forEach(s => { %>
                                    <tr>
                                        <td class="fw-bold"><%= s.nombre %></td>
                                        <td class="text-muted small"><%= s.descripcion || '-' %></td>
                                        <td class="fw-bold">$<%= Number(s.precio).toLocaleString() %></td>
                                        <td>
                                            <span class="badge badge-externo">
                                                <%= s.es_externo ? 'Externo (No suma venta)' : 'Propio' %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge <%= s.activo ? 'badge-activo' : 'badge-inactivo' %>">
                                                <%= s.activo ? 'Activo' : 'Inactivo' %>
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-info me-1 btn-edit" 
                                                    data-servicio='<%= JSON.stringify(s) %>'>
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger btn-delete" 
                                                    data-id="<%= s.id %>" data-nombre="<%= s.nombre %>">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Formulario -->
    <div class="modal fade" id="modalServicio" tabindex="-1">
        <div class="modal-dialog">
            <form id="formServicio" action="/servicios" method="POST">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalTitle">Nuevo Servicio</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="service_id" name="id">
                        <div class="mb-3">
                            <label class="form-label">Nombre del Servicio</label>
                            <input type="text" class="form-control" name="nombre" id="nombre" required placeholder="Ej: Domicilio Externo">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Descripción (Opcional)</label>
                            <textarea class="form-control" name="descripcion" id="descripcion" rows="2"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Precio al Cliente</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" step="0.01" class="form-control" name="precio" id="precio" required>
                            </div>
                        </div>
                        <div class="mb-3 form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="es_externo" id="es_externo" checked>
                            <label class="form-check-label">Servicio Externo (Costo = Precio, Ganancia 0)</label>
                            <div class="form-text text-danger">⚠️ Los servicios externos no se sumarán al volumen de ventas netas de productos en los reportes de ganancia.</div>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="activo" id="activo" checked>
                            <label class="form-check-label">Servicio Activo</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar Servicio</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(function() {
            const modal = new bootstrap.Modal('#modalServicio');
            const form = $('#formServicio');

            // Reset modal on close
            $('#modalServicio').on('hidden.bs.modal', function () {
                form[0].reset();
                form.attr('action', '/servicios');
                $('#modalTitle').text('Nuevo Servicio');
                $('#service_id').val('');
            });

            // Edit button handler
            $('.btn-edit').on('click', function() {
                const s = $(this).data('servicio');
                $('#modalTitle').text('Editar Servicio');
                form.attr('action', `/servicios/${s.id}/update`);
                $('#service_id').val(s.id);
                $('#nombre').val(s.nombre);
                $('#descripcion').val(s.descripcion);
                $('#precio').val(s.precio);
                $('#es_externo').prop('checked', !!s.es_externo);
                $('#activo').prop('checked', !!s.activo);
                modal.show();
            });

            // Delete handler
            $('.btn-delete').on('click', function() {
                const id = $(this).data('id');
                const nombre = $(this).data('nombre');
                
                Swal.fire({
                    title: '¿Estás seguro?',
                    text: `Vas a eliminar el servicio "${nombre}". Esta acción no se puede deshacer.`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const deleteForm = $('<form>', {
                            'action': `/servicios/${id}/delete`,
                            'method': 'POST'
                        });
                        $('body').append(deleteForm);
                        deleteForm.submit();
                    }
                });
            });
        });
    </script>
</body>

</html>

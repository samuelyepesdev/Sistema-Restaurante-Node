<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analítica y Predicción - Sistema Restaurante</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/analitica.css">
</head>
<body>
<%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null, tenant: typeof tenant !== 'undefined' ? tenant : null, allowedByPlan: typeof allowedByPlan !== 'undefined' ? allowedByPlan : {} }) %>

<div class="container-fluid py-4">
    <div class="analitica-header">
        <h1 class="mb-1"><i class="bi bi-graph-up-arrow me-2"></i>Analítica y Predicción</h1>
        <p class="mb-0 opacity-90">Resumen de ventas y estimaciones basadas en los últimos 3 meses (plan Premium).</p>
    </div>

    <ul class="nav nav-tabs mb-3" id="analiticaTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-analisis" data-bs-toggle="tab" data-bs-target="#panel-analisis" type="button">Análisis</button>
        </li>
        <% if (typeof canShowPrediccion !== 'undefined' && canShowPrediccion) { %>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-prediccion" data-bs-toggle="tab" data-bs-target="#panel-prediccion" type="button">Predicción</button>
        </li>
        <% } %>
    </ul>

    <div class="tab-content" id="analiticaTabContent">
        <!-- Pestaña Análisis -->
        <div class="tab-pane fade show active" id="panel-analisis" role="tabpanel">
            <div class="card card-analitica">
                <div class="card-header"><i class="bi bi-bar-chart me-2"></i>Últimos 3 meses</div>
                <div class="card-body">
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="kpi-box">
                                <div class="valor" id="kpi-total"><%= (typeof resumen !== 'undefined' && resumen && typeof resumen.totalGeneral === 'number') ? resumen.totalGeneral.toLocaleString('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }) : '$0' %></div>
                                <div class="label">Total ventas (3 meses)</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="kpi-box">
                                <div class="valor" id="kpi-facturas"><%= (typeof resumen !== 'undefined' && resumen && typeof resumen.cantidadFacturas === 'number') ? resumen.cantidadFacturas : 0 %></div>
                                <div class="label">Facturas emitidas</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="kpi-box">
                                <div class="valor" id="kpi-promedio"><%= (typeof resumen !== 'undefined' && resumen && resumen.meses && resumen.meses.length) ? (resumen.totalGeneral / resumen.meses.length).toLocaleString('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }) : '$0' %></div>
                                <div class="label">Promedio por mes</div>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-meses table-hover">
                            <thead><tr><th>Mes</th><th>Total ventas</th><th>Facturas</th></tr></thead>
                            <tbody>
                                <% if (typeof resumen !== 'undefined' && resumen && resumen.meses && resumen.meses.length) { %>
                                <% resumen.meses.forEach(m => { %>
                                <tr>
                                    <td><%= m.nombreMes %> <%= m.year %></td>
                                    <td><%= (m.total_ventas || 0).toLocaleString('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }) %></td>
                                    <td><%= m.cantidad_facturas || 0 %></td>
                                </tr>
                                <% }); %>
                                <% } else { %>
                                <tr><td colspan="3" class="text-muted">No hay datos de ventas en los últimos 3 meses.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pestaña Predicción (plan Premium o permiso prediccion.ver) -->
        <% if (typeof canShowPrediccion !== 'undefined' && canShowPrediccion) { %>
        <div class="tab-pane fade" id="panel-prediccion" role="tabpanel">
            <div class="card card-analitica">
                <div class="card-header"><i class="bi bi-cpu me-2"></i>Predicción próximo mes</div>
                <div class="card-body">
                    <% if (typeof prediccion !== 'undefined' && prediccion && prediccion.mensaje && prediccion.mesesUsados && prediccion.mesesUsados.length === 0) { %>
                    <p class="text-muted"><%= prediccion.mensaje %></p>
                    <% } else { %>
                    <p class="small text-muted mb-4"><%= typeof prediccion !== 'undefined' && prediccion && prediccion.mensaje ? prediccion.mensaje : '' %></p>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="prediccion-destacado">
                                <div class="label">Ventas estimadas (próximo mes)</div>
                                <div class="valor" id="pred-ventas"><%= (typeof prediccion !== 'undefined' && prediccion && typeof prediccion.ventasProximoMes === 'number') ? prediccion.ventasProximoMes.toLocaleString('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }) : '$0' %></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="kpi-box">
                                <div class="valor text-success" id="pred-ganancias"><%= (typeof prediccion !== 'undefined' && prediccion && prediccion.gananciasEsperadas != null) ? prediccion.gananciasEsperadas.toLocaleString('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }) : 'N/A' %></div>
                                <div class="label">Ganancias esperadas (aprox.)</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="rango-variacion">
                                <strong>Rango de variación</strong><br>
                                <span id="pred-rango"><%= (typeof prediccion !== 'undefined' && prediccion) ? (prediccion.rangoMin || 0).toLocaleString('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }) : '$0' %> – <%= (typeof prediccion !== 'undefined' && prediccion) ? (prediccion.rangoMax || 0).toLocaleString('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }) : '$0' %></span><br>
                                <small class="text-muted">Posible variación: ±<%= (typeof prediccion !== 'undefined' && prediccion && prediccion.posiblesPerdidasVariacion != null) ? prediccion.posiblesPerdidasVariacion.toLocaleString('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }) : '0' %></small>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

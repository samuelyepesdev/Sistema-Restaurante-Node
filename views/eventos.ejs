<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eventos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }
        .card { border: none; box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.05); margin-bottom: 1.5rem; }
        .card-header { background: #fff; border-bottom: 2px solid #f8f9fa; font-weight: 600; }
        .table th { border-top: none; }
    </style>
</head>
<body>
<%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null, tenant: typeof tenant !== 'undefined' ? tenant : null }) %>

<div class="container mt-4">
    <div class="card">
        <div class="card-header">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-3 w-100">
                <div class="fw-semibold">
                    <i class="bi bi-calendar-event me-2"></i>Eventos
                </div>
                <% if (user && user.permisos && user.permisos.includes('eventos.crear')) { %>
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalEvento" id="btnNuevoEvento">
                        <i class="bi bi-plus-lg me-1"></i>Nuevo evento
                    </button>
                </div>
                <% } %>
            </div>
        </div>
        <div class="card-body">
            <p class="text-muted small">Las ventas asociadas a un evento no afectan el análisis predictivo de ventas. Aquí puedes crear eventos y, al facturar, asociar la venta a un evento si corresponde.</p>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Fecha inicio</th>
                            <th>Fecha fin</th>
                            <th>Descripción</th>
                            <th>Estado</th>
                            <% if (user && user.permisos && (user.permisos.includes('eventos.editar') || user.permisos.includes('eventos.eliminar'))) { %><th class="text-end">Acciones</th><% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% (eventos || []).forEach(function(e) { %>
                        <tr>
                            <td><strong><%= e.nombre %></strong></td>
                            <td><%= e.fecha_inicio %></td>
                            <td><%= e.fecha_fin %></td>
                            <td><%= e.descripcion ? e.descripcion.substring(0, 50) + (e.descripcion.length > 50 ? '…' : '') : '—' %></td>
                            <td><span class="badge bg-<%= e.activo ? 'success' : 'secondary' %>"><%= e.activo ? 'Activo' : 'Inactivo' %></span></td>
                            <% if (user && user.permisos && (user.permisos.includes('eventos.editar') || user.permisos.includes('eventos.eliminar'))) { %>
                            <td class="text-end">
                                <% if (user.permisos.includes('eventos.editar')) { %>
                                <button type="button" class="btn btn-sm btn-outline-primary me-1" onclick="editarEvento(<%= e.id %>, '<%= (e.nombre || "").replace(/'/g, "\\'") %>', '<%= e.fecha_inicio %>', '<%= e.fecha_fin %>', '<%= (e.descripcion || "").replace(/'/g, "\\'") %>', <%= e.activo ? 'true' : 'false' %>)" title="Editar"><i class="bi bi-pencil"></i></button>
                                <% } %>
                                <% if (user.permisos.includes('eventos.eliminar')) { %>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="eliminarEvento(<%= e.id %>, '<%= (e.nombre || "").replace(/'/g, "\\'") %>')" title="Eliminar"><i class="bi bi-trash"></i></button>
                                <% } %>
                            </td>
                            <% } %>
                        </tr>
                        <% }); %>
                        <% if (!eventos || eventos.length === 0) { %>
                        <tr><td colspan="6" class="text-muted text-center py-4">No hay eventos. Crea uno para asociar ventas y excluirlas del análisis predictivo.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal crear/editar -->
<div class="modal fade" id="modalEvento" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalEventoTitle"><i class="bi bi-calendar-plus me-2"></i>Nuevo evento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="eventoId" value="">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input type="text" class="form-control" id="eventoNombre" placeholder="Ej: Feria navideña" required>
                </div>
                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label">Fecha inicio</label>
                        <input type="date" class="form-control" id="eventoFechaInicio" required>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Fecha fin</label>
                        <input type="date" class="form-control" id="eventoFechaFin" required>
                    </div>
                </div>
                <div class="mb-3 mt-2">
                    <label class="form-label">Descripción (opcional)</label>
                    <textarea class="form-control" id="eventoDescripcion" rows="2" placeholder="Descripción del evento"></textarea>
                </div>
                <div class="form-check" id="wrapActivo">
                    <input type="checkbox" class="form-check-input" id="eventoActivo" checked>
                    <label class="form-check-label" for="eventoActivo">Activo</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarEvento"><i class="bi bi-check-lg me-1"></i>Guardar</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
(function() {
    const modal = document.getElementById('modalEvento');
    const title = document.getElementById('modalEventoTitle');
    const idInp = document.getElementById('eventoId');
    const nombreInp = document.getElementById('eventoNombre');
    const fechaInicio = document.getElementById('eventoFechaInicio');
    const fechaFin = document.getElementById('eventoFechaFin');
    const descInp = document.getElementById('eventoDescripcion');
    const activoInp = document.getElementById('eventoActivo');
    const wrapActivo = document.getElementById('wrapActivo');

    document.getElementById('btnNuevoEvento') && document.getElementById('btnNuevoEvento').addEventListener('click', function() {
        idInp.value = '';
        title.innerHTML = '<i class="bi bi-calendar-plus me-2"></i>Nuevo evento';
        nombreInp.value = '';
        fechaInicio.value = '';
        fechaFin.value = '';
        descInp.value = '';
        activoInp.checked = true;
        wrapActivo.style.display = '';
    });

    window.editarEvento = function(id, nombre, fIni, fFin, desc, activo) {
        idInp.value = id;
        title.innerHTML = '<i class="bi bi-pencil me-2"></i>Editar evento';
        nombreInp.value = nombre || '';
        fechaInicio.value = fIni || '';
        fechaFin.value = fFin || '';
        descInp.value = desc || '';
        activoInp.checked = !!activo;
        wrapActivo.style.display = '';
        new bootstrap.Modal(modal).show();
    };

    window.eliminarEvento = function(id, nombre) {
        Swal.fire({
            title: '¿Eliminar evento?',
            text: nombre ? 'Se eliminará "' + nombre + '". Las facturas ya asociadas quedarán sin evento.' : '',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then(function(r) {
            if (!r.isConfirmed) return;
            fetch('/eventos/' + id, { method: 'DELETE', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' } })
                .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data }; }); })
                .then(function(o) {
                    if (o.ok) { Swal.fire({ icon: 'success', title: 'Evento eliminado' }); window.location.reload(); }
                    else Swal.fire({ icon: 'error', title: o.data.error || 'Error' });
                })
                .catch(function() { Swal.fire({ icon: 'error', title: 'Error de conexión' }); });
        });
    };

    document.getElementById('btnGuardarEvento').addEventListener('click', function() {
        var id = idInp.value;
        var payload = {
            nombre: nombreInp.value.trim(),
            fecha_inicio: fechaInicio.value,
            fecha_fin: fechaFin.value,
            descripcion: descInp.value.trim() || null,
            activo: activoInp.checked
        };
        if (!payload.nombre || !payload.fecha_inicio || !payload.fecha_fin) {
            Swal.fire({ icon: 'warning', title: 'Completa nombre, fecha inicio y fecha fin.' });
            return;
        }
        var url = id ? '/eventos/' + id : '/eventos';
        var method = id ? 'PUT' : 'POST';
        fetch(url, { method: method, credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
            .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data }; }); })
            .then(function(o) {
                if (o.ok) { bootstrap.Modal.getInstance(modal).hide(); Swal.fire({ icon: 'success', title: id ? 'Evento actualizado' : 'Evento creado' }); window.location.reload(); }
                else Swal.fire({ icon: 'error', title: o.data.error || 'Error' });
            })
            .catch(function() { Swal.fire({ icon: 'error', title: 'Error de conexión' }); });
    });
})();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conexión WhatsApp - <%= tenant.nombre %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .qr-container {
            background: white;
            padding: 2rem;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            max-width: 400px;
            margin: 2rem auto;
            text-align: center;
        }

        .status-badge {
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .status-connected {
            background: #dcfce7;
            color: #166534;
        }

        .status-disconnected {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-waiting {
            background: #fef3c7;
            color: #92400e;
        }

        .whatsapp-icon {
            font-size: 3rem;
            color: #25D366;
            margin-bottom: 1rem;
        }
    </style>
</head>

<body class="bg-light">
    <%- include('../partials/navbar', { user: user, tenant: tenant }) %>

        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-md-8 text-center">
                    <i class="bi bi-whatsapp whatsapp-icon"></i>
                    <h2 class="fw-bold mb-4">Conexión con WhatsApp</h2>
                    <p class="text-muted mb-5">Escanea el código QR para conectar tu restaurante y empezar a recibir
                        pedidos automáticos.</p>

                    <div id="statusContainer" class="mb-4">
                        <span id="statusBadge" class="status-badge status-disconnected">
                            <i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i>
                            <span id="statusText">Desconectado</span>
                        </span>
                    </div>

                    <div id="qrContainer" class="qr-container d-none">
                        <h5 class="mb-3">Escanea este código</h5>
                        <img id="qrImage" src="" alt="QR WhatsApp" class="img-fluid mb-3">
                        <p class="small text-muted">Abre WhatsApp en tu teléfono > Dispositivos vinculados > Vincular un
                            dispositivo.</p>
                    </div>

                    <div id="connectedContainer" class="qr-container d-none">
                        <div class="text-success mb-3">
                            <i class="bi bi-check-circle-fill" style="font-size: 4rem;"></i>
                        </div>
                        <h4 class="fw-bold">¡Sistema Conectado!</h4>
                        <p class="text-muted">Tu restaurante ya puede recibir pedidos de WhatsApp automáticamente.</p>
                        <button class="btn btn-outline-danger btn-sm mt-3" onclick="desconectar()">Desconectar</button>
                    </div>

                    <div id="actionButtons" class="mt-4">
                        <button id="btnConnect" class="btn btn-success px-4 py-2 fw-bold">
                            <i class="bi bi-plug-fill me-2"></i>Iniciar Conexión
                        </button>
                        <button id="btnCancel" class="btn btn-outline-secondary px-4 py-2 fw-bold d-none"
                            onclick="desconectar()">
                            <i class="bi bi-x-circle me-2"></i>Cancelar / Reiniciar
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            let pollingInterval;

            function updateUI(status, qr) {
                const $badge = $('#statusBadge');
                const $text = $('#statusText');
                const $qrContainer = $('#qrContainer');
                const $connectedContainer = $('#connectedContainer');
                const $btnConnect = $('#btnConnect');

                $badge.removeClass('status-connected status-disconnected status-waiting');
                $qrContainer.addClass('d-none');
                $connectedContainer.addClass('d-none');
                $btnConnect.prop('disabled', false).removeClass('d-none');
                $('#btnCancel').addClass('d-none');

                if (status === 'conectado') {
                    $badge.addClass('status-connected');
                    $text.text('Conectado');
                    $connectedContainer.removeClass('d-none');
                    $btnConnect.addClass('d-none');
                    $('#btnCancel').removeClass('d-none').text('Desconectar');
                } else if (status === 'esperando_qr') {
                    $badge.addClass('status-waiting');
                    $text.text('Esperando escaneo');
                    if (qr) {
                        $('#qrImage').attr('src', qr);
                        $qrContainer.removeClass('d-none');
                    }
                    $btnConnect.prop('disabled', true).text('Procesando...');
                    $('#btnCancel').removeClass('d-none').text('Cancelar / Reiniciar');
                } else {
                    $badge.addClass('status-disconnected');
                    $text.text('Desconectado');
                    $btnConnect.text('Iniciar Conexión');
                }
            }

            async function checkStatus() {
                try {
                    const res = await fetch('/whatsapp/status');
                    const data = await res.json();
                    updateUI(data.estado, data.last_qr);
                } catch (e) {
                    console.error('Error al verificar estado', e);
                }
            }

            $('#btnConnect').click(async function () {
                $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Iniciando...');
                try {
                    const res = await fetch('/whatsapp/connect', { method: 'POST' });
                    if (res.ok) {
                        Swal.fire('Iniciado', 'Estamos preparando el código QR...', 'info');
                        if (!pollingInterval) pollingInterval = setInterval(checkStatus, 3000);
                    }
                } catch (e) {
                    Swal.fire('Error', 'No se pudo iniciar la conexión', 'error');
                    $(this).prop('disabled', false).text('Iniciar Conexión');
                }
            });

            async function desconectar() {
                const result = await Swal.fire({
                    title: '¿Desconectar WhatsApp?',
                    text: 'Se cerrará la sesión actual y el bot dejará de responder.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, desconectar',
                    cancelButtonText: 'Cancelar'
                });

                if (result.isConfirmed) {
                    try {
                        const res = await fetch('/whatsapp/disconnect', { method: 'POST' });
                        if (res.ok) {
                            Swal.fire('Desconectado', 'La sesión ha sido cerrada.', 'success');
                            checkStatus();
                        }
                    } catch (e) {
                        Swal.fire('Error', 'No se pudo desconectar', 'error');
                    }
                }
            }

            // Iniciar polling si ya estaba en algún estado
            pollingInterval = setInterval(checkStatus, 3000);
            checkStatus();
        </script>
</body>

</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Costeo de Platos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }
        .card { border: none; box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.05); margin-bottom: 1.5rem; }
        .card-header { background-color: #fff; border-bottom: 2px solid #f8f9fa; font-weight: 600; }
        .nav-tabs .nav-link { font-weight: 500; }
        .costeo-resumen { background: #f0f7ff; border-radius: 0.5rem; padding: 1rem; }
        .ingredientes-table tbody tr:hover { background: #f8f9fa; }
    </style>
</head>
<body>
    <%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null, tenant: typeof tenant !== 'undefined' ? tenant : null }) %>

    <div class="container mt-4">
        <% if (typeof showTenantSelector !== 'undefined' && showTenantSelector && tenants && tenants.length) { %>
        <div class="card">
            <div class="card-header"><i class="bi bi-calculator me-2"></i>Costeo de Platos</div>
            <div class="card-body">
                <p class="text-muted">Seleccioná el restaurante para gestionar costeo (insumos, recetas, temas y parámetros).</p>
                <ul class="list-group list-group-flush">
                    <% tenants.forEach(function(t) { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><%= t.nombre %></span>
                        <a href="/costeo?tenant_id=<%= t.id %>" class="btn btn-sm btn-primary">Entrar</a>
                    </li>
                    <% }); %>
                </ul>
            </div>
        </div>
        <% } else { %>
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div><i class="bi bi-calculator me-2"></i>Costeo de Platos<% if (typeof tenant !== 'undefined' && tenant) { %> — <%= tenant.nombre %><% } %></div>
                <ul class="nav nav-tabs card-header-tabs" id="costeoTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="insumos-tab" data-bs-toggle="tab" data-bs-target="#insumos" type="button">Insumos</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="recetas-tab" data-bs-toggle="tab" data-bs-target="#recetas" type="button">Recetas</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="alertas-tab" data-bs-toggle="tab" data-bs-target="#alertas" type="button">Alertas</button>
                    </li>
                    <% if (user && String(user.rol || '').toLowerCase() === 'superadmin') { %>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="temas-tab" data-bs-toggle="tab" data-bs-target="#temas" type="button">Temas y parámetros</button>
                    </li>
                    <% } %>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="config-tab" data-bs-toggle="tab" data-bs-target="#config" type="button">Configuración</button>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content" id="costeoTabContent">
                    <!-- Tab Insumos -->
                    <div class="tab-pane fade show active" id="insumos" role="tabpanel">
                        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                            <input type="text" class="form-control form-control-sm" id="filtroInsumoQ" placeholder="Buscar por código o nombre..." style="max-width: 220px;">
                            <select class="form-select form-select-sm" id="filtroInsumoUnidad" style="max-width: 120px;">
                                <option value="">Todas las unidades</option>
                            </select>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnFiltrarInsumos">Filtrar</button>
                            <% if (user && user.permisos && user.permisos.includes('costeo.editar')) { %>
                            <button type="button" class="btn btn-primary btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#insumoModal" id="btnNuevoInsumo">
                                <i class="bi bi-plus-lg me-1"></i>Nuevo Insumo
                            </button>
                            <% } %>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover" id="tablaInsumos">
                                <thead><tr><th>Código</th><th>Nombre</th><th>Unidad compra</th><th>Costo unitario</th><th></th></tr></thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Tab Recetas -->
                    <div class="tab-pane fade" id="recetas" role="tabpanel">
                        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                            <input type="text" class="form-control form-control-sm" id="filtroRecetaQ" placeholder="Buscar por producto o receta..." style="max-width: 220px;">
                            <select class="form-select form-select-sm" id="filtroRecetaTema" style="max-width: 160px;">
                                <option value="">Tema</option>
                            </select>
                            <select class="form-select form-select-sm" id="filtroRecetaParametro" style="max-width: 160px;">
                                <option value="">Parámetro</option>
                            </select>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnFiltrarRecetas">Filtrar</button>
                            <% if (user && user.permisos && user.permisos.includes('costeo.editar')) { %>
                            <button type="button" class="btn btn-primary btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#recetaNuevaModal" id="btnNuevaReceta">
                                <i class="bi bi-plus-lg me-1"></i>Nueva Receta
                            </button>
                            <% } %>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover" id="tablaRecetas">
                                <thead><tr><th>Producto</th><th>Receta</th><th>Porciones</th><th>Precio venta</th><th></th></tr></thead>
                                <tbody></tbody>
                            </table>
                        </div>
                        <div id="costeoRecetaPanel" class="costeo-resumen mt-3 d-none">
                            <h6 class="mb-2"><i class="bi bi-graph-up me-1"></i>Resumen de costeo</h6>
                            <div class="row small">
                                <div class="col-md-3">Costo directo/porción: <strong id="costeoDirecto">-</strong></div>
                                <div class="col-md-3">Costo indirecto: <strong id="costeoIndirecto">-</strong></div>
                                <div class="col-md-3">Costo total/porción: <strong id="costeoTotal">-</strong></div>
                                <div class="col-md-3">Precio sugerido: <strong id="costeoPrecioSug">-</strong></div>
                            </div>
                            <div class="mt-2 small">Precio actual: <strong id="costeoPrecioActual">-</strong> · Margen actual: <strong id="costeoMargen">-</strong></div>
                        </div>
                    </div>

                    <!-- Tab Alertas -->
                    <div class="tab-pane fade" id="alertas" role="tabpanel">
                        <p class="text-muted small mb-3">Productos con margen bajo, precio bajo costo o sin receta asociada.</p>
                        <div id="alertasLoading" class="text-center py-4">
                            <div class="spinner-border text-primary"></div>
                            <p class="mt-2 mb-0 small text-muted">Cargando alertas...</p>
                        </div>
                        <div id="alertasContent" class="d-none">
                            <div class="card mb-3 border-warning">
                                <div class="card-header bg-warning bg-opacity-25">
                                    <i class="bi bi-exclamation-triangle me-2"></i>Margen bajo (por debajo del mínimo configurado)
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover mb-0">
                                            <thead><tr><th>Producto</th><th>Código</th><th class="text-end">Precio</th><th class="text-end">Costo/porción</th><th class="text-end">Margen %</th></tr></thead>
                                            <tbody id="alertasMargenBajo"></tbody>
                                        </table>
                                    </div>
                                    <div id="alertasMargenBajoVacio" class="p-3 text-muted small d-none">No hay productos con margen bajo.</div>
                                </div>
                            </div>
                            <div class="card mb-3 border-danger">
                                <div class="card-header bg-danger bg-opacity-25">
                                    <i class="bi bi-currency-dollar me-2"></i>Precio bajo costo
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover mb-0">
                                            <thead><tr><th>Producto</th><th>Código</th><th class="text-end">Precio</th><th class="text-end">Costo/porción</th></tr></thead>
                                            <tbody id="alertasPrecioBajo"></tbody>
                                        </table>
                                    </div>
                                    <div id="alertasPrecioBajoVacio" class="p-3 text-muted small d-none">No hay productos con precio bajo costo.</div>
                                </div>
                            </div>
                            <div class="card border-secondary">
                                <div class="card-header bg-secondary bg-opacity-25">
                                    <i class="bi bi-link-45deg me-2"></i>Productos sin receta
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover mb-0">
                                            <thead><tr><th>Producto</th><th>Código</th><th></th></tr></thead>
                                            <tbody id="alertasSinReceta"></tbody>
                                        </table>
                                    </div>
                                    <div id="alertasSinRecetaVacio" class="p-3 text-muted small d-none">Todos los productos tienen receta asociada.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tab Temas y parámetros -->
                    <div class="tab-pane fade" id="temas" role="tabpanel">
                        <p class="text-muted small mb-3">Temas agrupan parámetros (ej: tema "Unidades de masa" → kg, lb, g; tema "Alimentos" → bebidas, comidas). Asigná parámetros a cada tema.</p>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="card h-100">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <span><i class="bi bi-collection me-2"></i>Temas</span>
                                        <% if (user && String(user.rol || '').toLowerCase() === 'superadmin') { %>
                                        <button type="button" class="btn btn-sm btn-primary" id="btnNuevoTema"><i class="bi bi-plus"></i></button>
                                        <% } %>
                                    </div>
                                    <div class="card-body p-0">
                                        <ul class="list-group list-group-flush" id="listaTemas"></ul>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="card h-100">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <span><i class="bi bi-tags me-2"></i>Parámetros</span>
                                        <% if (user && String(user.rol || '').toLowerCase() === 'superadmin') { %>
                                        <button type="button" class="btn btn-sm btn-primary" id="btnNuevoParametro"><i class="bi bi-plus"></i></button>
                                        <% } %>
                                    </div>
                                    <div class="card-body p-0">
                                        <ul class="list-group list-group-flush" id="listaParametros"></ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card d-none" id="cardTemaParametros">
                            <div class="card-header">
                                <i class="bi bi-link-45deg me-2"></i>Parámetros del tema: <strong id="temaParametrosNombre"></strong>
                            </div>
                            <div class="card-body">
                                <p class="small text-muted">Seleccioná los parámetros que pertenecen a este tema.</p>
                                <div id="checkboxesParametrosTema"></div>
                                <button type="button" class="btn btn-sm btn-primary mt-2" id="btnGuardarTemaParametros">Guardar</button>
                            </div>
                        </div>
                    </div>

                    <!-- Tab Configuración -->
                    <div class="tab-pane fade" id="config" role="tabpanel">
                        <form id="formConfigCosteo">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Método de costos indirectos</label>
                                    <select class="form-select" name="metodo_indirectos" id="configMetodo">
                                        <option value="porcentaje">Porcentaje sobre costo directo</option>
                                        <option value="costo_fijo">Costo fijo mensual repartido</option>
                                        <option value="factor">Factor de carga (sin indirecto explícito)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3" id="rowPorcentaje">
                                <div class="col-md-4">
                                    <label class="form-label">Porcentaje indirectos (%)</label>
                                    <input type="number" class="form-control" name="porcentaje_indirectos" id="configPorcentaje" step="0.01" min="0">
                                </div>
                            </div>
                            <div class="row mb-3 d-none" id="rowCostoFijo">
                                <div class="col-md-4">
                                    <label class="form-label">Costo fijo mensual</label>
                                    <input type="number" class="form-control" name="costo_fijo_mensual" id="configCostoFijo" step="0.01" min="0">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Platos estimados/mes</label>
                                    <input type="number" class="form-control" name="platos_estimados_mes" id="configPlatosMes" min="1">
                                </div>
                            </div>
                            <div class="row mb-3 d-none" id="rowFactor">
                                <div class="col-md-4">
                                    <label class="form-label">Factor de carga</label>
                                    <input type="number" class="form-control" name="factor_carga" id="configFactor" step="0.01" min="1">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label class="form-label">Margen objetivo por defecto (%)</label>
                                    <input type="number" class="form-control" name="margen_objetivo_default" id="configMargen" step="0.01" min="0" max="100">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Margen mínimo para alerta (%)</label>
                                    <input type="number" class="form-control" name="margen_minimo_alerta" id="configMargenMinimoAlerta" step="0.01" min="0" max="100" title="Productos con margen por debajo de este valor aparecerán en Alertas">
                                </div>
                            </div>
                            <% if (user && user.permisos && user.permisos.includes('costeo.editar')) { %>
                            <button type="submit" form="formConfigCosteo" class="btn btn-primary"><i class="bi bi-save me-1"></i>Guardar configuración</button>
                            <% } %>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <% } %>
    </div>

    <!-- Modal Insumo -->
    <div class="modal fade" id="insumoModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="insumoModalTitle">Nuevo Insumo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="insumoId">
                    <div class="mb-2">
                        <label class="form-label">Código</label>
                        <input type="text" class="form-control" id="insumoCodigo" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="insumoNombre" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Unidad de compra</label>
                        <select class="form-select" id="insumoUnidad">
                            <option value="UND">UND</option>
                            <option value="kg">kg</option>
                            <option value="g">g</option>
                            <option value="L">L</option>
                            <option value="ml">ml</option>
                            <option value="lb">lb</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Costo unitario</label>
                        <input type="number" class="form-control" id="insumoCosto" step="0.01" min="0" value="0">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarInsumo">Guardar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Nueva Receta -->
    <div class="modal fade" id="recetaNuevaModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nueva Receta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Producto</label>
                        <select class="form-select" id="recetaProductoId" required>
                            <option value="">Seleccione producto</option>
                            <% (productos || []).forEach(function(p) { %>
                            <option value="<%= p.id %>"><%= p.codigo %> - <%= p.nombre %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Nombre de la receta</label>
                        <input type="text" class="form-control" id="recetaNombreNueva" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Porciones</label>
                        <input type="number" class="form-control" id="recetaPorcionesNueva" step="0.01" min="0.01" value="1">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnCrearReceta">Crear</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Editar Receta (ingredientes) -->
    <div class="modal fade" id="recetaEditarModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="recetaEditarTitle">Editar Receta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="recetaId">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Nombre receta</label>
                            <input type="text" class="form-control" id="recetaNombre">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Porciones</label>
                            <input type="number" class="form-control" id="recetaPorciones" step="0.01" min="0.01">
                        </div>
                    </div>
                    <h6 class="mt-3">Ingredientes</h6>
                    <div class="table-responsive">
                        <table class="table table-sm ingredientes-table" id="tablaIngredientes">
                            <thead><tr><th>Insumo</th><th>Cantidad</th><th>Unidad</th><th></th></tr></thead>
                            <tbody id="ingredientesBody"></tbody>
                        </table>
                    </div>
                    <div class="d-flex align-items-center gap-2 mt-2">
                        <select class="form-select form-select-sm" id="ingredienteInsumo" style="max-width: 220px;"></select>
                        <input type="number" class="form-control form-control-sm" id="ingredienteCantidad" placeholder="Cantidad" step="0.001" style="max-width: 100px;">
                        <select class="form-select form-select-sm" id="ingredienteUnidad" style="max-width: 90px;">
                            <option value="g">g</option>
                            <option value="kg">kg</option>
                            <option value="ml">ml</option>
                            <option value="L">L</option>
                            <option value="UND">UND</option>
                            <option value="lb">lb</option>
                        </select>
                        <button type="button" class="btn btn-outline-primary btn-sm" id="btnAgregarIngrediente"><i class="bi bi-plus"></i> Agregar</button>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarReceta">Guardar receta</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Tema -->
    <div class="modal fade" id="temaModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="temaModalTitle">Nuevo Tema</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="temaId">
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="temaNombre" placeholder="ej: Unidades de masa, Alimentos">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarTema">Guardar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Parámetro -->
    <div class="modal fade" id="parametroModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="parametroModalTitle">Nuevo Parámetro</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="parametroId">
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="parametroNombre" placeholder="ej: kg, bebidas, comidas">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarParametro">Guardar</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        window.USER_PERMISOS = <%= typeof user !== 'undefined' && user && user.permisos ? JSON.stringify(user.permisos) : '[]' %>;
        window.USER_ROL = <%= typeof user !== 'undefined' && user && user.rol ? JSON.stringify(user.rol) : '""' %>;
        window.COSTEO_TENANT_ID = <%= typeof tenant !== 'undefined' && tenant && tenant.id ? tenant.id : 'null' %>;
        window.COSTEO_SHOW_TENANT_SELECTOR = <%= typeof showTenantSelector !== 'undefined' && showTenantSelector ? 'true' : 'false' %>;
    </script>
    <script src="/js/costeo.js"></script>
</body>
</html>

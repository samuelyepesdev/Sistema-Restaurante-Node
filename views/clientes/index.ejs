<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Clientes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/clientes.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null }) %>

        <div class="container">
            <div class="card">
                <div class="card-header">
                    <div
                        class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-3 w-100">
                        <div class="page-title fw-semibold">
                            <i class="bi bi-people-fill me-2"></i>Gestión de Clientes
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#clienteModal">
                                <i class="bi bi-plus-lg me-1"></i>Nuevo Cliente
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col">
                            <div class="input-group search-box ms-auto">
                                <span class="input-group-text">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input type="text" class="form-control" id="buscarCliente"
                                    placeholder="Buscar cliente...">
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Nombre / Documento</th>
                                    <th>Email / Teléfono</th>
                                    <th>Dirección</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="clientesTabla">
                                <% clientes.forEach(function(cliente) { %>
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">
                                                <%= cliente.nombre %>
                                            </div>
                                            <div class="text-muted small">
                                                <%= cliente.tipo_documento %>: <%= cliente.numero_documento || '-' %>
                                            </div>
                                        </td>
                                        <td>
                                            <div>
                                                <%= cliente.email || '-' %>
                                            </div>
                                            <div class="text-muted small">
                                                <%= cliente.telefono || 'No especificado' %>
                                            </div>
                                        </td>
                                        <td>
                                            <%= cliente.direccion || 'No especificada' %>
                                        </td>
                                        <td class="text-center">
                                            <div class="action-buttons">
                                                <button class="btn btn-sm btn-outline-primary me-1"
                                                    data-cliente-id="<%= cliente.id %>" data-action="editar"
                                                    title="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger"
                                                    data-cliente-id="<%= cliente.id %>" data-action="eliminar"
                                                    title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Cliente -->
        <div class="modal fade" id="clienteModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-person-fill me-2"></i>
                            <span id="modalTitle">Nuevo Cliente</span>
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <form id="formCliente">
                            <input type="hidden" id="clienteId">
                            <div class="row">
                                <div class="col-4 mb-3">
                                    <label class="form-label">Tipo Doc.</label>
                                    <select class="form-select" id="tipo_documento" name="tipo_documento">
                                        <% if (typeof tiposDocumento !=='undefined' && tiposDocumento.length> 0) { %>
                                            <% tiposDocumento.forEach(function(tipo) { %>
                                                <option value="<%= tipo.name %>">
                                                    <%= tipo.name %>
                                                </option>
                                                <% }); %>
                                                    <% } else { %>
                                                        <option value="CC" selected>CC</option>
                                                        <option value="NIT">NIT</option>
                                                        <% } %>
                                    </select>
                                </div>
                                <div class="col-8 mb-3">
                                    <label class="form-label">Núm. de Documento (NIT/CC)</label>
                                    <input type="text" class="form-control" id="numero_documento"
                                        name="numero_documento" placeholder="000.000.000-0">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" name="email"
                                    placeholder="cliente@ejemplo.com">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Nombre / Razón Social</label>
                                <input type="text" class="form-control" id="nombre" name="nombre" required>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Teléfono</label>
                                    <input type="text" class="form-control" id="telefono" name="telefono"
                                        inputmode="numeric" pattern="[0-9]*" maxlength="15" placeholder="Solo números">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Dirección</label>
                                    <input type="text" class="form-control" id="direccion" name="direccion">
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-primary" id="guardarCliente">
                            <i class="bi bi-save me-1"></i>
                            Guardar
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <!-- Load modules -->
        <script src="/js/modules/Utils.js"></script>
        <script src="/js/modules/ApiClient.js"></script>
        <script src="/js/modules/AlertManager.js"></script>
        <script src="/js/modules/SearchManager.js"></script>
        <script src="/js/modules/FormManager.js"></script>
        <script src="/js/modules/TableManager.js"></script>
        <!-- Load main script -->
        <script src="/js/clientes-refactored.js"></script>
</body>

</html>

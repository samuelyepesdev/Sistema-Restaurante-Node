<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Clientes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/modulos/clientes.css">
</head>

<body>
    <%- include('../partials/navbar', { user: typeof user !=='undefined' ? user : null, tenant: typeof tenant
        !=='undefined' ? tenant : null }) %>

        <div class="container">
            <div class="card">
                <div class="card-header">
                    <div
                        class="d-flex flex-column flex-md-row justify-content-between align-items-stretch align-items-md-center gap-3 w-100">
                        <div class="page-title fw-semibold">
                            <i class="bi bi-people-fill me-2"></i>Gestión de Clientes
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <% if (user && user.permisos && user.permisos.includes('clientes.crear')) { %>
                                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#clienteModal">
                                    <i class="bi bi-plus-lg me-1"></i>Nuevo Cliente
                                </button>
                                <% } %>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <%- include('_table', { clientes: clientes }) %>
                </div>
            </div>
        </div>

        <%- include('_modal_form', { tiposDocumento: (typeof tiposDocumento !=='undefined' ? tiposDocumento : []) }) %>

            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <!-- Load modules -->
            <script src="/js/core/modules/Utils.js"></script>
            <script src="/js/core/modules/ApiClient.js"></script>
            <script src="/js/core/modules/AlertManager.js"></script>
            <script src="/js/core/modules/SearchManager.js"></script>
            <script src="/js/core/modules/FormManager.js"></script>
            <script src="/js/core/modules/TableManager.js"></script>
            <!-- Load main script -->
            <script src="/js/modulos/clientes-refactored.js"></script>
</body>

</html>
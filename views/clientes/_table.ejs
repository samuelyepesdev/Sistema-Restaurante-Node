<div class="row mb-4">
    <div class="col">
        <div class="input-group search-box ms-auto">
            <span class="input-group-text">
                <i class="bi bi-search"></i>
            </span>
            <input type="text" class="form-control" id="buscarCliente" placeholder="Buscar cliente...">
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Nombre / Documento</th>
                <th>Email / Teléfono</th>
                <th>Dirección</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody id="clientesTabla">
            <% clientes.forEach(function(cliente) { %>
                <tr>
                    <td>
                        <div class="fw-semibold">
                            <%= cliente.nombre %>
                        </div>
                        <div class="text-muted small">
                            <%= cliente.tipo_documento %>: <%= cliente.numero_documento || '-' %>
                        </div>
                    </td>
                    <td>
                        <div>
                            <%= cliente.email || '-' %>
                        </div>
                        <div class="text-muted small">
                            <%= cliente.telefono || 'No especificado' %>
                        </div>
                    </td>
                    <td>
                        <%= cliente.direccion || 'No especificada' %>
                    </td>
                    <td class="text-center">
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-outline-primary me-1" data-cliente-id="<%= cliente.id %>"
                                data-action="editar" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" data-cliente-id="<%= cliente.id %>"
                                data-action="eliminar" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }); %>
        </tbody>
    </table>
</div>

<!-- Vista Móvil: Lista de Cartas -->
<div class="clientes-mobile-list" id="clientesListaMobile">
    <% clientes.forEach(function(cliente) { %>
        <div class="cliente-card" data-cliente-id="<%= cliente.id %>">
            <div class="cliente-info-row">
                <div class="cliente-main-info">
                    <span class="cliente-name">
                        <%= cliente.nombre %>
                    </span>
                    <span class="cliente-doc">
                        <%= cliente.tipo_documento %>: <%= cliente.numero_documento || '-' %>
                    </span>
                </div>
            </div>

            <div class="cliente-details">
                <div class="detail-item">
                    <span class="detail-label">Teléfono</span>
                    <%= cliente.telefono || 'Sin tel' %>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Email</span>
                    <%= cliente.email || 'Sin email' %>
                </div>
                <div class="detail-item" style="grid-column: span 2;">
                    <span class="detail-label">Dirección</span>
                    <%= cliente.direccion || 'Sin dirección' %>
                </div>
            </div>

            <div class="cliente-actions">
                <button class="btn btn-outline-primary" data-cliente-id="<%= cliente.id %>" data-action="editar">
                    <i class="bi bi-pencil me-1"></i> Editar
                </button>
                <button class="btn btn-outline-danger" data-cliente-id="<%= cliente.id %>" data-action="eliminar">
                    <i class="bi bi-trash me-1"></i> Borrar
                </button>
            </div>
        </div>
        <% }); %>
</div>
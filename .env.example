# Database Configuration
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Server Configuration
PORT=
NODE_ENV=

# JWT Configuration
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Mínimo 32 caracteres requeridos
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Admin User Configuration (for scripts)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_NOMBRE=

# Correo / SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Sentry (opcional) — obtener en sentry.io
# Si está vacío, el error tracking queda deshabilitado
SENTRY_DSN=

# E2E Tests (Playwright) — credenciales del usuario de prueba
E2E_BASE_URL=http://localhost:3000
E2E_ADMIN_USER=admin
E2E_ADMIN_PASS=admin123

